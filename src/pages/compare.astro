---
import Layout from '../layouts/Layout.astro';
import { allCities } from '../data/cities/index';
import { formatCurrency, getFireScoreClass, getTotalSpend, SAFE_WITHDRAWAL_RATE } from '../data/types';
import type { CityData } from '../data/types';
import {
  getCityFireNumber,
  getLifestyleMonthlyCost,
  formatFireNumber,
  getCityDisplayTags,
  LIFESTYLE_LABELS,
  ALL_LIFESTYLE_TIERS,
  LIFESTYLE_TIER_MAP,
} from '../data/fireNumber';
import type { LifestyleTier } from '../data/fireNumber';

// Build client-side data
const cityDataForClient = allCities.map((city) => {
  const tags = getCityDisplayTags(city);
  const tiers: Record<string, { fireNumber: number; monthlyCost: number }> = {};
  for (const lifestyle of ALL_LIFESTYLE_TIERS) {
    tiers[lifestyle] = {
      fireNumber: getCityFireNumber(city, lifestyle),
      monthlyCost: getLifestyleMonthlyCost(city, lifestyle),
    };
  }
  return {
    slug: city.slug,
    name: city.name,
    country: city.country,
    emoji: city.emoji,
    fireScore: city.fireScore,
    scores: city.scores,
    tiers,
    tags,
  };
});

const cityDataJSON = JSON.stringify(cityDataForClient);

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://portfolioatlas.org' },
    { '@type': 'ListItem', 'position': 2, 'name': 'Compare', 'item': 'https://portfolioatlas.org/compare' },
  ],
};
---

<Layout
  title="Compare FIRE Destinations Side by Side"
  description="Compare FIRE Numbers across 100+ cities worldwide. See how much you need to retire in each city at Budget, Comfortable, and Luxury levels."
  jsonLd={breadcrumbLd}
>
  <section class="bg-brand-950 text-white py-16">
    <div class="container-narrow text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">
        Compare Destinations
      </h1>
      <p class="text-xl text-sand-300 max-w-2xl mx-auto">
        Pick two cities and compare FIRE Numbers side by side, or browse all 100+ cities below.
      </p>
    </div>
  </section>

  <!-- City Picker -->
  <section class="container-narrow py-8">
    <div class="bg-white rounded-2xl shadow-sm border border-sand-200 p-6">
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <div class="flex-1 w-full relative" id="picker-a">
          <label class="block text-sm font-semibold text-gray-600 mb-1">City A</label>
          <input
            type="text"
            id="city-input-a"
            placeholder="Type a city name..."
            autocomplete="off"
            class="w-full rounded-lg border border-sand-200 px-4 py-2.5 text-sm font-medium text-gray-800 bg-sand-50 focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
          />
          <input type="hidden" id="city-select-a" />
          <div id="city-dropdown-a" class="city-dropdown hidden"></div>
        </div>
        <div class="text-2xl font-bold text-gray-300 mt-5 hidden sm:block">vs</div>
        <div class="flex-1 w-full relative" id="picker-b">
          <label class="block text-sm font-semibold text-gray-600 mb-1">City B</label>
          <input
            type="text"
            id="city-input-b"
            placeholder="Type a city name..."
            autocomplete="off"
            class="w-full rounded-lg border border-sand-200 px-4 py-2.5 text-sm font-medium text-gray-800 bg-sand-50 focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
          />
          <input type="hidden" id="city-select-b" />
          <div id="city-dropdown-b" class="city-dropdown hidden"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Side-by-Side Comparison -->
  <section id="comparison-result" class="container-narrow pb-12 hidden">
    <div id="comparison-table-container"></div>
    <div id="comparison-lifestyle-container"></div>
  </section>

  <!-- All-Cities FIRE Number Matrix -->
  <section class="container-wide py-8" id="all-cities-section">
    <h2 class="font-serif text-2xl font-bold text-brand-950 mb-2">
      All 100+ Cities by FIRE Number
    </h2>
    <p class="text-sm text-gray-500 mb-4">Compare the portfolio needed to retire in each city at Budget, Comfortable, and Luxury levels.</p>
    <div id="matrix-portfolio-banner" class="hidden mb-4 bg-brand-50 border border-brand-200 rounded-xl px-5 py-3 flex items-center gap-3 flex-wrap">
      <span class="text-sm font-semibold text-brand-800" id="matrix-banner-text"></span>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-sand-200 overflow-x-auto" id="matrix-scroll-wrap">
      <div id="all-cities-matrix"></div>
    </div>
    <button id="matrix-show-more" type="button" class="mt-4 w-full py-2 text-sm font-semibold text-brand-600 hover:text-brand-800 border border-sand-200 rounded-lg hover:bg-sand-50 transition-colors">
      Show all 100+ cities
    </button>
  </section>
</Layout>

<style>
  .city-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 50;
    max-height: 280px;
    overflow-y: auto;
    background: #faf8f5;
    border: 1px solid #e5e0d8;
    border-radius: 0.75rem;
    box-shadow: 0 12px 24px -4px rgba(0,0,0,0.12), 0 4px 8px -2px rgba(0,0,0,0.06);
    margin-top: 6px;
    padding: 6px;
  }
  .city-dropdown-item {
    padding: 0.625rem 0.875rem;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: #1f2937;
    border-radius: 0.5rem;
    transition: background 0.1s, color 0.1s;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .city-dropdown-item:hover,
  .city-dropdown-item.highlighted {
    background: #ebe5d9;
    color: #7c5e2a;
  }

  #all-cities-matrix table {
    border-collapse: separate;
    border-spacing: 0;
  }
  #all-cities-matrix th.matrix-city-col,
  #all-cities-matrix td.matrix-city-col {
    position: sticky;
    left: 0;
    z-index: 5;
    background: white;
    min-width: 180px;
  }
  #all-cities-matrix th.matrix-city-col {
    background: #faf8f5;
    z-index: 6;
  }
</style>

<script define:vars={{ cityDataJSON, SAFE_WITHDRAWAL_RATE }}>
  const cityData = JSON.parse(cityDataJSON);
  const cityMap = {};
  cityData.forEach((c) => { cityMap[c.slug] = c; });
  const sortedList = [...cityData].sort((a, b) => b.fireScore - a.fireScore);
  const lifestyleTiers = ['budget', 'comfortable', 'luxury'];
  const lifestyleLabels = { budget: 'Budget', comfortable: 'Comfortable', luxury: 'Luxury' };

  // Portfolio from URL or localStorage
  let userPortfolio = null;
  const params = new URLSearchParams(window.location.search);
  const nwParam = params.get('nw');
  if (nwParam) userPortfolio = parseInt(nwParam, 10) || null;
  if (!userPortfolio) {
    try {
      const stored = JSON.parse(localStorage.getItem('pa_calc') || '{}');
      if (stored.nw && stored.nw > 0) userPortfolio = stored.nw;
    } catch (e) {}
  }

  const selectA = document.getElementById('city-select-a');
  const selectB = document.getElementById('city-select-b');
  const inputA = document.getElementById('city-input-a');
  const inputB = document.getElementById('city-input-b');
  const dropdownA = document.getElementById('city-dropdown-a');
  const dropdownB = document.getElementById('city-dropdown-b');
  const resultSection = document.getElementById('comparison-result');
  const tableContainer = document.getElementById('comparison-table-container');
  const lifestyleContainer = document.getElementById('comparison-lifestyle-container');

  function fmt(n) {
    return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
  }

  function fmtCompact(n) {
    if (n >= 1_000_000) {
      const m = n / 1_000_000;
      return '$' + m.toFixed(2).replace(/\.?0+$/, '') + 'M';
    }
    if (n >= 1_000) return '$' + Math.round(n / 1_000) + 'K';
    return fmt(n);
  }

  // ─── City Picker ───
  function setupPicker(input, hidden, dropdown) {
    let highlightIdx = -1;
    let filtered = [];

    function render(list) {
      filtered = list;
      highlightIdx = -1;
      if (list.length === 0 && input.value.trim().length > 0) {
        dropdown.innerHTML = '<div class="p-4 text-sm text-gray-400 text-center">No matching city found.</div>';
        dropdown.classList.remove('hidden');
        return;
      }
      if (list.length === 0) { dropdown.classList.add('hidden'); return; }
      dropdown.innerHTML = list.map((c, i) =>
        `<div class="city-dropdown-item" data-slug="${c.slug}" data-index="${i}">${c.emoji} ${c.name}, ${c.country}</div>`
      ).join('');
      dropdown.classList.remove('hidden');
    }

    function selectCity(city) {
      hidden.value = city.slug;
      input.value = `${city.emoji} ${city.name}, ${city.country}`;
      dropdown.classList.add('hidden');
      renderComparison();
    }

    input.addEventListener('focus', () => {
      const q = input.value.trim().toLowerCase();
      render(!q ? sortedList : sortedList.filter((c) => `${c.name} ${c.country}`.toLowerCase().includes(q)));
    });

    input.addEventListener('input', () => {
      hidden.value = '';
      const q = input.value.trim().toLowerCase();
      render(!q ? sortedList : sortedList.filter((c) => `${c.name} ${c.country}`.toLowerCase().includes(q)));
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') { e.preventDefault(); if (filtered.length > 0) { highlightIdx = Math.min(highlightIdx + 1, filtered.length - 1); highlight(); } }
      else if (e.key === 'ArrowUp') { e.preventDefault(); if (filtered.length > 0) { highlightIdx = Math.max(highlightIdx - 1, 0); highlight(); } }
      else if (e.key === 'Enter') { e.preventDefault(); if (highlightIdx >= 0 && filtered[highlightIdx]) selectCity(filtered[highlightIdx]); }
      else if (e.key === 'Escape') { dropdown.classList.add('hidden'); }
    });

    function highlight() {
      dropdown.querySelectorAll('.city-dropdown-item').forEach((el, i) => {
        el.classList.toggle('highlighted', i === highlightIdx);
        if (i === highlightIdx) el.scrollIntoView({ block: 'nearest' });
      });
    }

    dropdown.addEventListener('mousedown', (e) => e.preventDefault());
    dropdown.addEventListener('click', (e) => {
      const item = e.target.closest('.city-dropdown-item');
      if (!item) return;
      const city = cityMap[item.dataset.slug];
      if (city) selectCity(city);
    });

    input.addEventListener('blur', () => { setTimeout(() => dropdown.classList.add('hidden'), 150); });
  }

  setupPicker(inputA, selectA, dropdownA);
  setupPicker(inputB, selectB, dropdownB);

  // ─── Comparison Rendering ───
  function renderComparison() {
    const slugA = selectA.value;
    const slugB = selectB.value;
    if (!slugA || !slugB) { resultSection.classList.add('hidden'); return; }
    if (slugA === slugB) {
      resultSection.classList.remove('hidden');
      tableContainer.innerHTML = '<div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center"><p class="text-amber-800 font-semibold">Select two different cities to compare.</p></div>';
      lifestyleContainer.innerHTML = '';
      return;
    }

    const a = cityMap[slugA];
    const b = cityMap[slugB];
    if (!a || !b) return;

    resultSection.classList.remove('hidden');

    // Update URL
    const url = new URL(window.location);
    url.searchParams.set('cities', `${slugA},${slugB}`);
    window.history.replaceState({}, '', url);

    // Build FIRE Numbers comparison table
    let html = `<div class="bg-white rounded-2xl shadow-sm border border-sand-200 overflow-x-auto">
      <table class="w-full text-sm min-w-[500px]">
        <thead>
          <tr class="border-b-2 border-sand-200 bg-sand-50">
            <th class="text-left py-3 px-4 font-semibold text-gray-600">Lifestyle</th>
            <th class="text-right py-3 px-4 font-semibold text-gray-800">${a.emoji} ${a.name}</th>
            <th class="text-right py-3 px-4 font-semibold text-gray-800">${b.emoji} ${b.name}</th>
          </tr>
        </thead>
        <tbody>`;

    for (const tier of lifestyleTiers) {
      const fnA = a.tiers[tier].fireNumber;
      const fnB = b.tiers[tier].fireNumber;
      const cheaper = fnA < fnB ? 'a' : fnB < fnA ? 'b' : 'tie';

      // Portfolio indicators
      let statusA = '';
      let statusB = '';
      if (userPortfolio) {
        statusA = userPortfolio >= fnA
          ? ' <span class="text-emerald-500 text-xs font-medium ml-1">✓</span>'
          : ` <span class="text-gray-400 text-xs ml-1">-${fmtCompact(fnA - userPortfolio)}</span>`;
        statusB = userPortfolio >= fnB
          ? ' <span class="text-emerald-500 text-xs font-medium ml-1">✓</span>'
          : ` <span class="text-gray-400 text-xs ml-1">-${fmtCompact(fnB - userPortfolio)}</span>`;
      }

      html += `<tr class="border-b border-sand-100">
        <td class="py-3 px-4 font-bold text-gray-700">${lifestyleLabels[tier]}</td>
        <td class="text-right py-3 px-4${cheaper === 'a' ? ' text-brand-700 font-bold' : ' font-medium'}">
          ${fmtCompact(fnA)}${statusA}
          <div class="text-[10px] text-gray-400 font-normal">${fmt(a.tiers[tier].monthlyCost)}/mo</div>
        </td>
        <td class="text-right py-3 px-4${cheaper === 'b' ? ' text-brand-700 font-bold' : ' font-medium'}">
          ${fmtCompact(fnB)}${statusB}
          <div class="text-[10px] text-gray-400 font-normal">${fmt(b.tiers[tier].monthlyCost)}/mo</div>
        </td>
      </tr>`;
    }

    // Quality scores
    const qualityRows = [
      ['Safety', 'safety'],
      ['Healthcare', 'healthcare'],
      ['Infrastructure', 'infrastructure'],
      ['Expat Friendliness', 'expatFriendliness'],
    ];

    html += '<tr class="border-b-2 border-sand-200"><td colspan="3" class="py-2 px-4 text-xs font-bold text-gray-500 uppercase tracking-wider bg-sand-50">Quality of Life</td></tr>';

    for (const [label, key] of qualityRows) {
      const sa = a.scores[key];
      const sb = b.scores[key];
      const winner = sa > sb ? 'a' : sb > sa ? 'b' : 'tie';
      html += `<tr class="border-b border-sand-100">
        <td class="py-2.5 px-4 font-medium text-gray-700">${label}</td>
        <td class="text-right py-2.5 px-4 font-medium${winner === 'a' ? ' text-brand-700' : ''}">${sa}/10${winner === 'a' ? ' 👑' : ''}</td>
        <td class="text-right py-2.5 px-4 font-medium${winner === 'b' ? ' text-brand-700' : ''}">${sb}/10${winner === 'b' ? ' 👑' : ''}</td>
      </tr>`;
    }

    // FIRE Score
    const fireWinner = a.fireScore > b.fireScore ? 'a' : b.fireScore > a.fireScore ? 'b' : 'tie';
    html += `<tr class="font-bold">
      <td class="py-2.5 px-4 text-gray-800">FIRE Score</td>
      <td class="text-right py-2.5 px-4${fireWinner === 'a' ? ' text-brand-700' : ''}">${a.fireScore.toFixed(1)}${fireWinner === 'a' ? ' 👑' : ''}</td>
      <td class="text-right py-2.5 px-4${fireWinner === 'b' ? ' text-brand-700' : ''}">${b.fireScore.toFixed(1)}${fireWinner === 'b' ? ' 👑' : ''}</td>
    </tr>`;

    html += '</tbody></table></div>';
    tableContainer.innerHTML = html;

    // Lifestyle descriptions for comfortable tier
    lifestyleContainer.innerHTML = `
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
        <div class="bg-gradient-to-br from-brand-50 to-sand-50 rounded-2xl border border-brand-100 p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-lg">${a.emoji}</span>
            <h4 class="font-serif font-bold text-brand-950">${a.name}</h4>
          </div>
          <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide mb-2">Comfortable lifestyle — ${fmtCompact(a.tiers.comfortable.fireNumber)}</p>
          <div class="flex flex-wrap gap-1.5 mb-2">
            <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-amber-50 text-amber-700">${a.tags.climate}</span>
            <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700">${a.tags.safety}</span>
            <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-blue-50 text-blue-700">${a.tags.english}</span>
          </div>
        </div>
        <div class="bg-gradient-to-br from-brand-50 to-sand-50 rounded-2xl border border-brand-100 p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-lg">${b.emoji}</span>
            <h4 class="font-serif font-bold text-brand-950">${b.name}</h4>
          </div>
          <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide mb-2">Comfortable lifestyle — ${fmtCompact(b.tiers.comfortable.fireNumber)}</p>
          <div class="flex flex-wrap gap-1.5 mb-2">
            <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-amber-50 text-amber-700">${b.tags.climate}</span>
            <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700">${b.tags.safety}</span>
            <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-blue-50 text-blue-700">${b.tags.english}</span>
          </div>
        </div>
      </div>`;
  }

  // Pre-populate from URL
  (function() {
    const cities = params.get('cities');
    if (!cities) return;
    const [slugA, slugB] = cities.split(',');
    if (slugA && cityMap[slugA]) { selectA.value = slugA; const c = cityMap[slugA]; inputA.value = `${c.emoji} ${c.name}, ${c.country}`; }
    if (slugB && cityMap[slugB]) { selectB.value = slugB; const c = cityMap[slugB]; inputB.value = `${c.emoji} ${c.name}, ${c.country}`; }
    if (slugA && slugB) renderComparison();
  })();

  // ─── All-Cities Matrix ───
  const matrixContainer = document.getElementById('all-cities-matrix');
  const matrixShowMore = document.getElementById('matrix-show-more');
  const INITIAL_ROWS = 20;
  let matrixShowAll = false;
  let matrixSortKey = 'fireScore';
  let matrixSortAsc = false;

  // Show portfolio banner
  if (userPortfolio) {
    const banner = document.getElementById('matrix-portfolio-banner');
    const bannerText = document.getElementById('matrix-banner-text');
    if (banner && bannerText) {
      banner.classList.remove('hidden');
      const fmtNW = userPortfolio >= 1000000
        ? '$' + (userPortfolio / 1000000).toFixed(userPortfolio % 1000000 === 0 ? 0 : 1) + 'M'
        : '$' + userPortfolio.toLocaleString('en-US');
      bannerText.textContent = `Your portfolio: ${fmtNW} — ✓ means you can retire there`;
    }
  }

  function renderMatrix() {
    const sorted = [...sortedList];
    if (matrixSortKey === 'fireScore') {
      sorted.sort((a, b) => matrixSortAsc ? a.fireScore - b.fireScore : b.fireScore - a.fireScore);
    } else {
      sorted.sort((a, b) => {
        const fa = a.tiers[matrixSortKey]?.fireNumber || 0;
        const fb = b.tiers[matrixSortKey]?.fireNumber || 0;
        return matrixSortAsc ? fa - fb : fb - fa;
      });
    }

    const displayed = matrixShowAll ? sorted : sorted.slice(0, INITIAL_ROWS);
    const sortArrow = (key) => matrixSortKey === key ? (matrixSortAsc ? ' ▲' : ' ▼') : '';

    let html = '<table class="w-full text-sm"><thead><tr class="border-b-2 border-sand-200 bg-sand-50">';
    html += `<th class="matrix-city-col text-left py-3 px-4 font-semibold text-gray-600 cursor-pointer select-none hover:text-brand-600" data-sort="fireScore">City${sortArrow('fireScore')}</th>`;
    for (const tier of lifestyleTiers) {
      html += `<th class="text-center py-2 px-3 font-semibold text-gray-700 cursor-pointer select-none hover:text-brand-600 min-w-[120px]" data-sort="${tier}">${lifestyleLabels[tier]}${sortArrow(tier)}</th>`;
    }
    html += '</tr></thead><tbody>';

    for (const city of displayed) {
      html += '<tr class="border-b border-sand-100 hover:bg-sand-50 transition-colors">';
      html += `<td class="matrix-city-col py-2.5 px-4 border-r border-sand-100">
        <a href="/cities/${city.slug}" class="flex items-center gap-2 hover:text-brand-600 transition-colors">
          <span class="shrink-0">${city.emoji}</span>
          <div class="min-w-0"><span class="font-medium text-sm block truncate">${city.name}</span>
          <span class="text-gray-400 text-[10px]">${city.country} · ${city.fireScore.toFixed(1)}</span></div>
        </a>
      </td>`;

      for (const tier of lifestyleTiers) {
        const data = city.tiers[tier];
        if (!data) { html += '<td class="text-center py-2.5 px-3"><span class="text-gray-300">—</span></td>'; continue; }

        let statusHTML = '';
        if (userPortfolio) {
          if (userPortfolio >= data.fireNumber) {
            statusHTML = '<div class="text-emerald-500 text-xs font-semibold mt-0.5">✓</div>';
          } else {
            statusHTML = `<div class="text-gray-400 text-[10px] mt-0.5">-${fmtCompact(data.fireNumber - userPortfolio)}</div>`;
          }
        }

        html += `<td class="text-center py-2.5 px-3">
          <div class="font-bold text-sm">${fmtCompact(data.fireNumber)}</div>
          <div class="text-[10px] text-gray-400">${fmt(data.monthlyCost)}/mo</div>
          ${statusHTML}
        </td>`;
      }

      html += '</tr>';
    }
    html += '</tbody></table>';

    matrixContainer.innerHTML = html;

    // Sort handlers
    matrixContainer.querySelectorAll('th[data-sort]').forEach((th) => {
      th.addEventListener('click', () => {
        const key = th.getAttribute('data-sort');
        if (matrixSortKey === key) matrixSortAsc = !matrixSortAsc;
        else { matrixSortKey = key; matrixSortAsc = key === 'fireScore' ? false : true; }
        renderMatrix();
      });
    });

    if (matrixShowMore) {
      matrixShowMore.classList.toggle('hidden', matrixShowAll || sorted.length <= INITIAL_ROWS);
      matrixShowMore.textContent = `Show all ${sorted.length} cities`;
    }
  }

  matrixShowMore?.addEventListener('click', () => { matrixShowAll = true; renderMatrix(); });
  renderMatrix();
</script>
