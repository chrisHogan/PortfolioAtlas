---
import Layout from '../../layouts/Layout.astro';
import CityHero from '../../components/CityHero.astro';
import TierNav from '../../components/TierNav.astro';
import TierBreakdown from '../../components/TierBreakdown.astro';
import PersonalizedTier from '../../components/PersonalizedTier.astro';
import QuickFacts from '../../components/QuickFacts.astro';
import ComparisonCTA from '../../components/ComparisonCTA.astro';
import { allCities, getCityBySlug, getAllSlugs } from '../../data/cities/index';
import type { TierKey } from '../../data/types';

export function getStaticPaths() {
  return getAllSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const city = getCityBySlug(slug!);

if (!city) {
  return Astro.redirect('/404');
}

const tiers: TierKey[] = ['1M', '2M', '3M', '5M', '10M'];
---

<Layout
  title={`Retire in ${city.name}, ${city.country} — What Your Portfolio Buys You`}
  description={`Discover what a $1M to $10M portfolio gets you in ${city.name}, ${city.country}. Full lifestyle breakdowns including housing, healthcare, dining, and more.`}
>
  <CityHero city={city} />
  <TierNav />

  <div class="container-narrow py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content: Tier breakdowns -->
      <div class="lg:col-span-2 space-y-8">
        <div class="mb-8">
          <h2 class="font-serif text-3xl font-bold text-brand-950 mb-3">
            What Your Portfolio Gets You in {city.name}
          </h2>
          <p class="text-gray-600 leading-relaxed">
            We break down the lifestyle you can afford at five portfolio levels, using a
            <strong>4% safe withdrawal rate</strong>. Each tier shows realistic monthly costs
            for housing, food, healthcare, entertainment, and more in {city.name}.
          </p>
        </div>

        <PersonalizedTier city={city} />

        {tiers.map((tierKey) => (
          <TierBreakdown tierKey={tierKey} tier={city.tiers[tierKey]} cityName={city.name} />
        ))}
      </div>

      <script>
        // Accordion state machine: open first tier by default, mutual exclusion on click
        (function() {
          const accordions = document.querySelectorAll('.accordion-tier');
          if (accordions.length === 0) return;

          function openAccordion(el: Element) {
            el.setAttribute('data-open', 'true');
            const btn = el.querySelector('.accordion-header') as HTMLButtonElement;
            if (btn) btn.setAttribute('aria-expanded', 'true');
          }

          function closeAccordion(el: Element) {
            el.setAttribute('data-open', 'false');
            const btn = el.querySelector('.accordion-header') as HTMLButtonElement;
            if (btn) btn.setAttribute('aria-expanded', 'false');
          }

          // Only open first tier if there's no personalized tier (no ?nw= param)
          const hasPersonalized = new URLSearchParams(window.location.search).get('nw');
          if (!hasPersonalized) {
            openAccordion(accordions[0]);
          }

          // Click-to-toggle with mutual exclusion
          accordions.forEach((accordion) => {
            const header = accordion.querySelector('.accordion-header');
            if (!header) return;
            header.addEventListener('click', () => {
              const isOpen = accordion.getAttribute('data-open') === 'true';
              // Close all
              accordions.forEach((el) => closeAccordion(el));
              // If it was closed, open it
              if (!isOpen) {
                openAccordion(accordion);
              }
              // Update nav pills
              const activeTier = accordion.getAttribute('data-open') === 'true'
                ? accordion.getAttribute('data-tier') || ''
                : '';
              document.querySelectorAll('.tier-nav-pill').forEach((pill) => {
                const target = (pill as HTMLButtonElement).dataset.tierTarget;
                if (target === activeTier) {
                  pill.classList.add('bg-brand-600', 'text-white', 'border-brand-600');
                  pill.classList.remove('text-gray-600', 'border-sand-200');
                } else {
                  pill.classList.remove('bg-brand-600', 'text-white', 'border-brand-600');
                  pill.classList.add('text-gray-600', 'border-sand-200');
                }
              });
            });
          });
        })();
      </script>

      <!-- Sidebar -->
      <div class="space-y-8">
        <QuickFacts facts={city.quickFacts} cityName={city.name} />
        <ComparisonCTA currentCity={city} allCities={allCities} />
      </div>
    </div>
  </div>
</Layout>
