---
import Layout from '../../layouts/Layout.astro';
import CityHero from '../../components/CityHero.astro';
import FireStatusCard from '../../components/FireStatusCard.astro';
import ComparisonCTA from '../../components/ComparisonCTA.astro';
import CityFAQ from '../../components/CityFAQ.astro';
import RelatedCities from '../../components/RelatedCities.astro';
import { allCities, getCityBySlug, getAllSlugs } from '../../data/cities/index';
import { formatCurrency, getTotalSpend } from '../../data/types';
import { DATA_RECENCY, getCityConfidenceLevel } from '../../data/spendingProfile';
import {
  getAllFireNumbers,
  formatFireNumber,
  getCityDisplayTags,
  getTagColor,
  LIFESTYLE_LABELS,
  ALL_LIFESTYLE_TIERS,
  LIFESTYLE_TIER_MAP,
} from '../../data/fireNumber';
import type { LifestyleTier } from '../../data/fireNumber';

export function getStaticPaths() {
  return getAllSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const city = getCityBySlug(slug!);

if (!city) {
  return Astro.redirect('/404');
}

const confidenceLevel = getCityConfidenceLevel(city.slug);
const fireNumbers = getAllFireNumbers(city);
const displayTags = getCityDisplayTags(city);

// JSON-LD structured data
const siteUrl = 'https://portfolioatlas.org';
const pageUrl = `${siteUrl}/cities/${city.slug}/`;

const tier1M = city.tiers['1M'];
const tier3M = city.tiers['3M'];
const totalSpend1M = getTotalSpend(tier1M);
const totalSpend3M = getTotalSpend(tier3M);

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': siteUrl },
    { '@type': 'ListItem', 'position': 2, 'name': city.name, 'item': pageUrl },
  ],
};

const placeLd = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  'name': `${city.name}, ${city.country}`,
  'description': city.description,
  'url': pageUrl,
  'address': {
    '@type': 'PostalAddress',
    'addressLocality': city.name,
    'addressCountry': city.country,
  },
};

const isDomestic = city.country === 'United States';

const faqQuestions = [
  {
    question: `What is the FIRE Number for ${city.name}, ${city.country}?`,
    answer: `The FIRE Number for ${city.name} ranges from ${formatFireNumber(fireNumbers.budget.fireNumber)} (Lean FIRE lifestyle) to ${formatFireNumber(fireNumbers.luxury.fireNumber)} (Fat FIRE lifestyle). A FIRE retirement requires a portfolio of approximately ${formatFireNumber(fireNumbers.comfortable.fireNumber)}, based on estimated monthly costs of ${formatCurrency(fireNumbers.comfortable.monthlyCost)} and a 4% safe withdrawal rate.`,
  },
  {
    question: `How much does it cost to retire in ${city.name}?`,
    answer: `Monthly living costs in ${city.name} range from ${formatCurrency(totalSpend1M)} (Lean FIRE) to ${formatCurrency(totalSpend3M)} (FIRE), covering housing, dining, groceries, healthcare, transportation, entertainment, and utilities.`,
  },
  {
    question: `What is healthcare like in ${city.name} for ${isDomestic ? 'retirees' : 'expats and retirees'}?`,
    answer: `Healthcare in ${city.name} costs approximately ${formatCurrency(tier1M.healthcare.monthlyCost)} to ${formatCurrency(tier3M.healthcare.monthlyCost)}/month depending on coverage level. ${tier1M.healthcare.description}.`,
  },
  ...(!isDomestic ? [{
    question: `Do I need a visa to retire in ${city.name}, ${city.country}?`,
    answer: city.quickFacts.visa,
  }] : []),
  {
    question: `What is the weather like in ${city.name}?`,
    answer: `${city.quickFacts.climate} The average temperature is ${city.quickFacts.averageTemp}.`,
  },
  ...(!isDomestic ? [{
    question: `Is ${city.name} English-friendly?`,
    answer: `English proficiency in ${city.name} is rated "${city.quickFacts.englishFriendly}." The primary language is ${city.quickFacts.language}.`,
  }] : []),
  {
    question: `How safe is ${city.name} for retirees?`,
    answer: city.quickFacts.safetyRating,
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqQuestions.map((faq) => ({
    '@type': 'Question',
    'name': faq.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.answer,
    },
  })),
};

const jsonLd = [breadcrumbLd, placeLd, faqLd];

// Pre-compute data for client-side portfolio comparison
const fireNumbersJSON = JSON.stringify(fireNumbers);
const lifestyleTierMapJSON = JSON.stringify(LIFESTYLE_TIER_MAP);

// Get lifestyle descriptions for the 3 tiers
const lifestyleDescriptions = ALL_LIFESTYLE_TIERS.map((tier) => ({
  tier,
  label: LIFESTYLE_LABELS[tier],
  description: city.tiers[LIFESTYLE_TIER_MAP[tier]].lifestyle,
}));

// All display tags as entries for iteration
const tagEntries = Object.entries(displayTags) as [string, string][];

// Country hub link
const countrySlug = city.country.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const countryHubUrl = `/retire-in/${countrySlug}/`;

// Portfolio tier link — find the smallest tier >= this city's FIRE number
const portfolioTiers = [
  { slug: '500k', label: '$500K', value: 500_000 },
  { slug: '750k', label: '$750K', value: 750_000 },
  { slug: '1m', label: '$1M', value: 1_000_000 },
  { slug: '1-5m', label: '$1.5M', value: 1_500_000 },
  { slug: '2m', label: '$2M', value: 2_000_000 },
  { slug: '3m', label: '$3M', value: 3_000_000 },
];
const cityFire = fireNumbers.comfortable.fireNumber;
const nearestTier = portfolioTiers.find((t) => t.value >= cityFire) || portfolioTiers[portfolioTiers.length - 1];
const portfolioTierUrl = `/retire-on/${nearestTier.slug}/`;

// SEO: title with length check (prefer full format, fallback to short if >70 chars)
const fullTitle = `${city.name} FIRE Number: How Much You Need to Retire in ${city.name}, ${city.country}`;
const shortTitle = `Retire in ${city.name}: FIRE Number & Cost`;
const pageTitle = fullTitle.length + ' | PortfolioAtlas'.length <= 70 ? fullTitle : shortTitle;

// SEO: meta description with all 3 tier FIRE Numbers (target 140-160 chars)
const metaDesc = `Retiring in ${city.name}? You need ${formatFireNumber(fireNumbers.comfortable.fireNumber)} invested (4% rule). See Lean FIRE (${formatFireNumber(fireNumbers.budget.fireNumber)}), FIRE (${formatFireNumber(fireNumbers.comfortable.fireNumber)}), and Fat FIRE (${formatFireNumber(fireNumbers.luxury.fireNumber)}) cost breakdowns for ${city.name}, ${city.country}.`;
---

<Layout
  title={pageTitle}
  description={metaDesc}
  jsonLd={jsonLd}
>
  <CityHero city={city} />

  <div class="container-narrow py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2 space-y-10">

        <!-- 1. FIRE Numbers Table -->
        <section>
          <h2 class="font-serif text-3xl font-bold text-brand-950 mb-3">
            Lean FIRE, FIRE, and Fat FIRE for {city.name}
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            The portfolio you need to retire in {city.name} at each lifestyle level,
            based on the <strong>4% safe withdrawal rate</strong>.
          </p>

          <div class="bg-white rounded-2xl border border-sand-200 shadow-sm overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b-2 border-sand-200 bg-sand-50">
                  <th class="text-left py-3 px-5 font-semibold text-gray-600">Lifestyle</th>
                  <th class="text-right py-3 px-5 font-semibold text-gray-600">FIRE Number</th>
                  <th class="text-right py-3 px-5 font-semibold text-gray-600">Monthly Cost</th>
                  <th class="text-right py-3 px-5 font-semibold text-gray-600 hidden sm:table-cell" id="status-header">Status</th>
                </tr>
              </thead>
              <tbody>
                {ALL_LIFESTYLE_TIERS.map((tier) => {
                  const data = fireNumbers[tier];
                  return (
                    <tr
                      class="border-b border-sand-100 fire-row"
                      data-tier={tier}
                      data-fire-number={data.fireNumber}
                      data-monthly-cost={data.monthlyCost}
                    >
                      <td class="py-4 px-5">
                        <div class="font-bold text-brand-950">{LIFESTYLE_LABELS[tier]}</div>
                      </td>
                      <td class="text-right py-4 px-5">
                        <span class="text-lg font-bold text-brand-700">{formatFireNumber(data.fireNumber)}</span>
                      </td>
                      <td class="text-right py-4 px-5">
                        <span class="text-sm text-gray-600">{formatCurrency(data.monthlyCost)}/mo</span>
                      </td>
                      <td class="text-right py-4 px-5 hidden sm:table-cell fire-status"></td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>

          <div class="flex items-center gap-3 mt-3">
            <span class="text-xs text-gray-400">Cost data: {DATA_RECENCY}</span>
            <span class="text-xs text-gray-300">&middot;</span>
            <span class:list={[
              'text-xs font-medium',
              confidenceLevel === 'High' ? 'text-emerald-600' : confidenceLevel === 'Medium' ? 'text-amber-600' : 'text-gray-400',
            ]}>
              {confidenceLevel} confidence
            </span>
          </div>

          <!-- Portfolio prompt (shown when no portfolio set) -->
          <div id="portfolio-prompt" class="mt-4 bg-brand-50 border border-brand-200 rounded-xl px-5 py-4 text-center hidden">
            <p class="text-sm text-brand-800 font-medium mb-2">Enter your portfolio to see which tiers you can afford</p>
            <a href="/" class="inline-flex items-center gap-2 px-4 py-2 bg-brand-600 text-white text-sm font-semibold rounded-lg hover:bg-brand-700 transition-colors">
              See Where I Can Retire
            </a>
          </div>
        </section>

        <!-- Personalized FIRE Status Card (shown client-side when portfolio is set) -->
        <FireStatusCard cityName={city.name} country={city.country} fireNumbers={fireNumbers} />

        <!-- 2. Lifestyle Descriptions -->
        <section>
          <h2 class="font-serif text-2xl font-bold text-brand-950 mb-4">
            Cost of Living Breakdown for {city.name}
          </h2>

          <div class="space-y-4">
            {lifestyleDescriptions.map(({ tier, label, description }) => (
              <div class="bg-white rounded-xl border border-sand-200 p-5 lifestyle-desc" data-tier={tier}>
                <div class="flex items-center justify-between mb-3">
                  <h3 class="font-serif text-lg font-bold text-brand-950">{label} Lifestyle</h3>
                  <span class="text-sm font-semibold text-brand-600">
                    {formatFireNumber(fireNumbers[tier].fireNumber)}
                  </span>
                </div>
                <p class="text-sm text-gray-700 leading-relaxed">{description}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- 3. Retirement Confidence -->
        <section id="confidence-section">
          <h2 class="font-serif text-2xl font-bold text-brand-950 mb-3">
            Retirement Confidence
          </h2>
          <div id="confidence-result" class="bg-white rounded-xl border border-sand-200 p-5">
            <p id="confidence-text" class="text-gray-600">
              Enter your portfolio on the <a href="/" class="text-brand-600 hover:underline font-medium">homepage</a> to see Monte Carlo retirement confidence for {city.name}.
            </p>
            <div id="confidence-detail" class="hidden mt-3">
              <div class="flex items-center gap-3 mb-2">
                <span id="confidence-value" class="text-3xl font-bold text-brand-700"></span>
                <span class="text-sm text-gray-500">chance your portfolio lasts 30+ years</span>
              </div>
              <div class="w-full bg-sand-100 rounded-full h-2.5">
                <div id="confidence-bar" class="bg-brand-600 h-2.5 rounded-full transition-all"></div>
              </div>
            </div>
          </div>
          <details class="mt-3">
            <summary class="text-xs text-gray-500 cursor-pointer hover:text-gray-700">
              Important notes on retirement confidence
            </summary>
            <div class="text-xs text-gray-500 mt-2 leading-relaxed pl-4 border-l-2 border-sand-200 space-y-2">
              <p>
                A 90% confidence level is widely considered a strong retirement plan — it means your
                portfolio survived in 9 out of 10 historically-modeled scenarios. A 95% or higher rate
                is extremely conservative. Reaching 100% is nearly impossible in any Monte Carlo model,
                because there will always be a few extreme worst-case market sequences that deplete any portfolio.
              </p>
              <p>
                Early retirees may need portfolios to last 40-50+ years. The 4% rule was originally
                validated for 30-year retirements. Consider a more conservative withdrawal rate (3-3.5%)
                for very early retirement.
              </p>
            </div>
          </details>
        </section>

        <!-- 4. City Tags (all expanded) -->
        <section>
          <h2 class="font-serif text-2xl font-bold text-brand-950 mb-4">
            Healthcare, Visa &amp; City Overview
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {tagEntries.map(([category, value]) => (
              <div class="flex items-center gap-3 bg-white rounded-xl border border-sand-200 px-4 py-3">
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider w-20 shrink-0">{category}</span>
                <span class:list={['text-sm font-medium px-3 py-1 rounded-full', getTagColor(category, value)]}>
                  {value}
                </span>
              </div>
            ))}
          </div>

          <!-- Quick facts below tags -->
          <div class="mt-4 bg-white rounded-xl border border-sand-200 p-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
              <div>
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Timezone</span>
                <p class="text-gray-800 mt-0.5">{city.quickFacts.timezone}</p>
              </div>
              <div>
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Currency</span>
                <p class="text-gray-800 mt-0.5">{city.quickFacts.currency}</p>
              </div>
              <div>
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Language</span>
                <p class="text-gray-800 mt-0.5">{city.quickFacts.language}</p>
              </div>
              <div>
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Avg. Temperature</span>
                <p class="text-gray-800 mt-0.5">{city.quickFacts.averageTemp}</p>
              </div>
              <div>
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Internet</span>
                <p class="text-gray-800 mt-0.5">{city.quickFacts.internetSpeed}</p>
              </div>
              <div>
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Airport</span>
                <p class="text-gray-800 mt-0.5">{city.quickFacts.nearestAirport}</p>
              </div>
              {!isDomestic && (
                <div class="sm:col-span-2">
                  <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Visa</span>
                  <p class="text-gray-800 mt-0.5">{city.quickFacts.visa}</p>
                </div>
              )}
            </div>
          </div>
        </section>

        <!-- 5. Compare & Related -->
        <CityFAQ city={city} faqs={faqQuestions} />
        <RelatedCities currentCity={city} allCities={allCities} />
      </div>

      <!-- Sidebar -->
      <div class="space-y-8">
        <ComparisonCTA currentCity={city} allCities={allCities} />

        <section class="bg-brand-950 rounded-2xl p-6 text-white">
          <h3 class="font-serif text-lg font-bold mb-2">See Where You Can Retire</h3>
          <p class="text-sm text-sand-300 mb-4">
            Enter your portfolio value and see which cities worldwide you can retire in.
          </p>
          <a
            href="/"
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-white text-brand-700 text-sm font-semibold rounded-lg hover:bg-sand-50 transition-colors w-full justify-center"
          >
            Explore All Cities
          </a>
        </section>

        <a
          href={countryHubUrl}
          class="flex items-center justify-between bg-white rounded-xl border border-sand-200 p-4 hover:border-brand-300 hover:shadow-sm transition-all group"
        >
          <span class="text-sm font-semibold text-gray-700 group-hover:text-brand-700 transition-colors">
            See all cities in {city.country}
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 group-hover:text-brand-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>

        <a
          href={portfolioTierUrl}
          class="flex items-center justify-between bg-white rounded-xl border border-sand-200 p-4 hover:border-brand-300 hover:shadow-sm transition-all group"
        >
          <span class="text-sm font-semibold text-gray-700 group-hover:text-brand-700 transition-colors">
            All cities affordable on {nearestTier.label}
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 group-hover:text-brand-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Client-side: compare user's portfolio against FIRE Numbers
  (function() {
    const SWR = 0.04;
    let portfolio = 0;
    let userPassiveIncome = 0;

    // Read portfolio and passive income from URL or localStorage
    const params = new URLSearchParams(window.location.search);
    const nwParam = params.get('portfolio') || params.get('nw');
    if (nwParam) {
      portfolio = parseInt(nwParam, 10) || 0;
    }
    const passiveParam = parseInt(params.get('passive') || '0', 10);
    if (passiveParam > 0) userPassiveIncome = passiveParam;

    if (!portfolio) {
      try {
        const stored = JSON.parse(localStorage.getItem('pa_calc') || '{}');
        if (stored.nw && stored.nw > 0) portfolio = stored.nw;
        if (!userPassiveIncome && stored.passiveIncome) userPassiveIncome = stored.passiveIncome;
      } catch (e) {}
    } else if (!userPassiveIncome) {
      try {
        const stored = JSON.parse(localStorage.getItem('pa_calc') || '{}');
        if (stored.passiveIncome) userPassiveIncome = stored.passiveIncome;
      } catch (e) {}
    }

    function adjustFN(base: number): number {
      if (!userPassiveIncome || userPassiveIncome <= 0) return base;
      return Math.max(0, base - userPassiveIncome / SWR);
    }

    const rows = document.querySelectorAll('.fire-row');
    const prompt = document.getElementById('portfolio-prompt');
    const statusHeader = document.getElementById('status-header');

    if (!portfolio || portfolio <= 0) {
      if (prompt) prompt.classList.remove('hidden');
      if (statusHeader) statusHeader.textContent = '';
      return;
    }

    function fmt(n: number): string {
      if (n >= 1_000_000) {
        const m = n / 1_000_000;
        const formatted = m.toFixed(2).replace(/\.?0+$/, '');
        return '$' + formatted + 'M';
      }
      if (n >= 1_000) return '$' + Math.round(n / 1_000) + 'K';
      return '$' + n.toLocaleString();
    }

    // Update FIRE Numbers table with adjusted values and status indicators
    rows.forEach((row) => {
      const baseFireNumber = parseInt(row.getAttribute('data-fire-number') || '0', 10);
      const adjustedFN = adjustFN(baseFireNumber);
      const fullyCovered = userPassiveIncome > 0 && adjustedFN === 0;
      const statusCell = row.querySelector('.fire-status');
      const fireNumberCell = row.querySelector('td:nth-child(2) span');

      // Update displayed FIRE Number if adjusted
      if (userPassiveIncome > 0 && fireNumberCell) {
        (fireNumberCell as HTMLElement).textContent = fullyCovered ? '$0' : fmt(adjustedFN);
      }

      if (!statusCell) return;

      if (fullyCovered) {
        statusCell.innerHTML = '<span class="inline-flex items-center gap-1.5 text-emerald-600 font-semibold text-sm"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Fully covered by passive income</span>';
        (row as HTMLElement).classList.add('bg-emerald-50/50');
      } else if (portfolio >= adjustedFN) {
        statusCell.innerHTML = '<span class="inline-flex items-center gap-1.5 text-emerald-600 font-semibold text-sm"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>You can retire here</span>';
        (row as HTMLElement).classList.add('bg-emerald-50/50');
      } else {
        const gap = adjustedFN - portfolio;
        statusCell.innerHTML = `<span class="text-sm text-gray-500">Need ${fmt(gap)} more</span>`;
      }
    });

    // Highlight the best affordable tier's lifestyle description
    const lifestyleDescs = document.querySelectorAll('.lifestyle-desc');
    lifestyleDescs.forEach((desc) => {
      const tier = desc.getAttribute('data-tier') as string;
      const row = document.querySelector(`.fire-row[data-tier="${tier}"]`);
      if (!row) return;
      const baseFireNumber = parseInt(row.getAttribute('data-fire-number') || '0', 10);
      const adjustedFN = adjustFN(baseFireNumber);
      if (portfolio >= adjustedFN) {
        (desc as HTMLElement).classList.add('border-emerald-200', 'bg-emerald-50/30');
        (desc as HTMLElement).classList.remove('border-sand-200');
      }
    });

    // Monte Carlo confidence estimate (simplified)
    const confSection = document.getElementById('confidence-detail');
    const confText = document.getElementById('confidence-text');
    const confValue = document.getElementById('confidence-value');
    const confBar = document.getElementById('confidence-bar');

    if (confSection && confText && confValue && confBar) {
      const tiers = ['luxury', 'comfortable', 'budget'] as const;
      let bestTier: string | null = null;
      let bestFireNumber = 0;

      for (const tier of tiers) {
        const row = document.querySelector(`.fire-row[data-tier="${tier}"]`);
        if (!row) continue;
        const baseFN = parseInt(row.getAttribute('data-fire-number') || '0', 10);
        const fn = adjustFN(baseFN);
        if (fn === 0 || portfolio >= fn) {
          bestTier = tier;
          bestFireNumber = fn;
          break;
        }
      }

      if (bestTier !== null) {
        let confidence: number;
        if (bestFireNumber === 0) {
          confidence = 99; // Fully covered by passive income
        } else {
          const ratio = portfolio / bestFireNumber;
          if (ratio >= 2.0) confidence = 99;
          else if (ratio >= 1.5) confidence = 96;
          else if (ratio >= 1.25) confidence = 93;
          else if (ratio >= 1.1) confidence = 88;
          else if (ratio >= 1.0) confidence = 82;
          else confidence = Math.max(50, Math.round(ratio * 82));
        }

        confText.classList.add('hidden');
        confSection.classList.remove('hidden');
        confValue.textContent = confidence + '%';
        confBar.style.width = confidence + '%';

        if (confidence >= 90) confBar.classList.add('bg-emerald-500');
        else if (confidence >= 80) { confBar.classList.remove('bg-brand-600'); confBar.classList.add('bg-amber-500'); }
        else { confBar.classList.remove('bg-brand-600'); confBar.classList.add('bg-red-500'); }
      }
    }
  })();
</script>
