---
import Layout from '../../layouts/Layout.astro';
import CityHero from '../../components/CityHero.astro';
import TierNav from '../../components/TierNav.astro';
import TierBreakdown from '../../components/TierBreakdown.astro';
import PersonalizedTier from '../../components/PersonalizedTier.astro';
import QuickFacts from '../../components/QuickFacts.astro';
import ComparisonCTA from '../../components/ComparisonCTA.astro';
import CityFAQ from '../../components/CityFAQ.astro';
import RelatedCities from '../../components/RelatedCities.astro';
import { allCities, getCityBySlug, getAllSlugs } from '../../data/cities/index';
import { formatCurrency, getTotalSpend } from '../../data/types';
import type { TierKey } from '../../data/types';

export function getStaticPaths() {
  return getAllSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const city = getCityBySlug(slug!);

if (!city) {
  return Astro.redirect('/404');
}

const tiers: TierKey[] = ['1M', '2M', '3M', '5M', '10M'];

// JSON-LD structured data
const siteUrl = 'https://portfolioatlas.org';
const pageUrl = `${siteUrl}/cities/${city.slug}/`;

const tier1M = city.tiers['1M'];
const tier3M = city.tiers['3M'];
const totalSpend1M = getTotalSpend(tier1M);
const totalSpend3M = getTotalSpend(tier3M);

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': siteUrl },
    { '@type': 'ListItem', 'position': 2, 'name': city.name, 'item': pageUrl },
  ],
};

const placeLd = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  'name': `${city.name}, ${city.country}`,
  'description': city.description,
  'url': pageUrl,
  'address': {
    '@type': 'PostalAddress',
    'addressLocality': city.name,
    'addressCountry': city.country,
  },
};

const faqQuestions = [
  {
    question: `What is the cost of living in ${city.name}, ${city.country} for retirees?`,
    answer: `With a $1M portfolio (${formatCurrency(tier1M.monthlyBudget)}/month at 4% withdrawal rate), monthly living costs in ${city.name} total roughly ${formatCurrency(totalSpend1M)}, covering housing, dining, groceries, healthcare, transportation, entertainment, and utilities. With a $3M portfolio (${formatCurrency(tier3M.monthlyBudget)}/month), you can expect to spend about ${formatCurrency(totalSpend3M)}/month for a significantly more comfortable lifestyle.`,
  },
  {
    question: `How much does housing cost in ${city.name}?`,
    answer: `Housing in ${city.name} ranges from ${formatCurrency(tier1M.housing.monthlyCost)}/month to ${formatCurrency(tier3M.housing.monthlyCost)}/month depending on lifestyle level. At higher portfolio levels ($5M+), luxury options are available from ${formatCurrency(city.tiers['5M'].housing.monthlyCost)}/month.`,
  },
  {
    question: `What is healthcare like in ${city.name} for expats and retirees?`,
    answer: `Healthcare in ${city.name} costs approximately ${formatCurrency(tier1M.healthcare.monthlyCost)} to ${formatCurrency(tier3M.healthcare.monthlyCost)}/month depending on coverage level. ${tier1M.healthcare.description}.`,
  },
  {
    question: `Do I need a visa to retire in ${city.name}, ${city.country}?`,
    answer: city.quickFacts.visa,
  },
  {
    question: `What is the weather like in ${city.name}?`,
    answer: `${city.quickFacts.climate} The average temperature is ${city.quickFacts.averageTemp}.`,
  },
  {
    question: `Is ${city.name} English-friendly?`,
    answer: `English proficiency in ${city.name} is rated "${city.quickFacts.englishFriendly}." The primary language is ${city.quickFacts.language}.`,
  },
  {
    question: `How safe is ${city.name} for retirees?`,
    answer: city.quickFacts.safetyRating,
  },
  {
    question: `Can I retire in ${city.name} with $1 million?`,
    answer: `With a $1M portfolio generating ${formatCurrency(tier1M.monthlyBudget)}/month at a 4% safe withdrawal rate, your monthly expenses in ${city.name} would be approximately ${formatCurrency(totalSpend1M)}. That leaves a ${totalSpend1M <= tier1M.monthlyBudget ? `surplus of ${formatCurrency(tier1M.monthlyBudget - totalSpend1M)}/month` : `deficit of ${formatCurrency(totalSpend1M - tier1M.monthlyBudget)}/month`}. ${tier1M.lifestyle}`,
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqQuestions.map((faq) => ({
    '@type': 'Question',
    'name': faq.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.answer,
    },
  })),
};

const jsonLd = [breadcrumbLd, placeLd, faqLd];
---

<Layout
  title={`Retire in ${city.name}, ${city.country} — What Your Portfolio Buys You`}
  description={`Discover what a $1M to $10M portfolio gets you in ${city.name}, ${city.country}. Full lifestyle breakdowns including housing, healthcare, dining, and more.`}
  jsonLd={jsonLd}
>
  <CityHero city={city} />
  <TierNav />

  <div class="container-narrow py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content: Tier breakdowns -->
      <div class="lg:col-span-2 space-y-8">
        <div class="mb-8">
          <h2 class="font-serif text-3xl font-bold text-brand-950 mb-3">
            What Your Portfolio Gets You in {city.name}
          </h2>
          <p class="text-gray-600 leading-relaxed">
            We break down the lifestyle you can afford at five portfolio levels, using a
            <strong>4% safe withdrawal rate</strong>. Each tier shows realistic monthly costs
            for housing, food, healthcare, entertainment, and more in {city.name}.
          </p>
        </div>

        <PersonalizedTier city={city} />

        {tiers.map((tierKey) => (
          <TierBreakdown tierKey={tierKey} tier={city.tiers[tierKey]} cityName={city.name} />
        ))}

        <CityFAQ city={city} faqs={faqQuestions} />
        <RelatedCities currentCity={city} allCities={allCities} />
      </div>

      <script>
        // Accordion state machine: open first tier by default, mutual exclusion on click
        (function() {
          const accordions = document.querySelectorAll('.accordion-tier');
          if (accordions.length === 0) return;

          function openAccordion(el: Element) {
            el.setAttribute('data-open', 'true');
            const btn = el.querySelector('.accordion-header') as HTMLButtonElement;
            if (btn) btn.setAttribute('aria-expanded', 'true');
          }

          function closeAccordion(el: Element) {
            el.setAttribute('data-open', 'false');
            const btn = el.querySelector('.accordion-header') as HTMLButtonElement;
            if (btn) btn.setAttribute('aria-expanded', 'false');
          }

          // Only open first tier if there's no personalized tier (no ?nw= param)
          const hasPersonalized = new URLSearchParams(window.location.search).get('nw');
          if (!hasPersonalized) {
            openAccordion(accordions[0]);
          }

          // Click-to-toggle with mutual exclusion
          accordions.forEach((accordion) => {
            const header = accordion.querySelector('.accordion-header');
            if (!header) return;
            header.addEventListener('click', () => {
              const isOpen = accordion.getAttribute('data-open') === 'true';
              // If already open, do nothing — keep it visible
              if (isOpen) return;
              // Close all others, then open this one
              accordions.forEach((el) => closeAccordion(el));
              openAccordion(accordion);
              // Update nav pills
              const activeTier = accordion.getAttribute('data-open') === 'true'
                ? accordion.getAttribute('data-tier') || ''
                : '';
              document.querySelectorAll('.tier-nav-pill').forEach((pill) => {
                const target = (pill as HTMLButtonElement).dataset.tierTarget;
                if (target === activeTier) {
                  pill.classList.add('bg-brand-600', 'text-white', 'border-brand-600');
                  pill.classList.remove('text-gray-600', 'border-sand-200');
                } else {
                  pill.classList.remove('bg-brand-600', 'text-white', 'border-brand-600');
                  pill.classList.add('text-gray-600', 'border-sand-200');
                }
              });
            });
          });
        })();
      </script>

      <!-- Sidebar -->
      <div class="space-y-8">
        <QuickFacts facts={city.quickFacts} cityName={city.name} />
        <ComparisonCTA currentCity={city} allCities={allCities} />
      </div>
    </div>
  </div>
</Layout>
