---
import Layout from '../layouts/Layout.astro';
import { allCities } from '../data/cities/index';
import { formatCurrency, getTotalSpend, SAFE_WITHDRAWAL_RATE } from '../data/types';
import {
  getCityFireNumber,
  getLifestyleMonthlyCost,
  formatFireNumber,
  getCityDisplayTags,
  getTagColor,
  LIFESTYLE_LABELS,
  LIFESTYLE_DESCRIPTIONS,
  ALL_LIFESTYLE_TIERS,
} from '../data/fireNumber';
import type { LifestyleTier } from '../data/fireNumber';

// Pre-compute city data for client-side use
const cityData = allCities.map((city) => {
  const tags = getCityDisplayTags(city);
  const tiers: Record<string, { fireNumber: number; monthlyCost: number }> = {};
  for (const lifestyle of ALL_LIFESTYLE_TIERS) {
    tiers[lifestyle] = {
      fireNumber: getCityFireNumber(city, lifestyle),
      monthlyCost: getLifestyleMonthlyCost(city, lifestyle),
    };
  }
  return {
    name: city.name,
    country: city.country,
    slug: city.slug,
    emoji: city.emoji,
    region: city.region,
    fireScore: city.fireScore,
    tags,
    tiers,
  };
});


const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  'name': 'PortfolioAtlas',
  'url': 'https://portfolioatlas.org',
  'description': `Enter your portfolio value and see where in the world you can retire across 100+ cities. Built on the 4% rule.`,
};

const calcLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  'name': 'FIRE Retirement Calculator',
  'url': 'https://portfolioatlas.org',
  'applicationCategory': 'FinanceApplication',
  'operatingSystem': 'Web',
  'description': `Enter your portfolio and see where you can retire across 100+ cities worldwide.`,
  'offers': { '@type': 'Offer', 'price': '0', 'priceCurrency': 'USD' },
};

const lifestyleLabels = LIFESTYLE_LABELS;
const lifestyleDescriptions = LIFESTYLE_DESCRIPTIONS;
---

<Layout
  title="Where Can You Retire? | FIRE Calculator"
  description={`Enter your portfolio value and see where in the world you can retire. Compare FIRE Numbers across 100+ cities worldwide.`}
  jsonLd={[websiteLd, calcLd]}
>
  <!-- Hero: Two inputs only -->
  <section class="bg-brand-950 text-white py-16 md:py-24">
    <div class="container-narrow text-center">
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold mb-4">
        Where Can You Retire?
      </h1>
      <p class="text-xl text-sand-300 max-w-2xl mx-auto mb-10">
        Enter your portfolio. See where in the world you can retire. Understand what that life looks like.
      </p>

      <!-- Returning user message -->
      <div id="welcome-back" class="hidden mb-6">
        <p class="text-sm text-brand-300">Welcome back — we've saved your last portfolio value.</p>
      </div>

      <div class="max-w-xl mx-auto">
        <!-- Input 1: Portfolio Value -->
        <div class="mb-6">
          <label for="portfolio-input" class="block text-lg font-semibold text-white mb-3">
            Your Portfolio Value
          </label>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-brand-300 text-xl font-bold">$</span>
            <input
              type="text"
              id="portfolio-input"
              inputmode="numeric"
              placeholder="2,500,000"
              autocomplete="off"
              class="w-full pl-10 pr-4 py-4 text-2xl font-bold rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-brand-400"
            />
          </div>
          <div class="flex flex-wrap justify-center gap-2 mt-3">
            {[500_000, 1_000_000, 2_000_000, 3_000_000, 5_000_000, 10_000_000].map((value) => (
              <button
                type="button"
                class="quick-btn px-4 py-1.5 text-sm font-medium rounded-full bg-white/10 border border-white/20 text-white/80 hover:bg-white/20 hover:text-white transition-all"
                data-value={value}
              >
                {value >= 1_000_000 ? `$${value / 1_000_000}M` : `$${value / 1_000}K`}
              </button>
            ))}
          </div>
        </div>

        <!-- Input 2: Lifestyle Selector -->
        <div class="mb-8">
          <label class="block text-lg font-semibold text-white mb-3">
            Lifestyle Level
          </label>
          <div class="grid grid-cols-3 gap-2">
            {ALL_LIFESTYLE_TIERS.map((tier) => (
              <button
                type="button"
                class:list={[
                  'lifestyle-btn px-4 py-3 rounded-xl border text-center transition-all',
                  tier === 'comfortable'
                    ? 'bg-white/20 border-white/40 text-white'
                    : 'bg-white/5 border-white/15 text-white/70 hover:bg-white/10 hover:text-white',
                ]}
                data-lifestyle={tier}
              >
                <div class="text-sm font-bold">{lifestyleLabels[tier]}</div>
                <div class="text-[11px] mt-1 opacity-70">{lifestyleDescriptions[tier]}</div>
              </button>
            ))}
          </div>
        </div>

        <!-- CTA -->
        <button
          type="button"
          id="explore-btn"
          class="w-full py-4 text-lg font-bold rounded-xl bg-white text-brand-950 hover:bg-sand-100 transition-colors"
        >
          See Where I Can Retire
        </button>

        <p class="mt-4 text-sm text-sand-400">
          <a href="#reverse-flow" id="reverse-link" class="hover:text-white transition-colors underline decoration-dotted underline-offset-4">
            Not sure of your number? Calculate what you need →
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- Results Section (hidden until portfolio is entered) -->
  <section id="results-section" class="hidden">
    <!-- Summary line -->
    <div class="bg-white border-b border-sand-200 sticky top-16 z-30">
      <div class="container-narrow py-4">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <p id="results-summary" class="text-lg font-serif font-bold text-brand-950"></p>
          <!-- Inline lifestyle toggle for results page -->
          <div class="flex items-center gap-1">
            {ALL_LIFESTYLE_TIERS.map((tier) => (
              <button
                type="button"
                class:list={[
                  'results-lifestyle-btn px-3 py-1.5 text-xs font-semibold rounded-full border transition-all',
                  tier === 'comfortable'
                    ? 'bg-brand-600 text-white border-brand-600'
                    : 'bg-white text-gray-600 border-sand-200 hover:border-brand-300',
                ]}
                data-lifestyle={tier}
              >
                {lifestyleLabels[tier]}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="container-narrow py-4">
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">Filter:</span>
        <div class="flex gap-1">
          <button data-filter="loc" data-value="" class="filter-btn active px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">All</button>
          <button data-filter="loc" data-value="us" class="filter-btn px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">US Only</button>
          <button data-filter="loc" data-value="intl" class="filter-btn px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">International</button>
        </div>
        <div class="w-px h-5 bg-sand-200"></div>
        <div class="flex gap-1">
          <button data-filter="climate" data-value="" class="filter-btn active px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">Any Climate</button>
          <button data-filter="climate" data-value="warm" class="filter-btn px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">Warm</button>
          <button data-filter="climate" data-value="mild" class="filter-btn px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">Mild</button>
        </div>
        <div class="w-px h-5 bg-sand-200"></div>
        <div class="flex gap-1">
          <button data-filter="eng" data-value="" class="filter-btn active px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">Any Language</button>
          <button data-filter="eng" data-value="yes" class="filter-btn px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">English Essential</button>
        </div>
      </div>
    </div>

    <!-- City Grid -->
    <div class="container-wide pb-16">
      <div id="city-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4"></div>
      <div id="no-cities" class="hidden py-12 text-center">
        <p class="text-gray-500 font-semibold mb-2">No cities match your criteria</p>
        <p class="text-sm text-gray-400">Try adjusting your filters or increasing your portfolio.</p>
      </div>
      <div id="show-more-wrap" class="text-center py-6 hidden">
        <button id="show-more-btn" type="button" class="px-8 py-2.5 bg-white border border-sand-200 rounded-full text-sm font-medium text-gray-700 hover:bg-sand-50 transition-all">
          Show more cities
        </button>
        <p id="show-more-count" class="text-xs text-gray-400 mt-2"></p>
      </div>
    </div>
  </section>

  <!-- Fallback (shown when no portfolio entered) -->
  <section id="fallback-section" class="container-narrow py-20">
    <div class="max-w-2xl mx-auto text-center">
      <div class="w-16 h-16 bg-brand-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
        <span class="text-3xl">🌍</span>
      </div>
      <h2 class="font-serif text-3xl font-bold text-brand-950 mb-4">
        Discover Your FIRE Destinations
      </h2>
      <p class="text-gray-600 mb-6 leading-relaxed">
        Enter your portfolio value above and we'll show you every city in the world where you can retire.
        We compare your portfolio against the FIRE Number for each city — the exact amount you need to live there using the 4% rule.
      </p>
      <p class="text-sm text-gray-400">
        Currently tracking 100+ cities across 6 continents.
      </p>
    </div>
  </section>

  <!-- Reverse Flow (secondary, accessible via link) -->
  <section id="reverse-flow" class="container-narrow py-12 hidden">
    <div class="bg-white rounded-2xl border border-sand-200 shadow-sm p-6 max-w-2xl mx-auto">
      <h2 class="font-serif text-xl font-bold text-brand-950 mb-1 text-center">Calculate What You Need</h2>
      <p class="text-sm text-gray-500 text-center mb-6">Pick a city and lifestyle to see the portfolio required.</p>

      <div class="mb-4 relative">
        <label class="block text-sm font-semibold text-gray-700 mb-1">Target city</label>
        <input type="text" id="reverse-city-input" placeholder="Type a city name..." autocomplete="off"
          class="w-full rounded-xl border border-sand-200 px-4 py-2.5 text-sm font-medium text-gray-800 bg-sand-50 focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
        <div id="reverse-city-dropdown" class="reverse-dropdown hidden"></div>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-semibold text-gray-700 mb-2">Lifestyle level</label>
        <div class="grid grid-cols-3 gap-2">
          <button type="button" data-reverse-tier="budget" class="reverse-tier-btn px-3 py-3 rounded-xl border border-sand-200 text-center hover:border-brand-400 transition-colors">
            <div class="text-sm font-bold text-brand-950">Budget</div>
          </button>
          <button type="button" data-reverse-tier="comfortable" class="reverse-tier-btn px-3 py-3 rounded-xl border border-sand-200 text-center hover:border-brand-400 transition-colors">
            <div class="text-sm font-bold text-brand-950">Comfortable</div>
          </button>
          <button type="button" data-reverse-tier="luxury" class="reverse-tier-btn px-3 py-3 rounded-xl border border-sand-200 text-center hover:border-brand-400 transition-colors">
            <div class="text-sm font-bold text-brand-950">Luxury</div>
          </button>
        </div>
      </div>

      <div id="reverse-results" class="hidden">
        <div class="bg-brand-50 rounded-xl p-5 mb-4 text-center">
          <div class="text-sm text-gray-500 mb-1">FIRE Number needed</div>
          <div id="reverse-fire-number" class="text-3xl font-bold text-brand-600"></div>
          <div class="text-sm text-gray-500 mt-2">
            <span id="reverse-monthly"></span>/mo cost of living
          </div>
        </div>
        <div class="text-center">
          <button id="reverse-use-value" type="button" class="px-6 py-2.5 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors">
            Use this as my portfolio →
          </button>
        </div>
      </div>

      <div class="text-center mt-4">
        <button id="reverse-close" type="button" class="text-sm text-gray-400 hover:text-gray-600">
          ← Back
        </button>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="container-narrow py-12 text-center">
    <p class="text-sm text-gray-500">
      <a href="/compare" class="text-brand-600 hover:underline font-medium">Compare cities side by side</a>
    </p>
  </section>
</Layout>

<style>
  .filter-btn {
    color: #4b5563;
    background-color: white;
    border-color: #e6ddd0;
  }
  .filter-btn:hover {
    background-color: #faf8f5;
    border-color: #c4bfb5;
    color: #1f2937;
  }
  .filter-btn.active {
    background-color: #0074c5;
    color: white;
    border-color: #0074c5;
  }
  .city-card {
    background: white;
    border-radius: 1rem;
    border: 1px solid #e5e0d8;
    overflow: hidden;
    transition: box-shadow 0.2s, border-color 0.2s;
  }
  .city-card:hover {
    box-shadow: 0 8px 24px -4px rgba(0,0,0,0.08);
    border-color: #c4bfb5;
  }
  .reverse-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 50;
    max-height: 240px;
    overflow-y: auto;
    background: #faf8f5;
    border: 1px solid #e5e0d8;
    border-radius: 0.75rem;
    box-shadow: 0 12px 24px -4px rgba(0,0,0,0.12);
    margin-top: 4px;
    padding: 4px;
  }
</style>

<script define:vars={{ cityData, SAFE_WITHDRAWAL_RATE }}>
  // ─── State ───
  let portfolio = 0;
  let lifestyle = 'comfortable';
  let visibleCount = 12;
  const filters = { loc: '', climate: '', eng: '' };

  // Climate mappings
  const warmClimates = ['Tropical', 'Warm', 'Desert'];
  const mildClimates = ['Mediterranean', 'Mild'];

  // ─── Helpers ───
  function fmt(n) {
    return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
  }

  function fmtCompact(n) {
    if (n >= 1_000_000) {
      const m = n / 1_000_000;
      return '$' + m.toFixed(2).replace(/\.?0+$/, '') + 'M';
    }
    if (n >= 1_000) return '$' + Math.round(n / 1_000) + 'K';
    return fmt(n);
  }

  function fmtPortfolio(n) {
    if (n >= 1_000_000) {
      const m = n / 1_000_000;
      return '$' + (m % 1 === 0 ? m.toFixed(0) : m.toFixed(1)) + 'M';
    }
    return '$' + Math.round(n / 1_000) + 'K';
  }

  function formatWithCommas(val) {
    const num = val.replace(/[^0-9]/g, '');
    return num.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function getScoreClass(score) {
    if (score >= 7.5) return 'fire-score-high';
    if (score >= 5.5) return 'fire-score-mid';
    return 'fire-score-low';
  }

  function getTagColorClient(category, value) {
    switch (category) {
      case 'climate':
        if (['Tropical', 'Warm', 'Desert'].includes(value)) return 'bg-amber-50 text-amber-700';
        if (value === 'Mediterranean') return 'bg-sky-50 text-sky-700';
        return 'bg-slate-50 text-slate-600';
      case 'safety':
        if (value === 'Very safe') return 'bg-emerald-50 text-emerald-700';
        if (value === 'Safe') return 'bg-green-50 text-green-700';
        return 'bg-orange-50 text-orange-600';
      case 'english':
        if (value === 'Widely spoken') return 'bg-blue-50 text-blue-700';
        if (value === 'Common') return 'bg-indigo-50 text-indigo-600';
        return 'bg-gray-50 text-gray-500';
      case 'visa':
        if (value === 'Easy') return 'bg-emerald-50 text-emerald-700';
        if (value === 'Moderate') return 'bg-amber-50 text-amber-700';
        return 'bg-red-50 text-red-600';
      default: return 'bg-gray-50 text-gray-600';
    }
  }

  // ─── DOM ───
  const portfolioInput = document.getElementById('portfolio-input');
  const exploreBtn = document.getElementById('explore-btn');
  const resultsSection = document.getElementById('results-section');
  const fallbackSection = document.getElementById('fallback-section');
  const cityGrid = document.getElementById('city-grid');
  const noCities = document.getElementById('no-cities');
  const summaryEl = document.getElementById('results-summary');
  const showMoreWrap = document.getElementById('show-more-wrap');
  const showMoreBtn = document.getElementById('show-more-btn');
  const showMoreCount = document.getElementById('show-more-count');
  const welcomeBack = document.getElementById('welcome-back');

  // ─── Input Formatting ───
  portfolioInput.addEventListener('input', () => {
    const pos = portfolioInput.selectionStart || 0;
    const digitsBefore = portfolioInput.value.slice(0, pos).replace(/[^0-9]/g, '').length;
    portfolioInput.value = formatWithCommas(portfolioInput.value);
    let newPos = 0;
    let counted = 0;
    for (let i = 0; i < portfolioInput.value.length && counted < digitsBefore; i++) {
      if (/[0-9]/.test(portfolioInput.value[i])) counted++;
      newPos = i + 1;
    }
    portfolioInput.setSelectionRange(newPos, newPos);
  });

  // Quick-select buttons
  document.querySelectorAll('.quick-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const value = parseInt(btn.dataset.value, 10);
      portfolioInput.value = value.toLocaleString('en-US');
    });
  });

  // ─── Lifestyle selector (hero) ───
  document.querySelectorAll('.lifestyle-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      lifestyle = btn.dataset.lifestyle;
      document.querySelectorAll('.lifestyle-btn').forEach((b) => {
        const isActive = b === btn;
        b.classList.toggle('bg-white/20', isActive);
        b.classList.toggle('border-white/40', isActive);
        b.classList.toggle('text-white', isActive);
        b.classList.toggle('bg-white/5', !isActive);
        b.classList.toggle('border-white/15', !isActive);
        b.classList.toggle('text-white/70', !isActive);
      });
      // Also sync results lifestyle pills
      syncResultsLifestyle();
      if (portfolio > 0) renderResults();
    });
  });

  // ─── Lifestyle selector (results bar) ───
  function syncResultsLifestyle() {
    document.querySelectorAll('.results-lifestyle-btn').forEach((btn) => {
      const isActive = btn.dataset.lifestyle === lifestyle;
      btn.classList.toggle('bg-brand-600', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('border-brand-600', isActive);
      btn.classList.toggle('bg-white', !isActive);
      btn.classList.toggle('text-gray-600', !isActive);
      btn.classList.toggle('border-sand-200', !isActive);
    });
  }

  document.querySelectorAll('.results-lifestyle-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      lifestyle = btn.dataset.lifestyle;
      syncResultsLifestyle();
      // Also sync hero buttons
      document.querySelectorAll('.lifestyle-btn').forEach((b) => {
        const isActive = b.dataset.lifestyle === lifestyle;
        b.classList.toggle('bg-white/20', isActive);
        b.classList.toggle('border-white/40', isActive);
        b.classList.toggle('text-white', isActive);
        b.classList.toggle('bg-white/5', !isActive);
        b.classList.toggle('border-white/15', !isActive);
        b.classList.toggle('text-white/70', !isActive);
      });
      if (portfolio > 0) renderResults();
    });
  });

  // ─── Filter buttons ───
  document.querySelectorAll('.filter-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const filterName = btn.dataset.filter;
      const filterValue = btn.dataset.value || '';
      filters[filterName] = filterValue;

      // Update active styles
      document.querySelectorAll(`.filter-btn[data-filter="${filterName}"]`).forEach((b) => {
        b.classList.toggle('active', (b.dataset.value || '') === filterValue);
      });
      if (portfolio > 0) renderResults();
    });
  });

  // ─── Explore button ───
  exploreBtn.addEventListener('click', () => {
    const raw = parseInt((portfolioInput.value || '').replace(/[^0-9]/g, ''), 10) || 0;
    if (raw <= 0) {
      portfolioInput.focus();
      return;
    }
    portfolio = raw;
    saveState();
    renderResults();
    resultsSection.scrollIntoView({ behavior: 'smooth' });
  });

  // Enter key on input
  portfolioInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      exploreBtn.click();
    }
  });

  // Show more
  showMoreBtn?.addEventListener('click', () => {
    visibleCount += 12;
    renderResults();
  });

  // ─── Filter Logic ───
  function passesFilters(city) {
    if (filters.loc === 'us' && city.country !== 'United States') return false;
    if (filters.loc === 'intl' && city.country === 'United States') return false;
    if (filters.climate === 'warm' && !warmClimates.includes(city.tags.climate)) return false;
    if (filters.climate === 'mild' && !mildClimates.includes(city.tags.climate)) return false;
    if (filters.eng === 'yes' && city.tags.english !== 'Widely spoken') return false;
    return true;
  }

  // ─── Render Results ───
  function renderResults() {
    fallbackSection?.classList.add('hidden');
    resultsSection?.classList.remove('hidden');
    document.getElementById('reverse-flow')?.classList.add('hidden');

    // Compute and sort cities
    const sorted = cityData
      .filter(passesFilters)
      .map((city) => {
        const tierData = city.tiers[lifestyle];
        const fireNumber = tierData.fireNumber;
        const monthlyCost = tierData.monthlyCost;
        const affordable = portfolio >= fireNumber;
        const gap = portfolio - fireNumber;
        return { ...city, fireNumber, monthlyCost, affordable, gap };
      })
      .sort((a, b) => {
        // Affordable first, then by FIRE score
        if (a.affordable !== b.affordable) return a.affordable ? -1 : 1;
        // Within affordable: by FIRE score desc
        // Within unaffordable: by gap (closest to affordable first)
        if (a.affordable) return b.fireScore - a.fireScore;
        return b.gap - a.gap; // gap is negative, so larger (less negative) = closer
      });

    const affordableCount = sorted.filter((c) => c.affordable).length;
    const lifestyleLabel = lifestyle.charAt(0).toUpperCase() + lifestyle.slice(1);

    // Update summary
    if (summaryEl) {
      summaryEl.innerHTML = `Your <strong>${fmtPortfolio(portfolio)}</strong> portfolio unlocks a <strong>${lifestyleLabel}</strong> lifestyle in <strong>${affordableCount}</strong> ${affordableCount === 1 ? 'city' : 'cities'} worldwide.`;
    }

    // Render cards
    const toShow = sorted.slice(0, visibleCount);

    if (sorted.length === 0) {
      cityGrid.innerHTML = '';
      noCities?.classList.remove('hidden');
    } else {
      noCities?.classList.add('hidden');
      cityGrid.innerHTML = toShow.map((city) => {
        const tagPills = [
          { label: city.tags.climate, cat: 'climate' },
          { label: city.tags.safety, cat: 'safety' },
          { label: city.tags.english, cat: 'english' },
        ].filter((t) => t.label).slice(0, 3);

        const tagHTML = tagPills.map((t) =>
          `<span class="text-[10px] font-medium px-2 py-0.5 rounded-full ${getTagColorClient(t.cat, t.label)}">${t.label}</span>`
        ).join('');

        const signalHTML = city.affordable
          ? '<div class="flex items-center gap-1.5 mt-1"><svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span class="text-sm font-semibold text-emerald-600">You can retire here</span></div>'
          : `<p class="text-sm text-gray-500 mt-1">Need ${fmtCompact(Math.abs(city.gap))} more</p>`;

        const barColor = city.affordable ? 'from-emerald-400 to-emerald-500' : 'from-brand-500 to-brand-600';

        return `<a href="/cities/${city.slug}" class="city-card block group">
          <div class="h-2 bg-gradient-to-r ${barColor}"></div>
          <div class="p-5">
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-2">
                <span class="text-2xl">${city.emoji}</span>
                <div>
                  <h3 class="font-serif font-bold text-lg text-brand-950 group-hover:text-brand-600 transition-colors">${city.name}</h3>
                  <p class="text-sm text-gray-500">${city.country}</p>
                </div>
              </div>
              <div class="fire-score w-10 h-10 text-sm ${getScoreClass(city.fireScore)}">${city.fireScore.toFixed(1)}</div>
            </div>
            <div class="mb-3">
              <div class="flex items-baseline justify-between">
                <span class="text-xs text-gray-500">FIRE Number</span>
                <span class="text-lg font-bold text-brand-700">${fmtCompact(city.fireNumber)}</span>
              </div>
              ${signalHTML}
            </div>
            <div class="flex flex-wrap gap-1.5 mb-3">${tagHTML}</div>
            <div class="flex items-center justify-between pt-3 border-t border-sand-100">
              <p class="text-xs text-gray-400">From ${fmt(city.monthlyCost)}/mo</p>
              <span class="text-xs font-medium text-brand-600 bg-brand-50 px-3 py-1 rounded-full">${city.region}</span>
            </div>
          </div>
        </a>`;
      }).join('');
    }

    // Show more button
    if (showMoreWrap && showMoreCount) {
      if (visibleCount < sorted.length) {
        showMoreWrap.classList.remove('hidden');
        showMoreCount.textContent = `Showing ${toShow.length} of ${sorted.length} cities`;
      } else {
        showMoreWrap.classList.add('hidden');
      }
    }

    updateURL();
  }

  // ─── URL & State Persistence ───
  function saveState() {
    try {
      localStorage.setItem('pa_calc', JSON.stringify({
        nw: portfolio,
        lifestyle: lifestyle,
      }));
    } catch (e) {}
  }

  function updateURL() {
    const params = new URLSearchParams();
    if (portfolio > 0) params.set('nw', String(portfolio));
    if (lifestyle !== 'comfortable') params.set('lifestyle', lifestyle);
    if (filters.loc) params.set('loc', filters.loc);
    if (filters.climate) params.set('climate', filters.climate);
    if (filters.eng) params.set('eng', filters.eng);
    const qs = params.toString();
    history.replaceState(null, '', '/' + (qs ? '?' + qs : ''));
    saveState();
  }

  // ─── Restore from URL / localStorage ───
  function restore() {
    const params = new URLSearchParams(window.location.search);
    let nw = parseInt(params.get('nw') || '0', 10);
    let ls = params.get('lifestyle') || '';
    let restored = false;

    // Try localStorage if no URL params
    if (!nw) {
      try {
        const stored = JSON.parse(localStorage.getItem('pa_calc') || '{}');
        if (stored.nw && stored.nw > 0) {
          nw = stored.nw;
          if (!ls && stored.lifestyle) ls = stored.lifestyle;
          restored = true;
        }
      } catch (e) {}
    }

    // Restore filters from URL
    if (params.get('loc')) filters.loc = params.get('loc');
    if (params.get('climate')) filters.climate = params.get('climate');
    if (params.get('eng')) filters.eng = params.get('eng');

    // Sync filter button styles
    for (const [key, val] of Object.entries(filters)) {
      document.querySelectorAll(`.filter-btn[data-filter="${key}"]`).forEach((btn) => {
        btn.classList.toggle('active', (btn.dataset.value || '') === val);
      });
    }

    // Restore lifestyle
    if (ls && ['budget', 'comfortable', 'luxury'].includes(ls)) {
      lifestyle = ls;
      // Sync hero buttons
      document.querySelectorAll('.lifestyle-btn').forEach((btn) => {
        const isActive = btn.dataset.lifestyle === lifestyle;
        btn.classList.toggle('bg-white/20', isActive);
        btn.classList.toggle('border-white/40', isActive);
        btn.classList.toggle('text-white', isActive);
        btn.classList.toggle('bg-white/5', !isActive);
        btn.classList.toggle('border-white/15', !isActive);
        btn.classList.toggle('text-white/70', !isActive);
      });
      syncResultsLifestyle();
    }

    if (nw > 0) {
      portfolio = nw;
      portfolioInput.value = nw.toLocaleString('en-US');

      if (restored) {
        welcomeBack?.classList.remove('hidden');
      }

      renderResults();
    } else {
      fallbackSection?.classList.remove('hidden');
    }
  }

  // ─── Reverse Flow ───
  function setupReverseFlow() {
    const reverseLink = document.getElementById('reverse-link');
    const reverseFlow = document.getElementById('reverse-flow');
    const reverseClose = document.getElementById('reverse-close');
    const reverseInput = document.getElementById('reverse-city-input');
    const reverseDropdown = document.getElementById('reverse-city-dropdown');
    const reverseResults = document.getElementById('reverse-results');
    const reverseUse = document.getElementById('reverse-use-value');

    let selectedCity = null;
    let selectedTier = null;

    reverseLink?.addEventListener('click', (e) => {
      e.preventDefault();
      reverseFlow?.classList.remove('hidden');
      reverseFlow?.scrollIntoView({ behavior: 'smooth' });
    });

    reverseClose?.addEventListener('click', () => {
      reverseFlow?.classList.add('hidden');
    });

    // City search
    reverseInput?.addEventListener('input', () => {
      const q = reverseInput.value.toLowerCase().trim();
      if (q.length < 2) { reverseDropdown?.classList.add('hidden'); return; }
      const matches = cityData.filter((c) =>
        c.name.toLowerCase().includes(q) || c.country.toLowerCase().includes(q)
      ).slice(0, 8);

      if (!reverseDropdown) return;
      if (matches.length === 0) {
        reverseDropdown.innerHTML = '<div class="text-sm text-gray-400 p-3 text-center">No cities found</div>';
      } else {
        reverseDropdown.innerHTML = matches.map((c) =>
          `<div class="flex items-center gap-2 px-3 py-2 text-sm cursor-pointer hover:bg-sand-100 rounded-lg" data-slug="${c.slug}">
            <span>${c.emoji}</span><span class="font-medium">${c.name}</span><span class="text-gray-400 text-xs">${c.country}</span>
          </div>`
        ).join('');
        reverseDropdown.querySelectorAll('[data-slug]').forEach((item) => {
          item.addEventListener('click', () => {
            selectedCity = cityData.find((c) => c.slug === item.dataset.slug);
            if (selectedCity) {
              reverseInput.value = selectedCity.name + ', ' + selectedCity.country;
              reverseDropdown.classList.add('hidden');
              updateReverse();
            }
          });
        });
      }
      reverseDropdown.classList.remove('hidden');
    });

    reverseInput?.addEventListener('blur', () => {
      setTimeout(() => reverseDropdown?.classList.add('hidden'), 200);
    });

    // Tier selection
    document.querySelectorAll('.reverse-tier-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedTier = btn.dataset.reverseTier;
        document.querySelectorAll('.reverse-tier-btn').forEach((b) => {
          b.classList.toggle('border-brand-500', b === btn);
          b.classList.toggle('bg-brand-50', b === btn);
          b.classList.toggle('border-sand-200', b !== btn);
        });
        updateReverse();
      });
    });

    function updateReverse() {
      if (!selectedCity || !selectedTier) return;
      const data = selectedCity.tiers[selectedTier];
      if (!data) return;

      const fireNumEl = document.getElementById('reverse-fire-number');
      const monthlyEl = document.getElementById('reverse-monthly');
      if (fireNumEl) fireNumEl.textContent = fmtCompact(data.fireNumber);
      if (monthlyEl) monthlyEl.textContent = fmt(data.monthlyCost);
      reverseResults?.classList.remove('hidden');
    }

    reverseUse?.addEventListener('click', () => {
      if (!selectedCity || !selectedTier) return;
      const fn = selectedCity.tiers[selectedTier]?.fireNumber;
      if (!fn) return;
      portfolio = fn;
      portfolioInput.value = fn.toLocaleString('en-US');
      reverseFlow?.classList.add('hidden');
      renderResults();
      resultsSection?.scrollIntoView({ behavior: 'smooth' });
    });
  }

  // ─── Init ───
  setupReverseFlow();
  restore();
</script>
