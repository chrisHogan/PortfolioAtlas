---
import Layout from '../layouts/Layout.astro';
import { allCities } from '../data/cities/index';
import { formatCurrency, getTotalSpend, SAFE_WITHDRAWAL_RATE } from '../data/types';
import {
  getCityFireNumber,
  getLifestyleMonthlyCost,
  formatFireNumber,
  getCityDisplayTags,
  getTagColor,
  LIFESTYLE_LABELS,
  LIFESTYLE_DESCRIPTIONS,
  ALL_LIFESTYLE_TIERS,
  PREMIUM_UNLOCK_THRESHOLDS,
} from '../data/fireNumber';
import type { LifestyleTier } from '../data/fireNumber';

// Pre-compute city data for client-side use
const cityData = allCities.map((city) => {
  const tags = getCityDisplayTags(city);
  const tiers: Record<string, { fireNumber: number; monthlyCost: number }> = {};
  for (const lifestyle of ALL_LIFESTYLE_TIERS) {
    tiers[lifestyle] = {
      fireNumber: getCityFireNumber(city, lifestyle),
      monthlyCost: getLifestyleMonthlyCost(city, lifestyle),
    };
  }
  return {
    name: city.name,
    country: city.country,
    slug: city.slug,
    emoji: city.emoji,
    region: city.region,
    fireScore: city.fireScore,
    tags,
    tiers,
    unlockThreshold: PREMIUM_UNLOCK_THRESHOLDS[city.slug] || 0,
  };
});


const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  'name': 'PortfolioAtlas',
  'url': 'https://portfolioatlas.org',
  'description': `Enter your portfolio value and see where in the world you can retire across 100+ cities. Built on the 4% rule.`,
};

const calcLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  'name': 'FIRE Retirement Calculator',
  'url': 'https://portfolioatlas.org',
  'applicationCategory': 'FinanceApplication',
  'operatingSystem': 'Web',
  'description': `Enter your portfolio and see where you can retire across 100+ cities worldwide.`,
  'offers': { '@type': 'Offer', 'price': '0', 'priceCurrency': 'USD' },
};

const lifestyleLabels = LIFESTYLE_LABELS;
const lifestyleDescriptions = LIFESTYLE_DESCRIPTIONS;
---

<Layout
  title="Where Can Your Portfolio Buy You Freedom?"
  description="See exactly where in the world your investment portfolio can sustain your retirement. 100+ cities, real FIRE numbers, Monte Carlo analysis."
  jsonLd={[websiteLd, calcLd]}
>
  <!-- Hero -->
  <section class="bg-brand-950 text-white py-16 md:py-24">
    <div class="container-narrow text-center">
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold mb-4">
        Where Can You Retire?
      </h1>
      <p class="text-xl text-sand-300 max-w-2xl mx-auto mb-12">
        Enter your portfolio. See where in the world you can retire. Understand what that life looks like.
      </p>

      <!-- Returning user message -->
      <div id="welcome-back" class="hidden mb-6">
        <p class="text-sm text-brand-300">Welcome back — we've saved your last portfolio value.</p>
      </div>

      <!-- 1-2-3 Flow Indicator -->
      <div class="max-w-2xl mx-auto mb-12">
        <!-- Desktop -->
        <div class="hidden sm:flex items-start justify-center">
          <div class="flex flex-col items-center w-36">
            <div class="step-circle w-14 h-14 rounded-full bg-brand-600/20 ring-2 ring-brand-400/50 flex items-center justify-center text-xl font-bold text-white">1</div>
            <span class="text-xs font-medium text-sand-300 mt-2.5">Enter your portfolio</span>
          </div>
          <div class="flex-shrink-0 mt-7 w-12 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-400/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </div>
          <div class="flex flex-col items-center w-36">
            <div class="step-circle w-14 h-14 rounded-full bg-brand-600/20 ring-2 ring-brand-400/50 flex items-center justify-center text-xl font-bold text-white">2</div>
            <span class="text-xs font-medium text-sand-300 mt-2.5">Choose your lifestyle</span>
          </div>
          <div class="flex-shrink-0 mt-7 w-12 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-400/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </div>
          <div class="flex flex-col items-center w-36">
            <div class="step-circle w-14 h-14 rounded-full bg-brand-600/20 ring-2 ring-brand-400/50 flex items-center justify-center text-xl font-bold text-white">3</div>
            <span class="text-xs font-medium text-sand-300 mt-2.5">Explore results</span>
          </div>
        </div>
        <!-- Mobile -->
        <div class="sm:hidden flex flex-col items-center gap-1.5">
          <div class="flex items-center gap-3 w-56">
            <div class="step-circle w-11 h-11 shrink-0 rounded-full bg-brand-600/20 ring-2 ring-brand-400/50 flex items-center justify-center text-base font-bold text-white">1</div>
            <span class="text-sm font-medium text-sand-300">Enter your portfolio</span>
          </div>
          <svg class="w-4 h-4 text-brand-400/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" /></svg>
          <div class="flex items-center gap-3 w-56">
            <div class="step-circle w-11 h-11 shrink-0 rounded-full bg-brand-600/20 ring-2 ring-brand-400/50 flex items-center justify-center text-base font-bold text-white">2</div>
            <span class="text-sm font-medium text-sand-300">Choose your lifestyle</span>
          </div>
          <svg class="w-4 h-4 text-brand-400/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" /></svg>
          <div class="flex items-center gap-3 w-56">
            <div class="step-circle w-11 h-11 shrink-0 rounded-full bg-brand-600/20 ring-2 ring-brand-400/50 flex items-center justify-center text-base font-bold text-white">3</div>
            <span class="text-sm font-medium text-sand-300">Explore results</span>
          </div>
        </div>
      </div>

      <div class="max-w-xl mx-auto">
        <!-- Input 1: Portfolio Value -->
        <div class="mb-8">
          <label for="portfolio-input" class="block text-lg font-semibold text-white mb-3">
            Your Portfolio Value
          </label>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-brand-300 text-xl font-bold">$</span>
            <input
              type="text"
              id="portfolio-input"
              inputmode="numeric"
              placeholder="2,500,000"
              autocomplete="off"
              class="w-full pl-10 pr-4 py-4 text-2xl font-bold rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-brand-400"
            />
          </div>
          <div class="flex flex-wrap justify-center gap-2 mt-3">
            {[500_000, 1_000_000, 2_000_000, 3_000_000, 5_000_000, 10_000_000].map((value) => (
              <button
                type="button"
                class="quick-btn px-4 py-1.5 text-sm font-medium rounded-full bg-white/10 border border-white/20 text-white/80 hover:bg-white/20 hover:text-white transition-all"
                data-value={value}
              >
                {value >= 1_000_000 ? `$${value / 1_000_000}M` : `$${value / 1_000}K`}
              </button>
            ))}
          </div>
        </div>

        <!-- Input 2: Lifestyle Selector -->
        <div class="mb-8">
          <label class="block text-lg font-semibold text-white mb-3">
            Your Lifestyle
          </label>
          <div class="grid grid-cols-3 gap-2">
            {ALL_LIFESTYLE_TIERS.map((tier) => (
              <button
                type="button"
                class:list={[
                  'lifestyle-btn px-4 py-3 rounded-xl border text-center transition-all',
                  tier === 'comfortable'
                    ? 'bg-white/20 border-white/40 text-white'
                    : 'bg-white/5 border-white/15 text-white/70 hover:bg-white/10 hover:text-white',
                ]}
                data-lifestyle={tier}
              >
                <div class="text-sm font-bold">{lifestyleLabels[tier]}</div>
                <div class="text-[11px] mt-1 opacity-70">{lifestyleDescriptions[tier]}</div>
              </button>
            ))}
          </div>
        </div>

        <!-- Input 3: Optional inputs (collapsed by default) -->
        <div class="mb-8">
          <button
            type="button"
            id="optional-toggle"
            class="flex items-center justify-center gap-2 w-full py-2 text-xs font-medium text-sand-400 hover:text-sand-200 transition-colors"
          >
            <span>Refine your projections (optional)</span>
            <svg id="optional-chevron" xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div id="optional-inputs" class="hidden mt-4 pt-4 border-t border-white/10 space-y-4">
            <!-- Annual Savings from Work -->
            <div>
              <label for="savings-input" class="block text-xs font-medium text-sand-300 mb-1.5">
                Annual savings from work (optional)
              </label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-brand-300 text-sm font-bold">$</span>
                <input
                  type="text"
                  id="savings-input"
                  inputmode="numeric"
                  placeholder="e.g. $30,000/year from your salary"
                  autocomplete="off"
                  class="w-full pl-8 pr-3 py-2.5 text-sm font-bold rounded-lg bg-white/10 backdrop-blur-sm border border-white/15 text-white placeholder-white/25 focus:outline-none focus:ring-2 focus:ring-brand-400"
                />
              </div>
              <p id="savings-error" class="text-xs text-red-400 mt-1 hidden"></p>
              <p class="text-[11px] text-sand-500 mt-1.5 leading-snug">How much you save each year from working. We'll use this to show when cities become affordable as your portfolio grows.</p>
            </div>

            <!-- Passive Income in Retirement -->
            <div>
              <label for="passive-input" class="block text-xs font-medium text-sand-300 mb-1.5">
                Passive income in retirement (optional)
                <span class="relative group inline-block ml-1 cursor-help align-middle">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-sand-400 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-64 rounded-lg bg-brand-950 text-white text-[11px] leading-snug px-3 py-2 shadow-lg opacity-0 group-hover:opacity-100 transition-opacity z-50">
                    Assumes this income continues indefinitely and keeps pace with inflation. Fixed income sources like pensions may provide less protection over time.
                  </span>
                </span>
              </label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-brand-300 text-sm font-bold">$</span>
                <input
                  type="text"
                  id="passive-input"
                  inputmode="numeric"
                  placeholder="e.g. $24,000/year from rental income"
                  autocomplete="off"
                  class="w-full pl-8 pr-3 py-2.5 text-sm font-bold rounded-lg bg-white/10 backdrop-blur-sm border border-white/15 text-white placeholder-white/25 focus:outline-none focus:ring-2 focus:ring-brand-400"
                />
              </div>
              <p id="passive-error" class="text-xs text-red-400 mt-1 hidden"></p>
              <p id="passive-warn" class="text-xs text-amber-400 mt-1 hidden"></p>
              <p class="text-[11px] text-sand-500 mt-1.5 leading-snug">Rental income, dividends, pension, or any income that continues after you stop working. Reduces the portfolio you need to retire.</p>
            </div>
          </div>
        </div>

        <!-- CTA (Step 3) -->
        <button
          type="button"
          id="explore-btn"
          class="w-full py-4 text-lg font-bold rounded-xl bg-brand-600 text-white hover:bg-brand-700 transition-colors"
        >
          Explore Where I Can Retire →
        </button>

        <p class="mt-4 text-sm text-sand-400">
          <a href="#reverse-flow" id="reverse-link" class="hover:text-white transition-colors underline decoration-dotted underline-offset-4">
            Not sure of your number? Calculate what you need →
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- Results Section (hidden until portfolio is entered) -->
  <section id="results-section" class="hidden">
    <!-- Summary line -->
    <div class="bg-white border-b border-sand-200 sticky top-16 z-30">
      <div class="container-narrow py-4">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <div class="flex items-center gap-3">
            <p id="results-summary" class="text-lg font-serif font-bold text-brand-950"></p>
            <button id="share-btn" type="button" class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-full border border-sand-200 text-gray-600 hover:bg-sand-50 hover:border-brand-300 transition-all" title="Copy shareable link">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
              </svg>
              Share
            </button>
          </div>
          <!-- Inline lifestyle toggle for results page -->
          <div class="flex items-center gap-1">
            {ALL_LIFESTYLE_TIERS.map((tier) => (
              <button
                type="button"
                class:list={[
                  'results-lifestyle-btn px-3 py-1.5 text-xs font-semibold rounded-full border transition-all',
                  tier === 'comfortable'
                    ? 'bg-brand-600 text-white border-brand-600'
                    : 'bg-white text-gray-600 border-sand-200 hover:border-brand-300',
                ]}
                data-lifestyle={tier}
              >
                {lifestyleLabels[tier]}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="container-narrow py-4">
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">Filter:</span>
        <div class="flex gap-1">
          <button data-filter="loc" data-value="" class="filter-btn active px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">All</button>
          <button data-filter="loc" data-value="us" class="filter-btn px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">US Only</button>
          <button data-filter="loc" data-value="intl" class="filter-btn px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">International</button>
        </div>
        <div class="w-px h-5 bg-sand-200"></div>
        <div class="flex gap-1">
          <button data-filter="climate" data-value="" class="filter-btn active px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">Any Climate</button>
          <button data-filter="climate" data-value="warm" class="filter-btn px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">Warm</button>
          <button data-filter="climate" data-value="mild" class="filter-btn px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">Mild</button>
        </div>
        <div class="w-px h-5 bg-sand-200"></div>
        <div class="flex gap-1">
          <button data-filter="eng" data-value="" class="filter-btn active px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">Any Language</button>
          <button data-filter="eng" data-value="yes" class="filter-btn px-3 py-1.5 text-xs font-medium rounded-full border border-sand-200 transition-all">English Essential</button>
        </div>
      </div>
    </div>

    <!-- City Sections -->
    <div class="container-wide pb-16">
      <div id="city-sections"></div>
      <div id="no-cities" class="hidden py-12 text-center">
        <p class="text-gray-500 font-semibold mb-2">No cities match your criteria</p>
        <p class="text-sm text-gray-400">Try adjusting your filters or increasing your portfolio.</p>
      </div>
      <div id="show-more-wrap" class="text-center py-6 hidden">
        <button id="show-more-btn" type="button" class="px-8 py-2.5 bg-white border border-sand-200 rounded-full text-sm font-medium text-gray-700 hover:bg-sand-50 transition-all">
          Show more cities
        </button>
        <p id="show-more-count" class="text-xs text-gray-400 mt-2"></p>
      </div>
    </div>
  </section>

  <!-- Fallback (shown when no portfolio entered) -->
  <section id="fallback-section" class="container-narrow py-20">
    <div class="max-w-2xl mx-auto text-center">
      <div class="w-16 h-16 bg-brand-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
        <span class="text-3xl">🌍</span>
      </div>
      <h2 class="font-serif text-3xl font-bold text-brand-950 mb-4">
        Discover Your FIRE Destinations
      </h2>
      <p class="text-gray-600 mb-6 leading-relaxed">
        Enter your portfolio value above and we'll show you every city in the world where you can retire.
        We compare your portfolio against the FIRE Number for each city — the exact amount you need to live there using the 4% rule.
      </p>
      <p class="text-sm text-gray-400">
        Currently tracking 100+ cities across 6 continents.
      </p>
    </div>
  </section>

  <!-- Reverse Flow (secondary, accessible via link) -->
  <section id="reverse-flow" class="container-narrow py-12 hidden">
    <div class="bg-white rounded-2xl border border-sand-200 shadow-sm p-6 max-w-2xl mx-auto">
      <h2 class="font-serif text-xl font-bold text-brand-950 mb-1 text-center">Calculate What You Need</h2>
      <p class="text-sm text-gray-500 text-center mb-6">Pick a city and lifestyle to see the portfolio required.</p>

      <div class="mb-4 relative">
        <label class="block text-sm font-semibold text-gray-700 mb-1">Target city</label>
        <input type="text" id="reverse-city-input" placeholder="Type a city name..." autocomplete="off"
          class="w-full rounded-xl border border-sand-200 px-4 py-2.5 text-sm font-medium text-gray-800 bg-sand-50 focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
        <div id="reverse-city-dropdown" class="reverse-dropdown hidden"></div>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-semibold text-gray-700 mb-2">Lifestyle level</label>
        <div class="grid grid-cols-3 gap-2">
          <button type="button" data-reverse-tier="budget" class="reverse-tier-btn px-3 py-3 rounded-xl border border-sand-200 text-center hover:border-brand-400 transition-colors">
            <div class="text-sm font-bold text-brand-950">Lean FIRE</div>
          </button>
          <button type="button" data-reverse-tier="comfortable" class="reverse-tier-btn px-3 py-3 rounded-xl border border-sand-200 text-center hover:border-brand-400 transition-colors">
            <div class="text-sm font-bold text-brand-950">FIRE</div>
          </button>
          <button type="button" data-reverse-tier="luxury" class="reverse-tier-btn px-3 py-3 rounded-xl border border-sand-200 text-center hover:border-brand-400 transition-colors">
            <div class="text-sm font-bold text-brand-950">Fat FIRE</div>
          </button>
        </div>
      </div>

      <div id="reverse-results" class="hidden">
        <div class="bg-brand-50 rounded-xl p-5 mb-4 text-center">
          <div class="text-sm text-gray-500 mb-1">FIRE Number needed</div>
          <div id="reverse-fire-number" class="text-3xl font-bold text-brand-600"></div>
          <div class="text-sm text-gray-500 mt-2">
            <span id="reverse-monthly"></span>/mo cost of living
          </div>
        </div>
        <div class="text-center">
          <button id="reverse-use-value" type="button" class="px-6 py-2.5 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors">
            Use this as my portfolio →
          </button>
        </div>
      </div>

      <div class="text-center mt-4">
        <button id="reverse-close" type="button" class="text-sm text-gray-400 hover:text-gray-600">
          ← Back
        </button>
      </div>
    </div>
  </section>

  <!-- Toast notification -->
  <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden">
    <div class="bg-brand-950 text-white text-sm font-medium px-5 py-2.5 rounded-full shadow-lg">
      Link copied!
    </div>
  </div>

  <!-- Bottom CTA -->
  <section class="container-narrow py-12 text-center">
    <p class="text-sm text-gray-500">
      <a href="/compare" class="text-brand-600 hover:underline font-medium">Compare cities side by side</a>
    </p>
  </section>
</Layout>

<style>
  .step-circle {
    box-shadow: 0 0 20px rgba(0, 116, 197, 0.15);
  }
  .filter-btn {
    color: #4b5563;
    background-color: white;
    border-color: #e6ddd0;
  }
  .filter-btn:hover {
    background-color: #faf8f5;
    border-color: #c4bfb5;
    color: #1f2937;
  }
  .filter-btn.active {
    background-color: #0074c5;
    color: white;
    border-color: #0074c5;
  }
  .city-card {
    background: white;
    border-radius: 1rem;
    border: 1px solid #e5e0d8;
    overflow: hidden;
    transition: box-shadow 0.2s, border-color 0.2s;
  }
  .city-card:hover {
    box-shadow: 0 8px 24px -4px rgba(0,0,0,0.08);
    border-color: #c4bfb5;
  }
  .reverse-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 50;
    max-height: 240px;
    overflow-y: auto;
    background: #faf8f5;
    border: 1px solid #e5e0d8;
    border-radius: 0.75rem;
    box-shadow: 0 12px 24px -4px rgba(0,0,0,0.12);
    margin-top: 4px;
    padding: 4px;
  }
</style>

<script define:vars={{ cityData, SAFE_WITHDRAWAL_RATE }}>
  // ─── State ───
  let portfolio = 0;
  let lifestyle = 'comfortable';
  let annualSavings = 0;
  let passiveIncome = 0;
  let visibleCount = 12;
  const filters = { loc: '', climate: '', eng: '' };

  // Climate mappings
  const warmClimates = ['Tropical', 'Warm', 'Desert'];
  const mildClimates = ['Mediterranean', 'Mild'];

  // ─── Helpers ───
  function fmt(n) {
    return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
  }

  function fmtCompact(n) {
    if (n >= 1_000_000) {
      const m = n / 1_000_000;
      return '$' + m.toFixed(2).replace(/\.?0+$/, '') + 'M';
    }
    if (n >= 1_000) return '$' + Math.round(n / 1_000) + 'K';
    return fmt(n);
  }

  function fmtPortfolio(n) {
    if (n >= 1_000_000) {
      const m = n / 1_000_000;
      return '$' + (m % 1 === 0 ? m.toFixed(0) : m.toFixed(1)) + 'M';
    }
    return '$' + Math.round(n / 1_000) + 'K';
  }

  function formatWithCommas(val) {
    const num = val.replace(/[^0-9]/g, '');
    return num.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function getScoreClass(score) {
    if (score >= 7.5) return 'fire-score-high';
    if (score >= 5.5) return 'fire-score-mid';
    return 'fire-score-low';
  }

  function getTagColorClient(category, value) {
    switch (category) {
      case 'climate':
        if (['Tropical', 'Warm', 'Desert'].includes(value)) return 'bg-amber-50 text-amber-700';
        if (value === 'Mediterranean') return 'bg-sky-50 text-sky-700';
        return 'bg-slate-50 text-slate-600';
      case 'safety':
        if (value === 'Very safe') return 'bg-emerald-50 text-emerald-700';
        if (value === 'Safe') return 'bg-green-50 text-green-700';
        return 'bg-orange-50 text-orange-600';
      case 'english':
        if (value === 'Widely spoken') return 'bg-blue-50 text-blue-700';
        if (value === 'Common') return 'bg-indigo-50 text-indigo-600';
        return 'bg-gray-50 text-gray-500';
      case 'visa':
        if (value === 'Easy') return 'bg-emerald-50 text-emerald-700';
        if (value === 'Moderate') return 'bg-amber-50 text-amber-700';
        return 'bg-red-50 text-red-600';
      default: return 'bg-gray-50 text-gray-600';
    }
  }

  // ─── DOM ───
  const portfolioInput = document.getElementById('portfolio-input');
  const exploreBtn = document.getElementById('explore-btn');
  const resultsSection = document.getElementById('results-section');
  const fallbackSection = document.getElementById('fallback-section');
  const citySections = document.getElementById('city-sections');
  const noCities = document.getElementById('no-cities');
  const summaryEl = document.getElementById('results-summary');
  const showMoreWrap = document.getElementById('show-more-wrap');
  const showMoreBtn = document.getElementById('show-more-btn');
  const showMoreCount = document.getElementById('show-more-count');
  const welcomeBack = document.getElementById('welcome-back');

  // ─── Optional Toggle ───
  const optionalToggle = document.getElementById('optional-toggle');
  const optionalInputs = document.getElementById('optional-inputs');
  const optionalChevron = document.getElementById('optional-chevron');

  function setOptionalOpen(open) {
    if (!optionalInputs || !optionalChevron) return;
    if (open) {
      optionalInputs.classList.remove('hidden');
      optionalChevron.style.transform = 'rotate(180deg)';
    } else {
      optionalInputs.classList.add('hidden');
      optionalChevron.style.transform = '';
    }
    try { localStorage.setItem('pa_optional_open', open ? '1' : '0'); } catch (e) {}
  }

  optionalToggle?.addEventListener('click', () => {
    const isHidden = optionalInputs?.classList.contains('hidden');
    setOptionalOpen(isHidden);
  });

  // ─── Input Formatting ───
  portfolioInput.addEventListener('input', () => {
    const pos = portfolioInput.selectionStart || 0;
    const digitsBefore = portfolioInput.value.slice(0, pos).replace(/[^0-9]/g, '').length;
    portfolioInput.value = formatWithCommas(portfolioInput.value);
    let newPos = 0;
    let counted = 0;
    for (let i = 0; i < portfolioInput.value.length && counted < digitsBefore; i++) {
      if (/[0-9]/.test(portfolioInput.value[i])) counted++;
      newPos = i + 1;
    }
    portfolioInput.setSelectionRange(newPos, newPos);
  });

  // ─── Optional Input Formatting & Validation ───
  const savingsInput = document.getElementById('savings-input');
  const passiveInput = document.getElementById('passive-input');
  const savingsError = document.getElementById('savings-error');
  const passiveError = document.getElementById('passive-error');
  const passiveWarn = document.getElementById('passive-warn');

  function setupOptionalInput(input, errorEl, onChange) {
    if (!input) return;
    input.addEventListener('input', () => {
      // Clear validation on typing
      if (errorEl) errorEl.classList.add('hidden');
      const raw = input.value;
      // Check for negative sign before stripping
      if (raw.includes('-')) {
        if (errorEl) { errorEl.textContent = 'Please enter a positive number'; errorEl.classList.remove('hidden'); }
        input.value = raw.replace(/-/g, '');
        return;
      }
      // Check for non-numeric (letters etc) before stripping
      if (raw.replace(/[,\s$]/g, '').length > 0 && !/[0-9]/.test(raw)) {
        if (errorEl) { errorEl.textContent = 'Please enter a number'; errorEl.classList.remove('hidden'); }
      }
      const pos = input.selectionStart || 0;
      const digitsBefore = input.value.slice(0, pos).replace(/[^0-9]/g, '').length;
      input.value = formatWithCommas(input.value);
      let newPos = 0;
      let counted = 0;
      for (let i = 0; i < input.value.length && counted < digitsBefore; i++) {
        if (/[0-9]/.test(input.value[i])) counted++;
        newPos = i + 1;
      }
      input.setSelectionRange(newPos, newPos);
    });
    input.addEventListener('change', () => {
      const val = parseInt((input.value || '').replace(/[^0-9]/g, ''), 10) || 0;
      onChange(val);
      if (portfolio > 0) renderResults();
    });
  }

  setupOptionalInput(savingsInput, savingsError, (val) => { annualSavings = val; });
  setupOptionalInput(passiveInput, passiveError, (val) => {
    passiveIncome = val;
    // Warn if > $1M
    if (passiveWarn) {
      if (val > 1_000_000) {
        passiveWarn.textContent = "That's a large passive income \u2014 double-check this is an annual figure, not a total portfolio value.";
        passiveWarn.classList.remove('hidden');
      } else {
        passiveWarn.classList.add('hidden');
      }
    }
  });

  // Quick-select buttons
  document.querySelectorAll('.quick-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const value = parseInt(btn.dataset.value, 10);
      portfolioInput.value = value.toLocaleString('en-US');
    });
  });

  // ─── Lifestyle selector (hero) ───
  document.querySelectorAll('.lifestyle-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      lifestyle = btn.dataset.lifestyle;
      document.querySelectorAll('.lifestyle-btn').forEach((b) => {
        const isActive = b === btn;
        b.classList.toggle('bg-white/20', isActive);
        b.classList.toggle('border-white/40', isActive);
        b.classList.toggle('text-white', isActive);
        b.classList.toggle('bg-white/5', !isActive);
        b.classList.toggle('border-white/15', !isActive);
        b.classList.toggle('text-white/70', !isActive);
      });
      // Also sync results lifestyle pills
      syncResultsLifestyle();
      if (portfolio > 0) renderResults();
    });
  });

  // ─── Lifestyle selector (results bar) ───
  function syncResultsLifestyle() {
    document.querySelectorAll('.results-lifestyle-btn').forEach((btn) => {
      const isActive = btn.dataset.lifestyle === lifestyle;
      btn.classList.toggle('bg-brand-600', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('border-brand-600', isActive);
      btn.classList.toggle('bg-white', !isActive);
      btn.classList.toggle('text-gray-600', !isActive);
      btn.classList.toggle('border-sand-200', !isActive);
    });
  }

  document.querySelectorAll('.results-lifestyle-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      lifestyle = btn.dataset.lifestyle;
      syncResultsLifestyle();
      // Also sync hero buttons
      document.querySelectorAll('.lifestyle-btn').forEach((b) => {
        const isActive = b.dataset.lifestyle === lifestyle;
        b.classList.toggle('bg-white/20', isActive);
        b.classList.toggle('border-white/40', isActive);
        b.classList.toggle('text-white', isActive);
        b.classList.toggle('bg-white/5', !isActive);
        b.classList.toggle('border-white/15', !isActive);
        b.classList.toggle('text-white/70', !isActive);
      });
      if (portfolio > 0) renderResults();
    });
  });

  // ─── Filter buttons ───
  document.querySelectorAll('.filter-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const filterName = btn.dataset.filter;
      const filterValue = btn.dataset.value || '';
      filters[filterName] = filterValue;

      // Update active styles
      document.querySelectorAll(`.filter-btn[data-filter="${filterName}"]`).forEach((b) => {
        b.classList.toggle('active', (b.dataset.value || '') === filterValue);
      });
      if (portfolio > 0) renderResults();
    });
  });

  // ─── Explore button ───
  exploreBtn.addEventListener('click', () => {
    const raw = parseInt((portfolioInput.value || '').replace(/[^0-9]/g, ''), 10) || 0;
    if (raw <= 0) {
      portfolioInput.focus();
      return;
    }
    portfolio = raw;
    annualSavings = parseInt((savingsInput?.value || '').replace(/[^0-9]/g, ''), 10) || 0;
    passiveIncome = parseInt((passiveInput?.value || '').replace(/[^0-9]/g, ''), 10) || 0;
    saveState();
    renderResults();
    resultsSection.scrollIntoView({ behavior: 'smooth' });
  });

  // Enter key on input
  portfolioInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      exploreBtn.click();
    }
  });

  // Show more
  showMoreBtn?.addEventListener('click', () => {
    visibleCount += 12;
    renderResults();
  });

  // ─── Passive Income Adjustment ───
  function adjustFireNumber(baseFireNumber, passive) {
    if (!passive || passive <= 0) return baseFireNumber;
    // adjustedAnnualCost = (baseFireNumber * 0.04) - passiveIncome
    // adjustedFireNumber = adjustedAnnualCost / 0.04
    // = baseFireNumber - passiveIncome / 0.04
    // = baseFireNumber - passiveIncome * 25
    return Math.max(0, baseFireNumber - passive / SAFE_WITHDRAWAL_RATE);
  }

  // ─── Years Until Affordable ───
  function yearsUntilAffordable(currentPortfolio, fireNumber, savings) {
    if (savings <= 0 || currentPortfolio >= fireNumber) return null;
    let p = currentPortfolio;
    for (let y = 1; y <= 30; y++) {
      p = (p + savings) * 1.07;
      if (p >= fireNumber) return y;
    }
    return null; // >30 years
  }

  function getYearsHTML(years) {
    if (years === null) return '';
    let colorClass;
    if (years <= 3) colorClass = 'text-amber-600';
    else if (years <= 10) colorClass = 'text-gray-500';
    else colorClass = 'text-gray-400';
    return `<div class="mt-1 group/tip relative inline-block">
      <span class="text-xs font-medium ${colorClass} cursor-help">Affordable in ~${years} ${years === 1 ? 'year' : 'years'}</span>
      <div class="absolute bottom-full left-0 mb-1 hidden group-hover/tip:block z-10 w-56 px-3 py-2 text-[10px] text-white bg-gray-800 rounded-lg shadow-lg">
        Estimate assumes 7% annual growth and your stated savings rate. Actual results will vary.
      </div>
    </div>`;
  }

  // ─── Filter Logic ───
  function passesFilters(city) {
    if (filters.loc === 'us' && city.country !== 'United States') return false;
    if (filters.loc === 'intl' && city.country === 'United States') return false;
    if (filters.climate === 'warm' && !warmClimates.includes(city.tags.climate)) return false;
    if (filters.climate === 'mild' && !mildClimates.includes(city.tags.climate)) return false;
    if (filters.eng === 'yes' && city.tags.english !== 'Widely spoken') return false;
    return true;
  }

  // ─── Portfolio Fit ───
  function getPortfolioFit(portfolioValue, cityFireNumber) {
    if (cityFireNumber <= 0) return 'over_resourced';
    const ratio = portfolioValue / cityFireNumber;
    if (ratio < 1) return 'not_affordable';
    if (ratio <= 2.5) return 'perfect_fit';
    if (ratio <= 5) return 'within_reach';
    return 'over_resourced';
  }

  // ─── Region summary helper ───
  function getRegionSummary(cities) {
    const regionCounts = {};
    cities.forEach((c) => { regionCounts[c.region] = (regionCounts[c.region] || 0) + 1; });
    const sorted = Object.entries(regionCounts).sort((a, b) => b[1] - a[1]);
    const topRegions = sorted.slice(0, 3).map(([r]) => r);
    return topRegions.length > 0 ? topRegions.join(', ') : 'various regions';
  }

  // ─── Build city card HTML ───
  function buildCardHTML(city) {
    const tagPills = [
      { label: city.tags.climate, cat: 'climate' },
      { label: city.tags.safety, cat: 'safety' },
      { label: city.tags.english, cat: 'english' },
    ].filter((t) => t.label).slice(0, 3);

    const tagTooltips = { climate: 'Climate', safety: 'Safety rating', english: 'English proficiency', visa: 'Visa ease' };
    const tagHTML = tagPills.map((t) =>
      `<span title="${tagTooltips[t.cat] || t.cat}: ${t.label}" class="text-[10px] font-medium px-2 py-0.5 rounded-full ${getTagColorClient(t.cat, t.label)}">${t.label}</span>`
    ).join('');

    const years = !city.affordable && annualSavings > 0 ? yearsUntilAffordable(portfolio, city.fireNumber, annualSavings) : null;
    const yearsProjection = getYearsHTML(years);

    let signalHTML;
    if (city.fullyCovered) {
      signalHTML = '<div class="flex items-center gap-1.5 mt-1"><svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span class="text-sm font-semibold text-emerald-600">Fully covered by passive income</span></div>';
    } else if (city.fitTier === 'over_resourced') {
      signalHTML = '<div class="flex items-center gap-1.5 mt-1"><svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span class="text-sm font-medium text-gray-400">Easily affordable</span></div>';
    } else if (city.affordable) {
      signalHTML = '<div class="flex items-center gap-1.5 mt-1"><svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span class="text-sm font-semibold text-emerald-600">You can retire here</span></div>';
    } else {
      signalHTML = `<p class="text-sm text-gray-500 mt-1">Need ${fmtCompact(Math.abs(city.gap))} more</p>${yearsProjection}`;
    }

    // Fit label
    let fitLabelHTML = '';
    if (city.fitTier === 'within_reach') {
      fitLabelHTML = '<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-blue-50 text-blue-600">Well within your means</span>';
    }

    // "Now in range" indicator for premium unlock cities
    let unlockHTML = '';
    if (city.justUnlocked) {
      unlockHTML = '<span class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-violet-50 text-violet-600 border border-violet-200">Now in range</span>';
    }

    const isOverResourced = city.fitTier === 'over_resourced';
    const barColor = isOverResourced ? 'from-gray-300 to-gray-400' : (city.affordable ? 'from-emerald-400 to-emerald-500' : 'from-brand-500 to-brand-600');
    const cardOpacity = isOverResourced ? 'opacity-70' : '';

    return `<a href="/cities/${city.slug}" class="city-card block group ${cardOpacity}">
      <div class="h-2 bg-gradient-to-r ${barColor}"></div>
      <div class="p-5">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-2">
            <span class="text-2xl">${city.emoji}</span>
            <div>
              <h3 class="font-serif font-bold text-lg text-brand-950 group-hover:text-brand-600 transition-colors">${city.name}</h3>
              <p class="text-sm text-gray-500">${city.country}</p>
            </div>
          </div>
          <div class="fire-score w-10 h-10 text-sm ${getScoreClass(city.fireScore)}">${city.fireScore.toFixed(1)}</div>
        </div>
        <div class="mb-3">
          <div class="flex items-baseline justify-between">
            <span class="text-xs text-gray-500">FIRE Number</span>
            <span class="text-lg font-bold text-brand-700">${fmtCompact(city.fireNumber)}</span>
          </div>
          ${signalHTML}
        </div>
        <div class="flex flex-wrap gap-1.5 mb-3">${tagHTML} ${fitLabelHTML} ${unlockHTML}</div>
        <div class="flex items-center justify-between pt-3 border-t border-sand-100">
          <p class="text-xs text-gray-400">From ${fmt(city.monthlyCost)}/mo</p>
          <span class="text-xs font-medium text-brand-600 bg-brand-50 px-3 py-1 rounded-full">${city.region}</span>
        </div>
      </div>
    </a>`;
  }

  // ─── Render Results ───
  function renderResults() {
    fallbackSection?.classList.add('hidden');
    resultsSection?.classList.remove('hidden');
    document.getElementById('reverse-flow')?.classList.add('hidden');

    // Compute cities with fit data
    const allComputed = cityData
      .filter(passesFilters)
      .map((city) => {
        const tierData = city.tiers[lifestyle];
        const baseFireNumber = tierData.fireNumber;
        const fireNumber = adjustFireNumber(baseFireNumber, passiveIncome);
        const monthlyCost = tierData.monthlyCost;
        const fullyCovered = passiveIncome > 0 && fireNumber === 0;
        const affordable = portfolio >= fireNumber;
        const gap = portfolio - fireNumber;
        const fitTier = fullyCovered ? 'over_resourced' : getPortfolioFit(portfolio, fireNumber);
        // "Now in range" — portfolio just crossed unlock threshold AND city is perfect_fit or within_reach
        const justUnlocked = city.unlockThreshold > 0 && portfolio >= city.unlockThreshold && fitTier === 'perfect_fit';
        return { ...city, fireNumber, monthlyCost, affordable, gap, fullyCovered, fitTier, justUnlocked };
      });

    // Bucket into sections
    const sweetSpot = allComputed.filter((c) => c.fitTier === 'perfect_fit');
    const withinReach = allComputed.filter((c) => c.fitTier === 'within_reach');
    const stretchGoals = allComputed.filter((c) => c.fitTier === 'not_affordable');
    const overResourced = allComputed.filter((c) => c.fitTier === 'over_resourced');

    // Sort within each bucket
    // Sweet spot: "just unlocked" premium cities first, then by fire score
    sweetSpot.sort((a, b) => {
      if (a.justUnlocked !== b.justUnlocked) return a.justUnlocked ? -1 : 1;
      return b.fireScore - a.fireScore;
    });
    withinReach.sort((a, b) => b.fireScore - a.fireScore);
    stretchGoals.sort((a, b) => b.gap - a.gap); // closest to affordable first
    overResourced.sort((a, b) => b.fireScore - a.fireScore);

    const totalFiltered = allComputed.length;

    const lifestyleLabelMap = { budget: 'Lean FIRE', comfortable: 'FIRE', luxury: 'Fat FIRE' };
    const lifestyleLabel = lifestyleLabelMap[lifestyle] || lifestyle;

    // Update summary with portfolio-aware framing
    if (summaryEl) {
      if (sweetSpot.length > 0) {
        const regionHint = getRegionSummary(sweetSpot);
        summaryEl.innerHTML = `<strong>${fmtPortfolio(portfolio)}</strong> portfolio: <strong>${sweetSpot.length}</strong> ${sweetSpot.length === 1 ? 'city' : 'cities'} perfectly matched for <strong>${lifestyleLabel}</strong>, including ${regionHint}`;
      } else if (withinReach.length > 0) {
        summaryEl.innerHTML = `Your <strong>${fmtPortfolio(portfolio)}</strong> portfolio easily covers <strong>${withinReach.length}</strong> ${lifestyleLabel} ${withinReach.length === 1 ? 'city' : 'cities'} — consider a higher lifestyle tier`;
      } else if (stretchGoals.length > 0) {
        summaryEl.innerHTML = `Your <strong>${fmtPortfolio(portfolio)}</strong> portfolio isn't quite there yet for <strong>${lifestyleLabel}</strong> — <strong>${stretchGoals.length}</strong> ${stretchGoals.length === 1 ? 'city is' : 'cities are'} within reach as you save more`;
      } else {
        summaryEl.innerHTML = `Your <strong>${fmtPortfolio(portfolio)}</strong> portfolio at <strong>${lifestyleLabel}</strong>`;
      }
    }

    if (totalFiltered === 0) {
      citySections.innerHTML = '';
      noCities?.classList.remove('hidden');
      showMoreWrap?.classList.add('hidden');
      updateURL();
      return;
    }
    noCities?.classList.add('hidden');

    // Allocate visible slots per section
    // Each non-empty section gets at least 4 cards so all section headers are visible on load
    const sectionDefs = [
      { key: 'perfect_fit', items: sweetSpot },
      { key: 'within_reach', items: withinReach },
      { key: 'not_affordable', items: stretchGoals },
    ].filter((s) => s.items.length > 0);

    const MIN_PER_SECTION = 4;
    const sectionLimits = {};

    // Pass 1: give each section min(MIN, available items)
    let used = 0;
    for (const s of sectionDefs) {
      sectionLimits[s.key] = Math.min(MIN_PER_SECTION, s.items.length);
      used += sectionLimits[s.key];
    }

    // Pass 2: distribute remaining budget in priority order
    let remaining = Math.max(0, visibleCount - used);
    for (const s of sectionDefs) {
      if (remaining <= 0) break;
      const canGive = s.items.length - sectionLimits[s.key];
      const give = Math.min(canGive, remaining);
      sectionLimits[s.key] += give;
      remaining -= give;
    }

    const ssVisible = sweetSpot.slice(0, sectionLimits['perfect_fit'] || 0);
    const wrVisible = withinReach.slice(0, sectionLimits['within_reach'] || 0);
    const sgVisible = stretchGoals.slice(0, sectionLimits['not_affordable'] || 0);
    const totalShown = ssVisible.length + wrVisible.length + sgVisible.length;

    // Build sections HTML
    let html = '';

    // Section: Sweet spot
    if (ssVisible.length > 0) {
      html += `<div class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <h2 class="font-serif text-xl font-bold text-brand-950">Your sweet spot</h2>
          <span class="text-xs font-medium text-gray-400">${sweetSpot.length} ${sweetSpot.length === 1 ? 'city' : 'cities'}</span>
        </div>
        <p class="text-sm text-gray-500 mb-4">Cities where your portfolio is the right size — enough to retire comfortably with a healthy buffer.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          ${ssVisible.map(buildCardHTML).join('')}
        </div>
      </div>`;
    }

    // Section: Also within reach
    if (wrVisible.length > 0) {
      html += `<div class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <h2 class="font-serif text-xl font-bold text-brand-950">Also within reach</h2>
          <span class="text-xs font-medium text-gray-400">${withinReach.length} ${withinReach.length === 1 ? 'city' : 'cities'}</span>
        </div>
        <p class="text-sm text-gray-500 mb-4">Affordable, but your portfolio exceeds what you'd need here. Consider a higher lifestyle tier.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          ${wrVisible.map(buildCardHTML).join('')}
        </div>
      </div>`;
    }

    // Section: Stretch goals
    if (sgVisible.length > 0) {
      html += `<div class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <h2 class="font-serif text-xl font-bold text-brand-950">Stretch goals</h2>
          <span class="text-xs font-medium text-gray-400">${stretchGoals.length} ${stretchGoals.length === 1 ? 'city' : 'cities'}</span>
        </div>
        <p class="text-sm text-gray-500 mb-4">Not yet affordable — but within reach as your portfolio grows.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          ${sgVisible.map(buildCardHTML).join('')}
        </div>
      </div>`;
    }

    // Section: Over-resourced (collapsed)
    if (overResourced.length > 0) {
      html += `<div class="mb-8">
        <button id="over-resourced-toggle" type="button" class="flex items-center gap-2 text-sm font-medium text-gray-400 hover:text-gray-600 transition-colors py-3">
          <svg id="over-resourced-chevron" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          Show ${overResourced.length} budget-friendly ${overResourced.length === 1 ? 'option' : 'options'} below your wealth level
        </button>
        <div id="over-resourced-grid" class="hidden mt-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            ${overResourced.map(buildCardHTML).join('')}
          </div>
        </div>
      </div>`;
    }

    citySections.innerHTML = html;

    // Wire up over-resourced toggle
    const orToggle = document.getElementById('over-resourced-toggle');
    const orGrid = document.getElementById('over-resourced-grid');
    const orChevron = document.getElementById('over-resourced-chevron');
    orToggle?.addEventListener('click', () => {
      const isHidden = orGrid?.classList.contains('hidden');
      if (isHidden) {
        orGrid?.classList.remove('hidden');
        if (orChevron) orChevron.style.transform = 'rotate(90deg)';
      } else {
        orGrid?.classList.add('hidden');
        if (orChevron) orChevron.style.transform = '';
      }
    });

    // Show more button
    const totalMain = sweetSpot.length + withinReach.length + stretchGoals.length;
    if (showMoreWrap && showMoreCount) {
      if (totalShown < totalMain) {
        showMoreWrap.classList.remove('hidden');
        showMoreCount.textContent = `Showing ${totalShown} of ${totalMain} cities`;
      } else {
        showMoreWrap.classList.add('hidden');
      }
    }

    updateURL();
  }

  // ─── URL & State Persistence ───
  const tierToUrlKey = { budget: 'leanfire', comfortable: 'fire', luxury: 'fatfire' };
  const urlKeyToTier = { leanfire: 'budget', fire: 'comfortable', fatfire: 'luxury' };

  function saveState() {
    try {
      localStorage.setItem('pa_calc', JSON.stringify({
        nw: portfolio,
        lifestyle: lifestyle,
        save: annualSavings || undefined,
        passiveIncome: passiveIncome || undefined,
      }));
    } catch (e) {}
  }

  function updateURL() {
    const params = new URLSearchParams();
    if (portfolio > 0) params.set('portfolio', String(portfolio));
    if (lifestyle !== 'comfortable') params.set('tier', tierToUrlKey[lifestyle] || lifestyle);
    if (filters.loc) params.set('region', filters.loc);
    if (filters.climate) params.set('climate', filters.climate);
    if (filters.eng) params.set('eng', filters.eng);
    if (annualSavings > 0) params.set('save', String(annualSavings));
    if (passiveIncome > 0) params.set('passive', String(passiveIncome));
    const qs = params.toString();
    history.replaceState(null, '', '/' + (qs ? '?' + qs : ''));
    saveState();
  }

  // ─── Restore from URL / localStorage ───
  function restore() {
    const params = new URLSearchParams(window.location.search);
    // Support new params (portfolio, tier, region) with fallback to old (nw, lifestyle, loc)
    let nw = parseInt(params.get('portfolio') || params.get('nw') || '0', 10);
    let tierParam = params.get('tier') || '';
    let ls = tierParam ? (urlKeyToTier[tierParam] || '') : (params.get('lifestyle') || '');
    let restored = false;
    const hasUrlParams = params.get('portfolio') || params.get('nw');

    // Restore annual savings and passive income from URL
    const saveParam = parseInt(params.get('save') || '0', 10);
    if (saveParam > 0) annualSavings = saveParam;
    const passiveParam = parseInt(params.get('passive') || '0', 10);
    if (passiveParam > 0) passiveIncome = passiveParam;

    // Try localStorage if no URL params
    if (!nw) {
      try {
        const stored = JSON.parse(localStorage.getItem('pa_calc') || '{}');
        if (stored.nw && stored.nw > 0) {
          nw = stored.nw;
          if (!ls && stored.lifestyle) ls = stored.lifestyle;
          if (!annualSavings && stored.save) annualSavings = stored.save;
          if (!passiveIncome && stored.passiveIncome) passiveIncome = stored.passiveIncome;
          restored = true;
        }
      } catch (e) {}
    } else {
      // URL had portfolio — check localStorage for any missing optional fields
      try {
        const stored = JSON.parse(localStorage.getItem('pa_calc') || '{}');
        if (!annualSavings && stored.save) annualSavings = stored.save;
        if (!passiveIncome && stored.passiveIncome) passiveIncome = stored.passiveIncome;
      } catch (e) {}
    }

    // Restore filters from URL
    if (params.get('region') || params.get('loc')) filters.loc = params.get('region') || params.get('loc');
    if (params.get('climate')) filters.climate = params.get('climate');
    if (params.get('eng')) filters.eng = params.get('eng');

    // Sync filter button styles
    for (const [key, val] of Object.entries(filters)) {
      document.querySelectorAll(`.filter-btn[data-filter="${key}"]`).forEach((btn) => {
        btn.classList.toggle('active', (btn.dataset.value || '') === val);
      });
    }

    // Restore lifestyle
    if (ls && ['budget', 'comfortable', 'luxury'].includes(ls)) {
      lifestyle = ls;
      // Sync hero buttons
      document.querySelectorAll('.lifestyle-btn').forEach((btn) => {
        const isActive = btn.dataset.lifestyle === lifestyle;
        btn.classList.toggle('bg-white/20', isActive);
        btn.classList.toggle('border-white/40', isActive);
        btn.classList.toggle('text-white', isActive);
        btn.classList.toggle('bg-white/5', !isActive);
        btn.classList.toggle('border-white/15', !isActive);
        btn.classList.toggle('text-white/70', !isActive);
      });
      syncResultsLifestyle();
    }

    // Restore optional inputs
    if (annualSavings > 0 && savingsInput) {
      savingsInput.value = annualSavings.toLocaleString('en-US');
    }
    if (passiveIncome > 0 && passiveInput) {
      passiveInput.value = passiveIncome.toLocaleString('en-US');
      // Show warning if > $1M
      if (passiveIncome > 1_000_000 && passiveWarn) {
        passiveWarn.textContent = "That's a large passive income \u2014 double-check this is an annual figure, not a total portfolio value.";
        passiveWarn.classList.remove('hidden');
      }
    }

    if (nw > 0) {
      portfolio = nw;
      portfolioInput.value = nw.toLocaleString('en-US');

      if (restored) {
        welcomeBack?.classList.remove('hidden');
      }

      renderResults();
    } else {
      fallbackSection?.classList.remove('hidden');
    }
  }

  // ─── Reverse Flow ───
  function setupReverseFlow() {
    const reverseLink = document.getElementById('reverse-link');
    const reverseFlow = document.getElementById('reverse-flow');
    const reverseClose = document.getElementById('reverse-close');
    const reverseInput = document.getElementById('reverse-city-input');
    const reverseDropdown = document.getElementById('reverse-city-dropdown');
    const reverseResults = document.getElementById('reverse-results');
    const reverseUse = document.getElementById('reverse-use-value');

    let selectedCity = null;
    let selectedTier = null;

    reverseLink?.addEventListener('click', (e) => {
      e.preventDefault();
      reverseFlow?.classList.remove('hidden');
      reverseFlow?.scrollIntoView({ behavior: 'smooth' });
    });

    reverseClose?.addEventListener('click', () => {
      reverseFlow?.classList.add('hidden');
    });

    // City search
    reverseInput?.addEventListener('input', () => {
      const q = reverseInput.value.toLowerCase().trim();
      if (q.length < 2) { reverseDropdown?.classList.add('hidden'); return; }
      const matches = cityData.filter((c) =>
        c.name.toLowerCase().includes(q) || c.country.toLowerCase().includes(q)
      ).slice(0, 8);

      if (!reverseDropdown) return;
      if (matches.length === 0) {
        reverseDropdown.innerHTML = '<div class="text-sm text-gray-400 p-3 text-center">No cities found</div>';
      } else {
        reverseDropdown.innerHTML = matches.map((c) =>
          `<div class="flex items-center gap-2 px-3 py-2 text-sm cursor-pointer hover:bg-sand-100 rounded-lg" data-slug="${c.slug}">
            <span>${c.emoji}</span><span class="font-medium">${c.name}</span><span class="text-gray-400 text-xs">${c.country}</span>
          </div>`
        ).join('');
        reverseDropdown.querySelectorAll('[data-slug]').forEach((item) => {
          item.addEventListener('click', () => {
            selectedCity = cityData.find((c) => c.slug === item.dataset.slug);
            if (selectedCity) {
              reverseInput.value = selectedCity.name + ', ' + selectedCity.country;
              reverseDropdown.classList.add('hidden');
              updateReverse();
            }
          });
        });
      }
      reverseDropdown.classList.remove('hidden');
    });

    reverseInput?.addEventListener('blur', () => {
      setTimeout(() => reverseDropdown?.classList.add('hidden'), 200);
    });

    // Tier selection
    document.querySelectorAll('.reverse-tier-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedTier = btn.dataset.reverseTier;
        document.querySelectorAll('.reverse-tier-btn').forEach((b) => {
          b.classList.toggle('border-brand-500', b === btn);
          b.classList.toggle('bg-brand-50', b === btn);
          b.classList.toggle('border-sand-200', b !== btn);
        });
        updateReverse();
      });
    });

    function updateReverse() {
      if (!selectedCity || !selectedTier) return;
      const data = selectedCity.tiers[selectedTier];
      if (!data) return;

      const fireNumEl = document.getElementById('reverse-fire-number');
      const monthlyEl = document.getElementById('reverse-monthly');
      if (fireNumEl) fireNumEl.textContent = fmtCompact(data.fireNumber);
      if (monthlyEl) monthlyEl.textContent = fmt(data.monthlyCost);
      reverseResults?.classList.remove('hidden');
    }

    reverseUse?.addEventListener('click', () => {
      if (!selectedCity || !selectedTier) return;
      const fn = selectedCity.tiers[selectedTier]?.fireNumber;
      if (!fn) return;
      portfolio = fn;
      portfolioInput.value = fn.toLocaleString('en-US');
      reverseFlow?.classList.add('hidden');
      renderResults();
      resultsSection?.scrollIntoView({ behavior: 'smooth' });
    });
  }

  // ─── Share Button ───
  const shareBtn = document.getElementById('share-btn');
  const toast = document.getElementById('toast');
  shareBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText(window.location.href).then(() => {
      if (toast) {
        toast.classList.remove('hidden');
        setTimeout(() => toast.classList.add('hidden'), 2000);
      }
    });
  });

  // ─── Init ───
  setupReverseFlow();
  restore();
</script>
