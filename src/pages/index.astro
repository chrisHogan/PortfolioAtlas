---
import Layout from '../layouts/Layout.astro';
import NetWorthInput from '../components/NetWorthInput.astro';
import { allCities } from '../data/cities/index';
import { formatCurrency, getTotalSpend, getFireScoreClass, TIER_MONTHLY_BUDGET, SAFE_WITHDRAWAL_RATE } from '../data/types';

// Pre-compute city cost data for client-side use
const cityData = allCities.map((city) => {
  const tiers: Record<string, { totalSpend: number; tierBudget: number }> = {};
  for (const [key, tier] of Object.entries(city.tiers)) {
    tiers[key] = {
      totalSpend: getTotalSpend(tier),
      tierBudget: tier.monthlyBudget,
    };
  }
  return {
    name: city.name,
    country: city.country,
    slug: city.slug,
    emoji: city.emoji,
    region: city.region,
    fireScore: city.fireScore,
    tagline: city.tagline,
    tags: city.tags,
    tiers,
  };
});

const totalCities = allCities.length;

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  'name': 'PortfolioAtlas',
  'url': 'https://portfolioatlas.org',
  'description': `Enter your portfolio value and see exactly what you can afford in ${totalCities}+ cities worldwide. Built on the 4% rule.`,
  'potentialAction': {
    '@type': 'SearchAction',
    'target': 'https://portfolioatlas.org/compare?cities={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  'name': 'PortfolioAtlas',
  'url': 'https://portfolioatlas.org',
  'logo': 'https://portfolioatlas.org/og-default.png',
  'description': `FIRE retirement planning tool comparing cost of living across ${totalCities}+ cities worldwide.`,
};

const calcLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  'name': 'FIRE Retirement Calculator',
  'url': 'https://portfolioatlas.org',
  'applicationCategory': 'FinanceApplication',
  'operatingSystem': 'Web',
  'description': `Enter your portfolio value and see personalized retirement lifestyle breakdowns across ${totalCities}+ cities worldwide.`,
  'offers': {
    '@type': 'Offer',
    'price': '0',
    'priceCurrency': 'USD',
  },
};
---

<Layout
  title="Home"
  description={`Enter your portfolio value and see personalized retirement lifestyle breakdowns across ${totalCities}+ cities worldwide. Built on the 4% safe withdrawal rate.`}
  jsonLd={[websiteLd, orgLd, calcLd]}
>
  <!-- Hero -->
  <section class="bg-brand-950 text-white py-12">
    <div class="container-narrow text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">
        Your Personalized Results
      </h1>
      <p class="text-xl text-sand-300 max-w-2xl mx-auto mb-8">
        See what your portfolio buys you in 100+ cities worldwide.
      </p>

      <NetWorthInput />
    </div>
  </section>

  <!-- Customize Assumptions (collapsible) -->
  <section id="advanced-section" class="container-narrow py-4">
    <button id="advanced-toggle" type="button" class="w-full flex items-center justify-between bg-white rounded-xl border border-sand-200 px-5 py-3 hover:bg-sand-50 transition-colors">
      <div class="flex items-center gap-2">
        <span class="text-sm font-semibold text-gray-700">Customize Assumptions</span>
        <span id="advanced-summary" class="text-xs text-gray-400">7% return · 12% volatility · 30yr retirement · 3% inflation</span>
      </div>
      <svg id="advanced-chevron" class="w-5 h-5 text-gray-400 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
    </button>
    <div id="advanced-panel" class="hidden bg-white rounded-b-2xl border border-t-0 border-sand-200 p-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Annual Contributions -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">Annual Contributions</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-bold">$</span>
            <input type="text" id="fire-contrib" inputmode="numeric" value="0" autocomplete="off" class="fire-currency-input" />
          </div>
        </div>

        <!-- Expected Annual Return -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Expected Annual Return: <span id="fire-return-val" class="text-brand-600">7%</span>
          </label>
          <input type="range" id="fire-return" min="1" max="15" value="7" step="0.5" class="fire-slider" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>1%</span><span>15%</span></div>
        </div>

        <!-- Years to Retirement -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Years to Retirement: <span id="fire-yrs-val" class="text-brand-600">0</span>
          </label>
          <input type="range" id="fire-yrs" min="0" max="40" value="0" step="1" class="fire-slider" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>0 (now)</span><span>40</span></div>
        </div>

        <!-- Market Volatility -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Market Volatility: <span id="fire-vol-val" class="text-brand-600">12%</span>
          </label>
          <input type="range" id="fire-vol" min="5" max="25" value="12" step="1" class="fire-slider" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>5% Smooth</span><span>25% Wild</span></div>
          <p class="text-xs text-gray-400 mt-1">How bumpy the ride is. Lower = steady bonds-like returns. Higher = stock-market swings. 12% matches a typical stock/bond mix.</p>
        </div>

        <!-- Inflation Rate -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Inflation Rate: <span id="fire-inflation-val" class="text-brand-600">3%</span>
          </label>
          <input type="range" id="fire-inflation" min="0" max="8" value="3" step="0.5" class="fire-slider" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>0%</span><span>8%</span></div>
          <p class="text-xs text-gray-400 mt-1">How fast prices rise each year. 3% is the historical U.S. average.</p>
        </div>

        <!-- Retirement Duration -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Retirement Duration: <span id="fire-duration-val" class="text-brand-600">30 years</span>
          </label>
          <input type="range" id="fire-duration" min="10" max="50" value="30" step="1" class="fire-slider" />
          <div class="flex justify-between text-xs text-gray-400 mt-1"><span>10</span><span>50</span></div>
        </div>
      </div>

      <p class="text-xs text-gray-400 mt-4 text-center">
        Results use a <a href="/about#monte-carlo" class="text-brand-600 hover:underline">Monte Carlo simulation</a>
        with 2,000 randomized market scenarios to estimate your Success Rate.
      </p>
    </div>
  </section>

  <!-- Fallback: shown when no ?nw= param -->
  <section id="calc-fallback" class="container-narrow py-16 text-center hidden">
    <div class="max-w-xl mx-auto">
      <div class="w-16 h-16 bg-brand-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
        <span class="text-3xl">💰</span>
      </div>
      <h2 class="font-serif text-2xl font-bold text-brand-950 mb-3">
        Enter Your Portfolio Value
      </h2>
      <p class="text-gray-600 mb-6">
        Use the input above to enter your net worth and see personalized results across all {totalCities} cities.
      </p>
      <p class="text-sm text-gray-500">
        Use the quick-pick buttons ($1M–$10M) or type your exact amount.
      </p>
    </div>
  </section>

  <!-- Summary Cards (shown when results exist, before filters) -->
  <section id="summary-cards" class="container-narrow py-8 hidden">
    <div id="summary-grid" class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div id="projected-card" class="bg-white rounded-2xl border border-sand-200 p-5 text-center hidden">
        <div class="text-sm text-gray-500 mb-1">Projected Portfolio</div>
        <div id="fire-projected" class="text-2xl font-bold text-brand-950"></div>
        <div class="text-xs text-gray-400 mt-1">median at retirement</div>
      </div>
      <div class="bg-white rounded-2xl border border-sand-200 p-5 text-center">
        <div class="text-sm text-gray-500 mb-1">Monthly Budget</div>
        <div id="summary-budget" class="text-2xl font-bold text-brand-600"></div>
        <div id="summary-budget-subtitle" class="text-xs text-gray-400 mt-1">4% safe withdrawal rate</div>
      </div>
      <div class="bg-white rounded-2xl border border-sand-200 p-5 text-center">
        <div class="text-sm text-gray-500 mb-1">Cities You Can FIRE In</div>
        <div class="text-[10px] text-gray-400 -mt-0.5 mb-0.5">at any lifestyle level</div>
        <div id="summary-surplus-count" class="text-2xl font-bold text-emerald-600"></div>
        <div id="summary-surplus-subtitle" class="text-xs text-gray-400 mt-1"></div>
      </div>
      <div class="bg-white rounded-2xl border border-sand-200 p-5 text-center">
        <div class="text-sm text-gray-500 mb-1">Top Ranked</div>
        <div id="summary-best" class="text-2xl font-bold text-brand-950"></div>
        <div id="summary-best-surplus" class="text-xs text-emerald-600 mt-1"></div>
      </div>
    </div>

    <!-- Lifestyle Reach Breakdown -->
    <div id="lifestyle-reach" class="mt-4 bg-white rounded-2xl border border-sand-200 p-5 hidden">
      <div id="lifestyle-reach-header" class="text-sm font-semibold text-gray-700 mb-1"></div>
      <p id="lifestyle-reach-desc" class="text-xs text-gray-400 mb-3"></p>
      <div class="space-y-2" id="lifestyle-reach-bars"></div>
      <div id="lifestyle-reach-cta" class="mt-4 text-center"></div>
    </div>
  </section>

  <!-- Filter Bar (narrows the surplus cities) -->
  <section id="filter-bar" class="container-narrow py-4 hidden">
    <div class="bg-white rounded-2xl border border-sand-200 p-4 space-y-3">
      <div class="flex flex-wrap items-stretch gap-3">
        <!-- Location Filter -->
        <div class="bg-sand-50 rounded-xl px-4 py-3 flex items-center gap-3 overflow-x-auto">
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wide shrink-0">Location</span>
          <div class="w-px h-5 bg-sand-200 shrink-0"></div>
          <div class="flex gap-1 shrink-0">
            <button data-filter="loc" data-value="" class="filter-btn px-3 py-2 text-sm font-medium rounded-full whitespace-nowrap">All</button>
            <button data-filter="loc" data-value="us" class="filter-btn px-3 py-2 text-sm font-medium rounded-full whitespace-nowrap">US Only</button>
            <button data-filter="loc" data-value="intl" class="filter-btn px-3 py-2 text-sm font-medium rounded-full whitespace-nowrap">International</button>
          </div>
        </div>

        <!-- Climate Filter -->
        <div class="bg-sand-50 rounded-xl px-4 py-3 flex items-center gap-3 overflow-x-auto">
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wide shrink-0">Climate</span>
          <div class="w-px h-5 bg-sand-200 shrink-0"></div>
          <div class="flex gap-1 shrink-0">
            <button data-filter="climate" data-value="" class="filter-btn px-3 py-2 text-sm font-medium rounded-full whitespace-nowrap">Any</button>
            <button data-filter="climate" data-value="warm" class="filter-btn px-3 py-2 text-sm font-medium rounded-full whitespace-nowrap">Warm & Sunny</button>
            <button data-filter="climate" data-value="mild" class="filter-btn px-3 py-2 text-sm font-medium rounded-full whitespace-nowrap">Mild & Temperate</button>
            <button data-filter="climate" data-value="four" class="filter-btn px-3 py-2 text-sm font-medium rounded-full whitespace-nowrap">Four Seasons</button>
          </div>
        </div>

        <!-- English Filter -->
        <div class="bg-sand-50 rounded-xl px-4 py-3 flex items-center gap-3 overflow-x-auto">
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wide shrink-0">English</span>
          <div class="w-px h-5 bg-sand-200 shrink-0"></div>
          <div class="flex gap-1 shrink-0">
            <button data-filter="eng" data-value="" class="filter-btn px-3 py-2 text-sm font-medium rounded-full whitespace-nowrap">Any</button>
            <button data-filter="eng" data-value="yes" class="filter-btn px-3 py-2 text-sm font-medium rounded-full whitespace-nowrap">English Essential</button>
          </div>
        </div>

        <!-- Lifestyle Filter (minimum threshold) -->
        <div class="bg-sand-50 rounded-xl px-4 py-3 overflow-x-auto">
          <div class="flex items-center gap-3">
            <span class="text-xs font-bold text-gray-500 uppercase tracking-wide shrink-0">Min. Lifestyle</span>
            <div class="w-px h-5 bg-sand-200 shrink-0"></div>
            <div class="flex gap-0 shrink-0" id="lifestyle-filter-pills">
              <button data-min-lifestyle="budget" data-level="1" class="lifestyle-pill px-2 sm:px-3 py-2 text-xs sm:text-sm font-medium rounded-l-full border border-r-0 border-sand-200 cursor-pointer select-none transition-all whitespace-nowrap">Budget</button>
              <button data-min-lifestyle="comfortable" data-level="2" class="lifestyle-pill px-2 sm:px-3 py-2 text-xs sm:text-sm font-medium border border-r-0 border-sand-200 cursor-pointer select-none transition-all whitespace-nowrap">Comfortable</button>
              <button data-min-lifestyle="premium" data-level="3" class="lifestyle-pill px-2 sm:px-3 py-2 text-xs sm:text-sm font-medium border border-r-0 border-sand-200 cursor-pointer select-none transition-all whitespace-nowrap">Premium</button>
              <button data-min-lifestyle="luxury" data-level="4" class="lifestyle-pill px-2 sm:px-3 py-2 text-xs sm:text-sm font-medium rounded-r-full border border-sand-200 cursor-pointer select-none transition-all whitespace-nowrap">Luxury</button>
            </div>
          </div>
          <p id="lifestyle-filter-desc" class="text-xs text-gray-400 mt-2">Essentials covered — modest apartment, local food, public transit, and basic healthcare.</p>
        </div>
      </div>

      <!-- Min. Success Rate — FIRE mode only -->
      <div id="success-rate-filter" class="bg-sand-50 rounded-xl px-4 py-3">
        <div class="flex items-center gap-3">
          <span class="text-xs font-bold text-gray-500 uppercase tracking-wide shrink-0">Min. Success Rate</span>
          <div class="w-px h-5 bg-sand-200 shrink-0"></div>
          <input type="range" id="success-rate-slider" min="50" max="100" value="90" step="1" class="fire-slider flex-1" />
          <span id="success-rate-value" class="text-sm font-bold text-brand-700 w-10 text-right">90%</span>
        </div>
        <p id="success-rate-desc" class="text-xs text-gray-400 mt-2">90% is recommended — the percentage of <a href="/about#monte-carlo" class="text-brand-600 hover:underline">Monte Carlo</a> simulated scenarios where your portfolio lasts through retirement.</p>
      </div>
    </div>
  </section>

  <!-- City Table (filtered results) -->
  <div id="calc-results" class="hidden">
    <!-- No cities message -->
    <div id="fire-no-cities" class="container-wide pt-8 hidden">
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
        <p class="text-amber-800 font-semibold mb-1">No affordable cities for this lifestyle level</p>
        <p class="text-amber-600 text-sm">Try lowering your success rate threshold, adjusting the lifestyle level, increasing contributions, or extending your timeline.</p>
      </div>
    </div>

    <!-- City Rankings -->
    <section class="container-wide py-8">
      <div class="flex items-baseline gap-3 mb-6">
        <h2 class="font-serif text-2xl font-bold text-brand-950">
          Cities Ranked by Best Match
        </h2>
        <span id="filtered-count" class="text-sm text-gray-400"></span>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead id="city-rankings-head">
            <tr class="border-b-2 border-sand-200">
              <th class="text-left py-3 px-4 font-semibold text-gray-600 hidden sm:table-cell">#</th>
              <th class="text-left py-3 px-4 font-semibold text-gray-600 sticky left-0 bg-white z-10">City</th>
              <th class="text-right py-3 px-4 font-semibold text-gray-600">FIRE Score</th>
              <th class="text-right py-3 px-4 font-semibold text-gray-600">Lifestyle</th>
              <th class="text-right py-3 px-4 font-semibold text-gray-600">Total Spend</th>
              <th class="text-right py-3 px-4 font-semibold text-gray-600">Surplus</th>
            </tr>
          </thead>
          <tbody id="city-rankings"></tbody>
        </table>
      </div>

      <!-- Show More -->
      <div id="show-more-container" class="text-center py-6 hidden">
        <button id="show-more-btn" class="px-6 py-2.5 bg-white border border-sand-200 rounded-full text-sm font-medium text-gray-700 hover:bg-sand-50 transition-all">
          Show 10 more
        </button>
        <p id="show-more-count" class="text-xs text-gray-400 mt-2"></p>
      </div>
    </section>
  </div>

  <!-- Bottom CTA -->
  <section class="container-narrow py-16 text-center">
    <p class="text-sm text-gray-500">
      Want to see detailed breakdowns? <a href="/compare" class="text-brand-600 hover:underline font-medium">Compare cities side by side</a>.
    </p>
  </section>
</Layout>

<script define:vars={{ cityData, totalCities, SAFE_WITHDRAWAL_RATE }}>
  function initCalculator() {
    const params = new URLSearchParams(window.location.search);

    // ─── Shared Utilities ───
    function fmtCurrency(n) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }

    function getScoreClass(score) {
      if (score >= 7.5) return 'fire-score-high';
      if (score >= 5.5) return 'fire-score-mid';
      return 'fire-score-low';
    }

    function formatWithCommas(val) {
      const num = val.replace(/[^0-9]/g, '');
      return num.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    function parseRawCurrency(el) {
      return parseInt((el.value || '').replace(/[^0-9]/g, ''), 10) || 0;
    }

    // Climate filter mapping
    const warmClimates = ['tropical', 'subtropical', 'desert', 'arid'];
    const mildClimates = ['mediterranean'];
    const fourSeasonClimates = ['continental'];

    // ─── Filter Logic ───
    let _stored = null;
    try { const r = localStorage.getItem('pa_calc'); if (r) _stored = JSON.parse(r); } catch (e) {}
    const activeFilters = {
      loc: params.get('loc') || (_stored && _stored.loc) || '',
      climate: params.get('climate') || (_stored && _stored.climate) || '',
      eng: params.get('eng') || (_stored && _stored.eng) || '',
      lifestyle: params.get('lifestyle') || (_stored && _stored.lifestyle) || 'budget',
      minSuccessRate: parseInt(params.get('sr') || (_stored && _stored.sr) || '90', 10),
    };

    function getActiveFilters() {
      return activeFilters;
    }

    // ─── DOM References ───
    const fallback = document.getElementById('calc-fallback');
    const results = document.getElementById('calc-results');
    const summaryCards = document.getElementById('summary-cards');
    const filterBar = document.getElementById('filter-bar');

    // ─── Simulation State ───
    let cachedSim = null;
    let cachedSimKey = null;
    let currentSavings = 0;

    // ─── Persist to localStorage ───
    function saveToLocalStorage() {
      if (currentSavings <= 0) return;
      const state = { nw: currentSavings };
      const contrib = parseRawCurrency(document.getElementById('fire-contrib'));
      const annualReturn = parseFloat(document.getElementById('fire-return')?.value || '7');
      const volatility = parseFloat(document.getElementById('fire-vol')?.value || '12');
      const yrsToRetire = parseInt(document.getElementById('fire-yrs')?.value || '0', 10);
      const retireDuration = parseInt(document.getElementById('fire-duration')?.value || '30', 10);
      const inflationRate = parseFloat(document.getElementById('fire-inflation')?.value || '3');
      if (contrib > 0) state.contrib = contrib;
      if (annualReturn !== 7) state['return'] = annualReturn;
      if (volatility !== 12) state.vol = volatility;
      if (yrsToRetire !== 0) state.yrs = yrsToRetire;
      if (retireDuration !== 30) state.duration = retireDuration;
      if (inflationRate !== 3) state.inflation = inflationRate;
      if (activeFilters.loc) state.loc = activeFilters.loc;
      if (activeFilters.climate) state.climate = activeFilters.climate;
      if (activeFilters.eng) state.eng = activeFilters.eng;
      if (activeFilters.lifestyle && activeFilters.lifestyle !== 'budget') state.lifestyle = activeFilters.lifestyle;
      if (activeFilters.minSuccessRate !== 90) state.sr = activeFilters.minSuccessRate;
      try { localStorage.setItem('pa_calc', JSON.stringify(state)); } catch (e) {}
    }

    // ─── URL Handling ───
    function updateURL() {
      const newParams = new URLSearchParams();
      if (currentSavings > 0) newParams.set('nw', String(currentSavings));

      // Advanced params — only include non-defaults
      const contrib = parseRawCurrency(document.getElementById('fire-contrib'));
      const annualReturn = parseFloat(document.getElementById('fire-return')?.value || '7');
      const volatility = parseFloat(document.getElementById('fire-vol')?.value || '12');
      const yrsToRetire = parseInt(document.getElementById('fire-yrs')?.value || '0', 10);
      const retireDuration = parseInt(document.getElementById('fire-duration')?.value || '30', 10);
      const inflationRate = parseFloat(document.getElementById('fire-inflation')?.value || '3');

      if (contrib > 0) newParams.set('contrib', String(contrib));
      if (annualReturn !== 7) newParams.set('return', String(annualReturn));
      if (volatility !== 12) newParams.set('vol', String(volatility));
      if (yrsToRetire !== 0) newParams.set('yrs', String(yrsToRetire));
      if (retireDuration !== 30) newParams.set('duration', String(retireDuration));
      if (inflationRate !== 3) newParams.set('inflation', String(inflationRate));

      // Filters
      if (activeFilters.loc) newParams.set('loc', activeFilters.loc);
      if (activeFilters.climate) newParams.set('climate', activeFilters.climate);
      if (activeFilters.eng) newParams.set('eng', activeFilters.eng);
      if (activeFilters.lifestyle && activeFilters.lifestyle !== 'budget') newParams.set('lifestyle', activeFilters.lifestyle);
      if (activeFilters.minSuccessRate !== 90) newParams.set('sr', String(activeFilters.minSuccessRate));
      const qs = newParams.toString();
      history.replaceState(null, '', '/' + (qs ? '?' + qs : ''));
      saveToLocalStorage();
    }

    function passesFilters(city, filters) {
      if (filters.loc === 'us' && city.country !== 'United States') return false;
      if (filters.loc === 'intl' && city.country === 'United States') return false;
      if (filters.climate === 'warm' && !warmClimates.includes(city.tags.climate)) return false;
      if (filters.climate === 'mild' && !mildClimates.includes(city.tags.climate)) return false;
      if (filters.climate === 'four' && !fourSeasonClimates.includes(city.tags.climate)) return false;
      if (filters.eng === 'yes' && city.tags.english !== 'high') return false;
      return true;
    }

    function getPrefAlignment(city, filters) {
      let activeCount = 0;
      let matched = 0;
      if (filters.loc) {
        activeCount++;
        if (filters.loc === 'us' && city.country === 'United States') matched++;
        if (filters.loc === 'intl' && city.country !== 'United States') matched++;
      }
      if (filters.climate) {
        activeCount++;
        if (filters.climate === 'warm' && warmClimates.includes(city.tags.climate)) matched++;
        if (filters.climate === 'mild' && mildClimates.includes(city.tags.climate)) matched++;
        if (filters.climate === 'four' && fourSeasonClimates.includes(city.tags.climate)) matched++;
      }
      if (filters.eng) {
        activeCount++;
        if (filters.eng === 'yes' && city.tags.english === 'high') matched++;
      }
      return activeCount === 0 ? 1.0 : matched / activeCount;
    }

    // ─── Lifestyle tiers ordered from highest to lowest ───
    const lifestyleTiers = [
      { key: '10M', label: 'Luxury', level: 4 },
      { key: '5M', label: 'Premium', level: 3 },
      { key: '3M', label: 'Comfortable', level: 2 },
      { key: '1M', label: 'Budget', level: 1 },
    ];

    const minLifestyleLevels = { budget: 1, comfortable: 2, premium: 3, luxury: 4 };

    function getBestAffordableTier(city, monthlyBudget) {
      for (const tier of lifestyleTiers) {
        const tierData = city.tiers[tier.key];
        if (tierData && monthlyBudget >= tierData.totalSpend) {
          return tier;
        }
      }
      return null;
    }

    function getBestConfidentTier(city, monthlyBudget, minConfidence, confidenceCache) {
      for (const tier of lifestyleTiers) {
        const tierData = city.tiers[tier.key];
        if (tierData && monthlyBudget >= tierData.totalSpend) {
          const cacheKey = city.slug + '|' + tier.key;
          const conf = confidenceCache[cacheKey];
          if (conf !== undefined && conf >= minConfidence) {
            return tier;
          }
        }
      }
      return null;
    }

    // ─── Lifestyle reach breakdown ───
    function renderLifestyleReach(monthlyBudget) {
      const container = document.getElementById('lifestyle-reach');
      const barsEl = document.getElementById('lifestyle-reach-bars');
      const headerEl = document.getElementById('lifestyle-reach-header');
      const descEl = document.getElementById('lifestyle-reach-desc');
      const ctaEl = document.getElementById('lifestyle-reach-cta');
      if (!container || !barsEl) return;

      const levels = [
        { key: '1M', label: 'Budget', color: 'bg-gray-400', desc: 'Essentials \u2014 modest apartment, local food, public transit, basic healthcare.' },
        { key: '3M', label: 'Comfortable', color: 'bg-brand-400', desc: 'Nice apartment, regular dining out, good healthcare, weekend activities.' },
        { key: '5M', label: 'Premium', color: 'bg-brand-600', desc: 'Spacious home, fine dining, premium healthcare, a car, frequent travel.' },
        { key: '10M', label: 'Luxury', color: 'bg-brand-800', desc: 'Luxury housing, private healthcare, domestic help, first-class travel.' },
      ];

      const total = cityData.length;
      const counts = levels.map((level) => {
        const count = cityData.filter((city) => {
          const tierData = city.tiers[level.key];
          return tierData && monthlyBudget >= tierData.totalSpend;
        }).length;
        return { ...level, count, pct: total > 0 ? Math.round((count / total) * 100) : 0 };
      });

      const budgetCount = counts[0].count;

      if (headerEl) {
        headerEl.textContent = budgetCount === 0 ? 'You\u2019re not quite there yet' : 'Your Retirement Reach';
      }

      if (descEl) {
        if (budgetCount === 0) {
          descEl.textContent = 'Your current portfolio doesn\u2019t cover the cost of living in any of the cities we track. Keep saving and investing \u2014 you\u2019re building toward FIRE.';
        } else if (budgetCount < 10) {
          descEl.textContent = 'Your budget goes further in some places than others. You qualify in a handful of cities today \u2014 increasing your savings or extending your timeline will unlock more.';
        } else {
          descEl.textContent = 'Your budget goes further in some places than others. Here\u2019s the lifestyle you can realistically sustain across the cities we track.';
        }
      }

      barsEl.innerHTML = counts.map((l) =>
        `<div class="mb-3">
          <div class="flex items-center gap-3">
            <span class="text-xs font-medium text-gray-600 w-24 shrink-0">${l.label}</span>
            <div class="flex-1 h-5 bg-sand-100 rounded-full overflow-hidden">
              <div class="${l.color} h-full rounded-full transition-all duration-500" style="width: ${l.pct}%"></div>
            </div>
            <span class="text-xs font-bold text-gray-700 w-16 text-right">${l.pct}% <span class="font-normal text-gray-400">(${l.count})</span></span>
          </div>
          <p class="text-xs text-gray-400 ml-[108px] mt-1">${l.desc}</p>
        </div>`
      ).join('');

      if (ctaEl) {
        if (budgetCount === 0) {
          ctaEl.innerHTML = '<p class="text-sm text-gray-500">Try increasing your savings, adding annual contributions, or extending your timeline using <strong>Customize Assumptions</strong> above to see what\u2019s possible.</p>';
        } else {
          ctaEl.innerHTML = '<p class="text-base font-semibold text-brand-700">Explore your retirement options below \u2193</p>';
        }
      }

      container.classList.remove('hidden');
    }

    // ─── Rank cities with composite scoring ───
    function rankCities(monthlyBudget, minLifestyle, filters) {
      const minLevel = minLifestyleLevels[minLifestyle] || 1;

      const allCitiesRanked = cityData.map((city) => {
        const best = getBestAffordableTier(city, monthlyBudget);
        if (!best || best.level < minLevel) return null;
        const tierData = city.tiers[best.key];
        const surplus = monthlyBudget - tierData.totalSpend;
        const surplusRatio = monthlyBudget > 0 ? surplus / monthlyBudget : 0;
        return { ...city, totalSpend: tierData.totalSpend, surplus, surplusRatio, usedTier: best.key, lifestyleLabel: best.label, lifestyleLevel: best.level };
      }).filter(Boolean);

      let filtered = allCitiesRanked.filter((c) => passesFilters(c, filters));

      if (filtered.length === 0) return [];

      return filtered.map((city) => {
        const normalizedFire = city.fireScore / 10;
        const prefAlignment = getPrefAlignment(city, filters);
        const compositeScore = 0.60 * normalizedFire + 0.40 * prefAlignment;
        return { ...city, compositeScore };
      }).sort((a, b) => b.compositeScore - a.compositeScore);
    }

    // ─── Show More button (attached once) ───
    let visibleCount = 10;
    let currentRenderFn = null;
    const showMoreBtnGlobal = document.getElementById('show-more-btn');
    if (showMoreBtnGlobal) {
      showMoreBtnGlobal.addEventListener('click', () => {
        visibleCount += 10;
        if (currentRenderFn) currentRenderFn();
      });
    }

    // ─── Render city table rows ───
    function renderRows(ranked, tbody, netWorthForLinks, showConfidence) {
      if (!tbody) return;
      tbody.innerHTML = '';

      const filteredCountEl = document.getElementById('filtered-count');
      if (filteredCountEl) filteredCountEl.textContent = ranked.length + (ranked.length === 1 ? ' city' : ' cities');

      let sortKey = 'fireScore';
      let sortAsc = false;
      const sortArrow = (key) => `<span class="inline-block w-3 text-center${sortKey === key ? '' : ' invisible'}">${sortKey === key ? (sortAsc ? '▲' : '▼') : '▲'}</span>`;
      const thClass = 'py-3 px-4 font-semibold text-gray-600 cursor-pointer hover:text-brand-600 select-none transition-colors';
      const headerTips = {
        city: 'City and country',
        confidence: 'Monte Carlo simulation: % of scenarios where your portfolio lasts through retirement at this city\u2019s cost of living',
        fireScore: 'Quality-of-life score (1\u201310) based on safety, healthcare, infrastructure, and expat friendliness — cost of living is handled separately by the affordability filter',
        lifestyle: 'The best lifestyle you can afford here: Budget (essentials), Comfortable (solid middle-class), Premium (upscale), or Luxury (top-tier)',
        totalSpend: 'Estimated monthly cost of living at your lifestyle level in this city',
        surplus: 'How much of your monthly budget remains after covering this city\u2019s cost of living',
      };

      function sortRanked() {
        if (sortKey === 'rank') {
          ranked.sort((a, b) => b.compositeScore - a.compositeScore);
        } else {
          ranked.sort((a, b) => {
            let va, vb;
            switch (sortKey) {
              case 'city': va = a.name.toLowerCase(); vb = b.name.toLowerCase(); break;
              case 'confidence': va = a.confidence || 0; vb = b.confidence || 0; break;
              case 'fireScore': va = a.fireScore; vb = b.fireScore; break;
              case 'lifestyle': va = a.lifestyleLevel || 0; vb = b.lifestyleLevel || 0; break;
              case 'totalSpend': va = a.totalSpend; vb = b.totalSpend; break;
              case 'surplus': va = a.surplus; vb = b.surplus; break;
              default: return 0;
            }
            if (va < vb) return sortAsc ? -1 : 1;
            if (va > vb) return sortAsc ? 1 : -1;
            return 0;
          });
        }
      }

      function handleSort(key) {
        if (sortKey === key) {
          sortAsc = !sortAsc;
        } else {
          sortKey = key;
          sortAsc = key === 'city' ? true : false;
        }
        sortRanked();
        buildHeader();
        render();
      }

      const thead = document.getElementById('city-rankings-head');
      function buildHeader() {
        if (!thead) return;
        const tip = (key) => headerTips[key] ? ` title="${headerTips[key]}"` : '';
        const confHeader = showConfidence
          ? `<th class="text-right ${thClass}" data-sort="confidence"${tip('confidence')}>Success Rate${sortArrow('confidence')}</th>`
          : '';
        thead.innerHTML = `
          <tr class="border-b-2 border-sand-200">
            <th class="text-left py-3 px-4 font-semibold text-gray-600 hidden sm:table-cell">#</th>
            <th class="text-left sticky left-0 bg-white z-10 ${thClass}" data-sort="city"${tip('city')}>City${sortArrow('city')}</th>
            ${confHeader}
            <th class="text-right ${thClass}" data-sort="fireScore"${tip('fireScore')}>FIRE Score${sortArrow('fireScore')}</th>
            <th class="text-right ${thClass}" data-sort="lifestyle"${tip('lifestyle')}>Lifestyle${sortArrow('lifestyle')}</th>
            <th class="text-right ${thClass}" data-sort="totalSpend"${tip('totalSpend')}>Total Spend${sortArrow('totalSpend')}</th>
            <th class="text-right ${thClass}" data-sort="surplus"${tip('surplus')}>Surplus${sortArrow('surplus')}</th>
          </tr>
        `;
        thead.querySelectorAll('[data-sort]').forEach((th) => {
          th.addEventListener('click', () => handleSort(th.getAttribute('data-sort')));
        });
      }
      buildHeader();

      const showMoreContainer = document.getElementById('show-more-container');
      const showMoreCount = document.getElementById('show-more-count');

      const filterParamStr = ['loc', 'climate', 'eng']
        .filter((k) => activeFilters[k])
        .map((k) => k + '=' + activeFilters[k])
        .join('&');

      function getConfidenceColor(conf) {
        if (conf >= 90) return 'text-emerald-600';
        if (conf >= 80) return 'text-amber-600';
        if (conf >= 70) return 'text-orange-600';
        return 'text-red-600';
      }

      function getConfidenceBg(conf) {
        if (conf >= 90) return 'background-color: #10b981';
        if (conf >= 80) return 'background-color: #f59e0b';
        if (conf >= 70) return 'background-color: #f97316';
        return 'background-color: #ef4444';
      }

      function render() {
        tbody.innerHTML = '';
        const toShow = ranked.slice(0, visibleCount);
        toShow.forEach((city, index) => {
          const tr = document.createElement('tr');
          tr.className = 'border-b border-sand-100 hover:bg-sand-50 transition-colors';
          const surplusClass = city.surplus >= 0 ? 'text-emerald-600' : 'text-red-600';
          const surplusPrefix = city.surplus >= 0 ? '+' : '';
          const scoreClass = getScoreClass(city.fireScore);
          const linkParams = 'nw=' + netWorthForLinks + (filterParamStr ? '&' + filterParamStr : '');

          const confCell = showConfidence
            ? `<td class="text-right py-3 px-4">
                <div class="inline-flex items-center gap-1.5">
                  <div class="w-12 h-2 rounded-full bg-sand-200 overflow-hidden">
                    <div class="h-full rounded-full" style="width: ${city.confidence}%; ${getConfidenceBg(city.confidence)}"></div>
                  </div>
                  <span class="font-bold text-xs ${getConfidenceColor(city.confidence)}">${city.confidence}%</span>
                </div>
              </td>`
            : '';

          tr.innerHTML = `
            <td class="py-3 px-4 text-gray-400 font-medium hidden sm:table-cell">${index + 1}</td>
            <td class="py-3 px-4 sticky left-0 bg-white z-10" title="${city.tagline}">
              <a href="/cities/${city.slug}?${linkParams}" class="flex items-center gap-2 hover:text-brand-600 transition-colors">
                <span>${city.emoji}</span>
                <span class="font-medium">${city.name}</span>
                <span class="text-gray-400 text-xs">${city.country}</span>
              </a>
            </td>
            ${confCell}
            <td class="text-right py-3 px-4" title="${city.tagline}">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-white text-xs font-bold ${scoreClass}">
                ${city.fireScore.toFixed(1)}
              </span>
            </td>
            <td class="text-right py-3 px-4 text-gray-500">${city.lifestyleLabel}</td>
            <td class="text-right py-3 px-4 font-bold">${fmtCurrency(city.totalSpend)}</td>
            <td class="text-right py-3 px-4 font-bold ${surplusClass}">
              ${surplusPrefix}${fmtCurrency(city.surplus)}
            </td>
          `;
          tbody.appendChild(tr);
        });

        if (showMoreContainer && showMoreCount) {
          if (visibleCount < ranked.length) {
            showMoreContainer.classList.remove('hidden');
            showMoreCount.textContent = 'Showing ' + visibleCount + ' of ' + ranked.length + ' cities';
          } else {
            showMoreContainer.classList.add('hidden');
          }
        }
      }

      visibleCount = 10;
      currentRenderFn = render;
      render();
    }

    // ─── Filter button setup ───
    function syncFilterButtonStyles() {
      document.querySelectorAll('.filter-btn').forEach((btn) => {
        const filterName = btn.getAttribute('data-filter');
        const filterValue = btn.getAttribute('data-value') || '';
        const currentValue = activeFilters[filterName] || '';
        btn.classList.toggle('active', filterValue === currentValue);
      });
    }

    function setupFilterButtons() {
      syncFilterButtonStyles();
      document.querySelectorAll('.filter-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const filterName = btn.getAttribute('data-filter');
          const filterValue = btn.getAttribute('data-value') || '';
          activeFilters[filterName] = filterValue;
          syncFilterButtonStyles();
          updateURL();
          reRender();
        });
      });
    }

    // ─── Lifestyle filter pills ───
    const lifestyleLevelMap = { budget: 1, comfortable: 2, premium: 3, luxury: 4 };
    const lifestyleDescriptions = {
      budget: 'Essentials covered — modest apartment, local food, public transit, and basic healthcare.',
      comfortable: 'Solid middle-class — nice apartment, regular dining out, good healthcare, and weekend activities.',
      premium: 'Upscale living — spacious home, fine dining, premium healthcare, a car, and frequent travel.',
      luxury: 'Top-tier everything — luxury housing, private healthcare, high-end dining, domestic help, and first-class travel.',
    };
    const lifestyleDescEl = document.getElementById('lifestyle-filter-desc');

    function syncLifestylePills() {
      const minLevel = lifestyleLevelMap[activeFilters.lifestyle] || 1;
      document.querySelectorAll('.lifestyle-pill').forEach((pill) => {
        const level = parseInt(pill.getAttribute('data-level'), 10);
        pill.classList.remove('at-min', 'above-min');
        if (level === minLevel) pill.classList.add('at-min');
        else if (level > minLevel) pill.classList.add('above-min');
      });
      if (lifestyleDescEl) lifestyleDescEl.textContent = lifestyleDescriptions[activeFilters.lifestyle] || '';
    }

    function setupLifestylePills() {
      syncLifestylePills();
      document.querySelectorAll('.lifestyle-pill').forEach((pill) => {
        pill.addEventListener('click', () => {
          activeFilters.lifestyle = pill.getAttribute('data-min-lifestyle');
          syncLifestylePills();
          updateURL();
          reRender();
        });
      });
    }

    // ─── Re-render (filter-only changes, no re-simulation) ───
    function reRender() {
      if (cachedSim) renderResults(cachedSim);
    }

    // ─── Monte Carlo Simulation ───
    function randomNormal(mean, stdDev) {
      let u1 = Math.random();
      while (u1 === 0) u1 = Math.random();
      const u2 = Math.random();
      const z = Math.sqrt(-2.0 * Math.log(u1)) * Math.cos(2.0 * Math.PI * u2);
      return mean + stdDev * z;
    }

    function runAccumulation(savings, contrib, annualReturn, volatility, yrsToRetire) {
      const NUM_RUNS = 2000;
      const portfolios = [];

      for (let run = 0; run < NUM_RUNS; run++) {
        let portfolio = savings;
        for (let y = 0; y < yrsToRetire; y++) {
          const r = randomNormal(annualReturn, volatility);
          portfolio = portfolio * (1 + r / 100) + contrib;
          if (portfolio < 0) portfolio = 0;
        }
        portfolios.push(portfolio);
      }

      portfolios.sort((a, b) => a - b);
      const median = portfolios[Math.floor(NUM_RUNS / 2)];
      const monthlyBudget = Math.round(((median * SAFE_WITHDRAWAL_RATE) + contrib) / 12);

      return { portfolios, median, monthlyBudget, contrib, NUM_RUNS };
    }

    function getCityConfidence(sim, annualSpend, annualReturn, volatility, retireDuration, inflationRate) {
      let survived = 0;

      for (let run = 0; run < sim.NUM_RUNS; run++) {
        let p = sim.portfolios[run];
        let withdrawal = annualSpend;
        let didSurvive = true;

        for (let y = 0; y < retireDuration; y++) {
          const r = randomNormal(annualReturn, volatility);
          p = p * (1 + r / 100) - withdrawal + sim.contrib;
          if (p < 0) { didSurvive = false; break; }
          withdrawal *= (1 + inflationRate / 100);
        }

        if (didSurvive) survived++;
      }

      return Math.round((survived / sim.NUM_RUNS) * 100);
    }

    // ─── Unified Simulation ───
    function runAndRender() {
      if (!currentSavings || currentSavings <= 0) return;

      const contrib = parseRawCurrency(document.getElementById('fire-contrib'));
      const annualReturn = parseFloat(document.getElementById('fire-return')?.value || '7');
      const volatility = parseFloat(document.getElementById('fire-vol')?.value || '12');
      const yrsToRetire = parseInt(document.getElementById('fire-yrs')?.value || '0', 10);
      const retireDuration = parseInt(document.getElementById('fire-duration')?.value || '30', 10);
      const inflationRate = parseFloat(document.getElementById('fire-inflation')?.value || '3');

      // Check if sim params changed (skip re-run for filter-only changes)
      const simKey = [currentSavings, contrib, annualReturn, volatility, yrsToRetire, retireDuration, inflationRate].join('|');
      if (simKey !== cachedSimKey) {
        cachedSim = runAccumulation(currentSavings, contrib, annualReturn, volatility, yrsToRetire);
        cachedSim.annualReturn = annualReturn;
        cachedSim.volatility = volatility;
        cachedSim.retireDuration = retireDuration;
        cachedSim.inflationRate = inflationRate;
        cachedSim.yrsToRetire = yrsToRetire;

        // Compute confidence cache
        cachedSim.confidenceCache = {};
        cityData.forEach((city) => {
          for (const tier of lifestyleTiers) {
            const tierData = city.tiers[tier.key];
            if (tierData) {
              const cacheKey = city.slug + '|' + tier.key;
              const annualSpend = tierData.totalSpend * 12;
              cachedSim.confidenceCache[cacheKey] = getCityConfidence(cachedSim, annualSpend, annualReturn, volatility, retireDuration, inflationRate);
            }
          }
        });

        cachedSimKey = simKey;
      }

      renderResults(cachedSim);
    }

    // ─── Unified Render ───
    function renderResults(sim) {
      fallback?.classList.add('hidden');
      summaryCards?.classList.remove('hidden');
      filterBar?.classList.remove('hidden');
      results?.classList.remove('hidden');

      const yrsToRetire = sim.yrsToRetire || 0;
      const lifestyle = activeFilters.lifestyle || 'budget';
      const filters = getActiveFilters();
      const minConf = activeFilters.minSuccessRate;
      const minLevel = minLifestyleLevels[lifestyle] || 1;

      // Projected Portfolio card — only show when years to retirement > 0
      const projectedCard = document.getElementById('projected-card');
      const projEl = document.getElementById('fire-projected');
      const summaryGrid = document.getElementById('summary-grid');
      if (projectedCard && projEl) {
        if (yrsToRetire > 0) {
          projectedCard.classList.remove('hidden');
          summaryGrid?.classList.remove('sm:grid-cols-3');
          summaryGrid?.classList.add('sm:grid-cols-4');
          if (sim.median >= 1_000_000) {
            projEl.textContent = '$' + (sim.median / 1_000_000).toFixed(1) + 'M';
          } else {
            projEl.textContent = fmtCurrency(sim.median);
          }
        } else {
          projectedCard.classList.add('hidden');
          summaryGrid?.classList.remove('sm:grid-cols-4');
          summaryGrid?.classList.add('sm:grid-cols-3');
        }
      }

      // Budget subtitle
      const budgetSubEl = document.getElementById('summary-budget-subtitle');
      if (budgetSubEl) {
        budgetSubEl.textContent = sim.contrib > 0
          ? '4% withdrawal + ' + fmtCurrency(Math.round(sim.contrib / 12)) + '/mo contributions'
          : '4% safe withdrawal rate';
      }

      // Cities with surplus count (broadest set, no filters)
      const noFilters = { loc: '', climate: '', eng: '' };
      const allAffordable = rankCities(sim.monthlyBudget, 'budget', noFilters);
      const surplusCount = allAffordable.length;

      // Confidence-aware ranking
      const ranked = cityData
        .filter((city) => passesFilters(city, filters))
        .map((city) => {
          const best = getBestConfidentTier(city, sim.monthlyBudget, minConf, sim.confidenceCache);
          if (!best || best.level < minLevel) return null;
          const tierData = city.tiers[best.key];
          const surplus = sim.monthlyBudget - tierData.totalSpend;
          const surplusRatio = sim.monthlyBudget > 0 ? surplus / sim.monthlyBudget : 0;
          const cacheKey = city.slug + '|' + best.key;
          const confidence = (sim.confidenceCache && sim.confidenceCache[cacheKey]) || 0;
          return { ...city, totalSpend: tierData.totalSpend, surplus, surplusRatio, usedTier: best.key, lifestyleLabel: best.label, lifestyleLevel: best.level, confidence };
        })
        .filter(Boolean)
        .map((city) => {
          const normalizedFire = city.fireScore / 10;
          const prefAlignment = getPrefAlignment(city, filters);
          const compositeScore = 0.60 * normalizedFire + 0.40 * prefAlignment;
          return { ...city, compositeScore };
        })
        .sort((a, b) => b.compositeScore - a.compositeScore);

      // Update summary cards
      const budgetEl = document.getElementById('summary-budget');
      const surplusCountEl = document.getElementById('summary-surplus-count');
      const surplusSubEl = document.getElementById('summary-surplus-subtitle');
      const bestEl = document.getElementById('summary-best');
      const bestSurplusEl = document.getElementById('summary-best-surplus');

      if (budgetEl) budgetEl.textContent = fmtCurrency(sim.monthlyBudget) + '/mo';
      if (surplusCountEl) surplusCountEl.textContent = String(surplusCount);
      if (surplusSubEl) surplusSubEl.textContent = 'budget to luxury';
      renderLifestyleReach(sim.monthlyBudget);

      const noCitiesEl = document.getElementById('fire-no-cities');
      const tbody = document.getElementById('city-rankings');

      if (ranked.length === 0) {
        noCitiesEl?.classList.remove('hidden');
        if (bestEl) bestEl.textContent = '\u2014';
        if (bestSurplusEl) bestSurplusEl.textContent = 'No matches with current filters';
        if (tbody) tbody.innerHTML = '';
        const filteredCountEl = document.getElementById('filtered-count');
        if (filteredCountEl) filteredCountEl.textContent = '0 cities';
        document.getElementById('show-more-container')?.classList.add('hidden');
      } else {
        noCitiesEl?.classList.add('hidden');
        if (bestEl) bestEl.textContent = ranked[0].emoji + ' ' + ranked[0].name;
        if (bestSurplusEl) {
          bestSurplusEl.textContent = '+' + fmtCurrency(ranked[0].surplus) + '/mo surplus';
          bestSurplusEl.className = 'text-xs text-emerald-600 mt-1';
        }
        renderRows(ranked, tbody, yrsToRetire > 0 ? Math.round(sim.median) : currentSavings, true);
      }
    }

    // ─── Debounced auto-run ───
    let debounceTimer = null;
    function debouncedRunAndRender() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => { runAndRender(); updateURL(); }, 500);
    }

    // ─── Advanced Panel Toggle ───
    function updateAdvancedSummary() {
      const summaryEl = document.getElementById('advanced-summary');
      if (!summaryEl) return;
      const ret = document.getElementById('fire-return')?.value || '7';
      const vol = document.getElementById('fire-vol')?.value || '12';
      const dur = document.getElementById('fire-duration')?.value || '30';
      const inf = document.getElementById('fire-inflation')?.value || '3';
      const contrib = parseRawCurrency(document.getElementById('fire-contrib'));
      const yrs = document.getElementById('fire-yrs')?.value || '0';
      let parts = [ret + '% return', vol + '% volatility', dur + 'yr retirement', inf + '% inflation'];
      if (parseInt(yrs, 10) > 0) parts.push(yrs + 'yr to retire');
      if (contrib > 0) parts.push(fmtCurrency(contrib) + '/yr contributions');
      summaryEl.textContent = parts.join(' \u00b7 ');
    }

    function setupAdvancedPanel() {
      const toggle = document.getElementById('advanced-toggle');
      const panel = document.getElementById('advanced-panel');
      const chevron = document.getElementById('advanced-chevron');

      if (toggle && panel && chevron) {
        toggle.addEventListener('click', () => {
          panel.classList.toggle('hidden');
          chevron.classList.toggle('rotate-180');
        });
      }

      // Slider value displays + debounced auto-run
      const sliderConfigs = [
        { id: 'fire-return', valId: 'fire-return-val', suffix: '%' },
        { id: 'fire-vol', valId: 'fire-vol-val', suffix: '%' },
        { id: 'fire-yrs', valId: 'fire-yrs-val', suffix: '' },
        { id: 'fire-duration', valId: 'fire-duration-val', suffix: ' years' },
        { id: 'fire-inflation', valId: 'fire-inflation-val', suffix: '%' },
      ];

      sliderConfigs.forEach(({ id, valId, suffix }) => {
        const slider = document.getElementById(id);
        const valEl = document.getElementById(valId);
        if (slider && valEl) {
          slider.addEventListener('input', () => {
            valEl.textContent = slider.value + suffix;
            updateAdvancedSummary();
            debouncedRunAndRender();
          });
        }
      });

      // Contributions input formatting + debounced auto-run
      const contribInput = document.getElementById('fire-contrib');
      if (contribInput) {
        contribInput.addEventListener('input', () => {
          const pos = contribInput.selectionStart || 0;
          const digitsBefore = contribInput.value.slice(0, pos).replace(/[^0-9]/g, '').length;
          contribInput.value = formatWithCommas(contribInput.value);
          let newPos = 0;
          let counted = 0;
          for (let i = 0; i < contribInput.value.length && counted < digitsBefore; i++) {
            if (/[0-9]/.test(contribInput.value[i])) counted++;
            newPos = i + 1;
          }
          contribInput.setSelectionRange(newPos, newPos);
          updateAdvancedSummary();
          debouncedRunAndRender();
        });
      }
    }

    // ─── Success Rate Slider Setup ───
    function setupSuccessRateSlider() {
      const slider = document.getElementById('success-rate-slider');
      const valueEl = document.getElementById('success-rate-value');
      if (!slider || !valueEl) return;

      slider.value = String(activeFilters.minSuccessRate);
      valueEl.textContent = activeFilters.minSuccessRate + '%';

      const descEl = document.getElementById('success-rate-desc');
      const mcLink = '<a href="/about#monte-carlo" class="text-brand-600 hover:underline">Monte Carlo</a>';
      function updateSuccessRateDesc(val) {
        if (!descEl) return;
        if (val === 100) {
          descEl.innerHTML = 'Because we use a ' + mcLink + ' simulation, 100% is nearly impossible. We recommend 90% or 95% as very conservative.';
        } else {
          descEl.innerHTML = '90% is recommended \u2014 the percentage of ' + mcLink + ' simulated scenarios where your portfolio lasts through retirement.';
        }
      }
      updateSuccessRateDesc(activeFilters.minSuccessRate);

      slider.addEventListener('input', () => {
        const val = parseInt(slider.value, 10);
        valueEl.textContent = val + '%';
        activeFilters.minSuccessRate = val;
        updateSuccessRateDesc(val);
        updateURL();
        reRender();
      });
    }

    // ─── NetWorthInput form interception ───
    function setupNetWorthInput() {
      // The NetWorthInput component uses a form that navigates to /?nw=X
      // Intercept it for instant results without page reload
      const form = document.querySelector('#nw-form');
      if (form) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const input = form.querySelector('input[name="nw"]') || form.querySelector('input');
          if (!input) return;
          const raw = parseInt((input.value || '').replace(/[^0-9]/g, ''), 10) || 0;
          if (raw <= 0) return;
          currentSavings = raw;
          runAndRender();
          updateURL();
        });
      }
    }

    // ─── Restore from URL (with localStorage fallback) ───
    function restoreFromUrl() {
      // Backwards compat: old FIRE URLs had mode=fire&savings=X
      const modeParam = params.get('mode');
      let nw = parseInt(params.get('nw') || '0', 10);
      if (!nw && modeParam === 'fire') {
        nw = parseInt(params.get('savings') || '0', 10);
      }

      // If no URL params, try localStorage
      let stored = null;
      const hasUrlParams = nw > 0 || params.get('contrib') || params.get('return') || params.get('vol') || params.get('yrs') || params.get('duration') || params.get('inflation');
      if (!hasUrlParams) {
        try {
          const raw = localStorage.getItem('pa_calc');
          if (raw) stored = JSON.parse(raw);
        } catch (e) {}
      }

      if (!nw && stored && stored.nw) nw = stored.nw;

      // Restore advanced params — URL takes priority, then localStorage, then defaults
      const setSlider = (id, valId, val, suffix) => {
        const slider = document.getElementById(id);
        const valEl = document.getElementById(valId);
        if (slider) slider.value = String(val);
        if (valEl) valEl.textContent = val + suffix;
      };

      const contrib = parseInt(params.get('contrib') || (stored && stored.contrib) || '0', 10);
      const annualReturn = parseFloat(params.get('return') || (stored && stored['return']) || '7');
      const volatility = parseFloat(params.get('vol') || (stored && stored.vol) || '12');
      const yrsToRetire = parseInt(params.get('yrs') || (stored && stored.yrs) || '0', 10);
      const retireDuration = parseInt(params.get('duration') || (stored && stored.duration) || '30', 10);
      const inflationRate = parseFloat(params.get('inflation') || (stored && stored.inflation) || '3');
      const lifestyle = params.get('lifestyle') || (stored && stored.lifestyle) || 'budget';

      // Populate form fields
      const contribInput = document.getElementById('fire-contrib');
      if (contribInput && contrib > 0) contribInput.value = contrib.toLocaleString('en-US');

      setSlider('fire-return', 'fire-return-val', annualReturn, '%');
      setSlider('fire-vol', 'fire-vol-val', volatility, '%');
      setSlider('fire-yrs', 'fire-yrs-val', yrsToRetire, '');
      setSlider('fire-duration', 'fire-duration-val', retireDuration, ' years');
      setSlider('fire-inflation', 'fire-inflation-val', inflationRate, '%');

      // Set lifestyle
      activeFilters.lifestyle = lifestyle;
      syncLifestylePills();

      // Restore success rate (already set in activeFilters from URL or localStorage)
      if (activeFilters.minSuccessRate !== 90) {
        const sr = activeFilters.minSuccessRate;
        const srSlider = document.getElementById('success-rate-slider');
        const srValue = document.getElementById('success-rate-value');
        if (srSlider) srSlider.value = String(sr);
        if (srValue) srValue.textContent = sr + '%';
      }

      // Auto-expand advanced panel if any non-default params
      const hasAdvanced = contrib > 0 || annualReturn !== 7 || volatility !== 12 || yrsToRetire !== 0 || retireDuration !== 30 || inflationRate !== 3;
      if (hasAdvanced) {
        const panel = document.getElementById('advanced-panel');
        const chevron = document.getElementById('advanced-chevron');
        if (panel) panel.classList.remove('hidden');
        if (chevron) chevron.classList.add('rotate-180');
      }

      updateAdvancedSummary();

      // Run simulation if we have savings
      if (nw > 0) {
        currentSavings = nw;
        runAndRender();
      } else {
        fallback?.classList.remove('hidden');
      }
    }

    // ─── Initialize ───
    setupFilterButtons();
    setupLifestylePills();
    setupSuccessRateSlider();
    setupAdvancedPanel();
    setupNetWorthInput();
    restoreFromUrl();
  }

  initCalculator();
</script>
