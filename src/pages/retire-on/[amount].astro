---
import Layout from '../../layouts/Layout.astro';
import { allCities } from '../../data/cities/index';
import { formatCurrency, SAFE_WITHDRAWAL_RATE } from '../../data/types';
import {
  getCityFireNumber,
  getLifestyleMonthlyCost,
  formatFireNumber,
} from '../../data/fireNumber';

interface TierDef {
  slug: string;
  label: string;
  value: number;
  titlePrefix: string;
}

const TIERS: TierDef[] = [
  { slug: '500k',  label: '$500K',  value: 500_000,   titlePrefix: 'Retire Abroad on $500K' },
  { slug: '750k',  label: '$750K',  value: 750_000,   titlePrefix: 'Retire Abroad on $750K' },
  { slug: '1m',    label: '$1M',    value: 1_000_000,  titlePrefix: 'Retire on $1 Million' },
  { slug: '1-5m',  label: '$1.5M',  value: 1_500_000,  titlePrefix: 'Retire on $1.5M Abroad' },
  { slug: '2m',    label: '$2M',    value: 2_000_000,  titlePrefix: 'Retire on $2 Million' },
  { slug: '3m',    label: '$3M',    value: 3_000_000,  titlePrefix: 'Fat FIRE Abroad on $3M' },
];

export function getStaticPaths() {
  return [
    { slug: '500k',  label: '$500K',  value: 500000,   titlePrefix: 'Retire Abroad on $500K' },
    { slug: '750k',  label: '$750K',  value: 750000,   titlePrefix: 'Retire Abroad on $750K' },
    { slug: '1m',    label: '$1M',    value: 1000000,  titlePrefix: 'Retire on $1 Million' },
    { slug: '1-5m',  label: '$1.5M',  value: 1500000,  titlePrefix: 'Retire on $1.5M Abroad' },
    { slug: '2m',    label: '$2M',    value: 2000000,  titlePrefix: 'Retire on $2 Million' },
    { slug: '3m',    label: '$3M',    value: 3000000,  titlePrefix: 'Fat FIRE Abroad on $3M' },
  ].map((t) => ({
    params: { amount: t.slug },
    props: { label: t.label, portfolioValue: t.value, titlePrefix: t.titlePrefix },
  }));
}

const { label, portfolioValue, titlePrefix } = Astro.props;
const { amount } = Astro.params;
const monthlyIncome = Math.round((portfolioValue * SAFE_WITHDRAWAL_RATE) / 12);

// Classify cities
const comfortable: { city: typeof allCities[0]; fireNumber: number; monthlyCost: number; buffer: number }[] = [];
const leanFire: { city: typeof allCities[0]; leanFireNumber: number; fireNumber: number; monthlyCost: number; gap: number }[] = [];

for (const city of allCities) {
  const fn = getCityFireNumber(city, 'comfortable');
  const leanFn = getCityFireNumber(city, 'budget');
  const mc = getLifestyleMonthlyCost(city, 'comfortable');
  const leanMc = getLifestyleMonthlyCost(city, 'budget');

  if (fn <= portfolioValue) {
    comfortable.push({ city, fireNumber: fn, monthlyCost: mc, buffer: portfolioValue - fn });
  } else if (leanFn <= portfolioValue) {
    leanFire.push({ city, leanFireNumber: leanFn, fireNumber: fn, monthlyCost: leanMc, gap: fn - portfolioValue });
  }
}

comfortable.sort((a, b) => a.fireNumber - b.fireNumber);
leanFire.sort((a, b) => a.leanFireNumber - b.leanFireNumber);

const totalAffordable = comfortable.length + leanFire.length;
const uniqueCountries = new Set(comfortable.map((r) => r.city.country)).size;

// SEO
const siteUrl = 'https://portfolioatlas.org';
const pageUrl = `${siteUrl}/retire-on/${amount}/`;

const comfortCount = comfortable.length;
const titleCitySuffix = comfortCount > 1
  ? `${comfortCount}+ Cities Where It's Possible`
  : comfortCount === 1
    ? `Cities Where It's Possible`
    : `${totalAffordable} ${totalAffordable === 1 ? 'City' : 'Cities'} Within Reach`;
const pageTitle = `${titlePrefix}: ${titleCitySuffix}`;

const top3 = comfortable.slice(0, 3).map((r) => r.city.name).join(', ');
const metaDesc = comfortCount > 0
  ? `A ${label} portfolio generates ${formatCurrency(monthlyIncome)}/month at the 4% rule. See the ${comfortCount} cities worldwide where that's enough for a comfortable retirement — including ${top3}.`
  : `A ${label} portfolio generates ${formatCurrency(monthlyIncome)}/month at the 4% rule. See ${totalAffordable} cities where Lean FIRE is possible on this budget.`;

const cheapestComfortable = comfortable[0];
const cheapestAnswer = cheapestComfortable
  ? `The most affordable comfortable retirement destination within a ${label} portfolio is ${cheapestComfortable.city.name}, ${cheapestComfortable.city.country}, with a FIRE Number of ${formatFireNumber(cheapestComfortable.fireNumber)} and monthly costs of approximately ${formatCurrency(cheapestComfortable.monthlyCost)}.`
  : `A ${label} portfolio is not yet sufficient for comfortable FIRE in any of the 111 cities we track, but Lean FIRE is possible in ${leanFire.length} cities.`;

const regionList = comfortCount > 0
  ? [...new Set(comfortable.map((r) => r.city.region))].slice(0, 3).join(', ')
  : [...new Set(leanFire.map((r) => r.city.region))].slice(0, 3).join(', ');

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': [
    {
      '@type': 'Question',
      'name': `Can I retire abroad on ${label}?`,
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': comfortCount > 0
          ? `Yes — a ${label} portfolio generates approximately ${formatCurrency(monthlyIncome)}/month using the 4% safe withdrawal rate. Of the ${allCities.length} cities tracked by PortfolioAtlas, ${comfortCount} cities offer a comfortable retirement lifestyle within this budget, primarily in ${regionList}.`
          : `A ${label} portfolio generates approximately ${formatCurrency(monthlyIncome)}/month using the 4% safe withdrawal rate. While comfortable FIRE isn't yet possible in any tracked city, Lean FIRE is achievable in ${leanFire.length} cities, primarily in ${regionList}.`,
      },
    },
    {
      '@type': 'Question',
      'name': `What is the cheapest place to retire on ${label}?`,
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': cheapestAnswer,
      },
    },
  ],
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': siteUrl },
    { '@type': 'ListItem', 'position': 2, 'name': 'Retire By Budget', 'item': `${siteUrl}/retire-on/` },
    { '@type': 'ListItem', 'position': 3, 'name': `Retire on ${label}`, 'item': pageUrl },
  ],
};

const jsonLd = [breadcrumbLd, faqLd];
---

<Layout
  title={pageTitle}
  description={metaDesc}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative bg-brand-950 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-950/95 via-brand-900/80 to-brand-800/70"></div>
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25px 25px, white 2px, transparent 0); background-size: 50px 50px;"></div>
    </div>
    <div class="relative container-narrow py-16 md:py-20">
      <a href="/retire-on" class="inline-flex items-center gap-1.5 text-sm text-brand-300 hover:text-white transition-colors mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        All Portfolio Tiers
      </a>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-serif font-bold mb-4">
        Where Can You Retire on {label}?
        <span class="block text-xl md:text-2xl font-normal text-brand-300 mt-2">
          {totalAffordable} cities worldwide
        </span>
      </h1>
      <p class="text-lg text-sand-300 max-w-2xl leading-relaxed">
        Using the <strong class="text-white">4% safe withdrawal rule</strong>, a {label} portfolio generates <strong class="text-white">{formatCurrency(monthlyIncome)}/month</strong>. Here are every city where that's enough to retire — and where you're close.
      </p>
    </div>
  </section>

  <div class="container-narrow py-12">

    <!-- Insights -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      <div class="bg-white rounded-xl border border-sand-200 p-5 text-center">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Comfortable FIRE</p>
        <p class="text-2xl font-bold text-brand-700">{comfortCount}</p>
        <p class="text-sm text-gray-500">{comfortCount === 1 ? 'city' : 'cities'} across {uniqueCountries} {uniqueCountries === 1 ? 'country' : 'countries'}</p>
      </div>
      <div class="bg-white rounded-xl border border-sand-200 p-5 text-center">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Lean FIRE Possible</p>
        <p class="text-2xl font-bold text-amber-600">{leanFire.length}</p>
        <p class="text-sm text-gray-500">additional {leanFire.length === 1 ? 'city' : 'cities'}</p>
      </div>
      <div class="bg-white rounded-xl border border-sand-200 p-5 text-center">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Monthly Income</p>
        <p class="text-2xl font-bold text-emerald-600">{formatCurrency(monthlyIncome)}</p>
        <p class="text-sm text-gray-500">at 4% withdrawal</p>
      </div>
    </div>

    {cheapestComfortable && (
      <div class="bg-brand-50 border border-brand-200 rounded-xl p-5 mb-10">
        <p class="text-sm text-brand-800">
          <strong>Cheapest comfortable option:</strong> {cheapestComfortable.city.emoji} <a href={`/cities/${cheapestComfortable.city.slug}/`} class="font-semibold underline hover:text-brand-600">{cheapestComfortable.city.name}, {cheapestComfortable.city.country}</a> at {formatFireNumber(cheapestComfortable.fireNumber)} — leaving you a {formatFireNumber(cheapestComfortable.buffer)} buffer.
          Of the {allCities.length} cities we track, you're within reach of <strong>{Math.round((totalAffordable / allCities.length) * 100)}%</strong>.
        </p>
      </div>
    )}

    <!-- Comfortable section -->
    {comfortable.length > 0 && (
      <section class="mb-12">
        <h2 class="font-serif text-2xl font-bold text-brand-950 mb-4">
          Comfortable Retirement ({comfortable.length} {comfortable.length === 1 ? 'city' : 'cities'})
        </h2>
        <div class="bg-white rounded-2xl border border-sand-200 shadow-sm overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b-2 border-sand-200 bg-sand-50">
                  <th class="text-left py-3 px-5 font-semibold text-gray-600">City</th>
                  <th class="text-left py-3 px-5 font-semibold text-gray-600 hidden sm:table-cell">Country</th>
                  <th class="text-right py-3 px-5 font-semibold text-gray-600">FIRE Number</th>
                  <th class="text-right py-3 px-5 font-semibold text-gray-600 hidden md:table-cell">Monthly Cost</th>
                  <th class="text-right py-3 px-5 font-semibold text-gray-600">Buffer</th>
                </tr>
              </thead>
              <tbody>
                {comfortable.map((row) => (
                  <tr class="border-b border-sand-100 hover:bg-emerald-50/30 transition-colors">
                    <td class="py-3.5 px-5">
                      <a href={`/cities/${row.city.slug}/`} class="font-bold text-brand-700 hover:text-brand-900 transition-colors">
                        <span class="mr-1.5">{row.city.emoji}</span>{row.city.name}
                      </a>
                    </td>
                    <td class="py-3.5 px-5 text-gray-500 hidden sm:table-cell">{row.city.country}</td>
                    <td class="text-right py-3.5 px-5">
                      <span class="font-bold text-brand-700">{formatFireNumber(row.fireNumber)}</span>
                    </td>
                    <td class="text-right py-3.5 px-5 text-gray-500 hidden md:table-cell">{formatCurrency(row.monthlyCost)}/mo</td>
                    <td class="text-right py-3.5 px-5">
                      <span class="text-emerald-600 font-semibold">+{formatFireNumber(row.buffer)}</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    )}

    <!-- Lean FIRE section -->
    {leanFire.length > 0 && (
      <section class="mb-12">
        <h2 class="font-serif text-2xl font-bold text-brand-950 mb-4">
          Lean FIRE Possible ({leanFire.length} {leanFire.length === 1 ? 'city' : 'cities'})
        </h2>
        <p class="text-sm text-gray-500 mb-4">
          These cities are affordable at a lean lifestyle. The gap shows how much more you'd need for comfortable FIRE.
        </p>
        <div class="bg-white rounded-2xl border border-sand-200 shadow-sm overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b-2 border-sand-200 bg-sand-50">
                  <th class="text-left py-3 px-5 font-semibold text-gray-600">City</th>
                  <th class="text-left py-3 px-5 font-semibold text-gray-600 hidden sm:table-cell">Country</th>
                  <th class="text-right py-3 px-5 font-semibold text-gray-600">Lean FIRE</th>
                  <th class="text-right py-3 px-5 font-semibold text-gray-600 hidden md:table-cell">Monthly Cost</th>
                  <th class="text-right py-3 px-5 font-semibold text-gray-600">Gap to FIRE</th>
                </tr>
              </thead>
              <tbody>
                {leanFire.map((row) => (
                  <tr class="border-b border-sand-100 hover:bg-amber-50/30 transition-colors">
                    <td class="py-3.5 px-5">
                      <a href={`/cities/${row.city.slug}/`} class="font-bold text-brand-700 hover:text-brand-900 transition-colors">
                        <span class="mr-1.5">{row.city.emoji}</span>{row.city.name}
                      </a>
                    </td>
                    <td class="py-3.5 px-5 text-gray-500 hidden sm:table-cell">{row.city.country}</td>
                    <td class="text-right py-3.5 px-5">
                      <span class="font-bold text-amber-600">{formatFireNumber(row.leanFireNumber)}</span>
                    </td>
                    <td class="text-right py-3.5 px-5 text-gray-500 hidden md:table-cell">{formatCurrency(row.monthlyCost)}/mo</td>
                    <td class="text-right py-3.5 px-5">
                      <span class="text-gray-500">{formatFireNumber(row.gap)} more</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section>
      <div class="bg-brand-950 rounded-2xl p-8 text-center text-white">
        <h2 class="font-serif text-2xl font-bold mb-3">
          Filter by Climate, Safety, Healthcare & More
        </h2>
        <p class="text-sand-300 mb-6 max-w-lg mx-auto">
          Use the full PortfolioAtlas tool to narrow down your retirement destination with advanced filters.
        </p>
        <a
          href={`/?portfolio=${portfolioValue}`}
          class="inline-flex items-center gap-2 px-6 py-3 bg-white text-brand-700 font-semibold rounded-lg hover:bg-sand-50 transition-colors"
        >
          Open Explorer with {label}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </section>
  </div>
</Layout>
