---
import Layout from '../../layouts/Layout.astro';
import { allCities } from '../../data/cities/index';
import { formatCurrency, getTotalSpend } from '../../data/types';
import {
  getCityFireNumber,
  getLifestyleMonthlyCost,
  formatFireNumber,
  getCityDisplayTags,
  getTagColor,
  LIFESTYLE_LABELS,
  ALL_LIFESTYLE_TIERS,
} from '../../data/fireNumber';
import type { LifestyleTier } from '../../data/fireNumber';

const toSlug = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

export function getStaticPaths() {
  const countryMap = new Map<string, typeof allCities>();
  const slugFn = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  for (const city of allCities) {
    const slug = slugFn(city.country);
    if (!countryMap.has(slug)) countryMap.set(slug, []);
    countryMap.get(slug)!.push(city);
  }
  return Array.from(countryMap.entries()).map(([slug, cities]) => ({
    params: { country: slug },
    props: { cities, countryName: cities[0].country },
  }));
}

const { cities, countryName } = Astro.props;
const countrySlug = toSlug(countryName);

// Compute FIRE numbers for all cities, sort by FIRE number ascending
const cityRows = cities.map((city) => {
  const leanFire = getCityFireNumber(city, 'budget');
  const fire = getCityFireNumber(city, 'comfortable');
  const fatFire = getCityFireNumber(city, 'luxury');
  const monthlyCost = getLifestyleMonthlyCost(city, 'comfortable');
  return { city, leanFire, fire, fatFire, monthlyCost };
}).sort((a, b) => a.fire - b.fire);

const cheapest = cityRows[0];
const mostExpensive = cityRows[cityRows.length - 1];
const avgFire = Math.round(cityRows.reduce((s, r) => s + r.fire, 0) / cityRows.length / 1000) * 1000;

// SEO
const siteUrl = 'https://portfolioatlas.org';
const pageUrl = `${siteUrl}/retire-in/${countrySlug}/`;

const top2 = cityRows.slice(0, 2).map((r) => r.city.name);
const titleCities = top2.length >= 2 ? `${top2[0]}, ${top2[1]} & More` : top2[0];
const pageTitle = cities.length > 1
  ? `Retire in ${countryName}: FIRE Numbers for ${titleCities}`
  : `Retire in ${countryName}: FIRE Number for ${top2[0]}`;

// Meta description — target 140-160 chars
const metaDescBase = `How much do you need to retire in ${countryName}? FIRE Numbers range from ${formatFireNumber(cheapest.fire)} in ${cheapest.city.name} to ${formatFireNumber(mostExpensive.fire)} in ${mostExpensive.city.name}. See full cost breakdowns for all ${cities.length} cities.`;
const metaDescSingle = `How much do you need to retire in ${countryName}? The FIRE Number for ${cheapest.city.name} is ${formatFireNumber(cheapest.fire)} (4% rule). See Lean FIRE, FIRE, and Fat FIRE cost breakdowns.`;
const metaDesc = cities.length > 1 ? metaDescBase : metaDescSingle;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': siteUrl },
    { '@type': 'ListItem', 'position': 2, 'name': `Retire in ${countryName}`, 'item': pageUrl },
  ],
};

const datasetLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  'name': `FIRE Numbers for ${countryName} Cities`,
  'description': `Portfolio requirements to retire in ${countryName} cities using the 4% safe withdrawal rule`,
  'url': pageUrl,
};

const jsonLd = [breadcrumbLd, datasetLd];

// Country description
function getCountryDescription(): string {
  const cheapName = cheapest.city.name;
  const cheapFire = formatFireNumber(cheapest.fire);
  if (cities.length === 1) {
    return `${cheapName} is the city we track in ${countryName}, with a FIRE Number of ${cheapFire} based on the 4% safe withdrawal rate. Explore the full cost breakdown below to see if ${countryName} fits your retirement plan.`;
  }
  const expName = mostExpensive.city.name;
  const expFire = formatFireNumber(mostExpensive.fire);
  const avgFormatted = formatFireNumber(avgFire);
  return `${countryName} offers ${cities.length} retirement destinations tracked on PortfolioAtlas. The most affordable is ${cheapName} at ${cheapFire}, while ${expName} requires ${expFire}. The average FIRE Number across all ${countryName} cities is ${avgFormatted}, calculated using the 4% safe withdrawal rate.`;
}
---

<Layout
  title={pageTitle}
  description={metaDesc}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative bg-brand-950 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-950/95 via-brand-900/80 to-brand-800/70"></div>
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25px 25px, white 2px, transparent 0); background-size: 50px 50px;"></div>
    </div>
    <div class="relative container-narrow py-16 md:py-20">
      <a href="/retire-in" class="inline-flex items-center gap-1.5 text-sm text-brand-300 hover:text-white transition-colors mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        All Countries
      </a>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-serif font-bold mb-4">
        Retire in {countryName}
      </h1>
      <p class="text-lg text-sand-300 max-w-2xl leading-relaxed">
        Using the <strong class="text-white">4% safe withdrawal rule</strong>, here's how much you need invested to retire in {countryName} at every lifestyle level.
      </p>
    </div>
  </section>

  <div class="container-narrow py-12">
    <!-- Summary stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      <div class="bg-white rounded-xl border border-sand-200 p-5 text-center">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Cheapest City</p>
        <p class="text-lg font-bold text-brand-700">{formatFireNumber(cheapest.fire)}</p>
        <p class="text-sm text-gray-500">{cheapest.city.name}</p>
      </div>
      {cities.length > 1 && (
        <div class="bg-white rounded-xl border border-sand-200 p-5 text-center">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Average FIRE Number</p>
          <p class="text-lg font-bold text-brand-700">{formatFireNumber(avgFire)}</p>
          <p class="text-sm text-gray-500">{cities.length} cities</p>
        </div>
      )}
      {cities.length > 1 && (
        <div class="bg-white rounded-xl border border-sand-200 p-5 text-center">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Most Expensive</p>
          <p class="text-lg font-bold text-brand-700">{formatFireNumber(mostExpensive.fire)}</p>
          <p class="text-sm text-gray-500">{mostExpensive.city.name}</p>
        </div>
      )}
    </div>

    <!-- Cities table -->
    <section>
      <h2 class="font-serif text-2xl font-bold text-brand-950 mb-4">
        FIRE Numbers for {cities.length > 1 ? `All ${cities.length} Cities in` : ''} {countryName}
      </h2>
      <div class="bg-white rounded-2xl border border-sand-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b-2 border-sand-200 bg-sand-50">
                <th class="text-left py-3 px-5 font-semibold text-gray-600">City</th>
                <th class="text-right py-3 px-5 font-semibold text-gray-600">Lean FIRE</th>
                <th class="text-right py-3 px-5 font-semibold text-gray-600">FIRE</th>
                <th class="text-right py-3 px-5 font-semibold text-gray-600">Fat FIRE</th>
                <th class="text-right py-3 px-5 font-semibold text-gray-600 hidden sm:table-cell">Monthly Cost</th>
              </tr>
            </thead>
            <tbody>
              {cityRows.map((row) => (
                <tr class="border-b border-sand-100 hover:bg-sand-50/50 transition-colors">
                  <td class="py-4 px-5">
                    <a href={`/cities/${row.city.slug}/`} class="font-bold text-brand-700 hover:text-brand-900 transition-colors">
                      <span class="mr-1.5">{row.city.emoji}</span>{row.city.name}
                    </a>
                  </td>
                  <td class="text-right py-4 px-5 text-gray-600">{formatFireNumber(row.leanFire)}</td>
                  <td class="text-right py-4 px-5">
                    <span class="font-bold text-brand-700">{formatFireNumber(row.fire)}</span>
                  </td>
                  <td class="text-right py-4 px-5 text-gray-600">{formatFireNumber(row.fatFire)}</td>
                  <td class="text-right py-4 px-5 text-gray-500 hidden sm:table-cell">{formatCurrency(row.monthlyCost)}/mo</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Country description -->
    <section class="mt-10">
      <h2 class="font-serif text-2xl font-bold text-brand-950 mb-3">
        About Retiring in {countryName}
      </h2>
      <p class="text-gray-600 leading-relaxed">
        {getCountryDescription()}
      </p>
    </section>

    <!-- CTA -->
    <section class="mt-10">
      <div class="bg-brand-950 rounded-2xl p-8 text-center text-white">
        <h2 class="font-serif text-2xl font-bold mb-3">
          See Which Cities in {countryName} Match Your Portfolio
        </h2>
        <p class="text-sand-300 mb-6 max-w-lg mx-auto">
          Enter your portfolio value and we'll show you which {countryName} cities you can retire in today.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white text-brand-700 font-semibold rounded-lg hover:bg-sand-50 transition-colors"
        >
          Explore All Cities
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </section>
  </div>
</Layout>
