---
import Layout from '../../layouts/Layout.astro';
import { allCities } from '../../data/cities/index';
import {
  getCityFireNumber,
  formatFireNumber,
} from '../../data/fireNumber';

function countryToSlug(country: string): string {
  return country.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

// Build country data
const countryMap = new Map<string, { name: string; slug: string; cityCount: number; minFire: number; maxFire: number; emoji: string }>();
for (const city of allCities) {
  const slug = countryToSlug(city.country);
  const fire = getCityFireNumber(city, 'comfortable');
  const existing = countryMap.get(slug);
  if (existing) {
    existing.cityCount++;
    existing.minFire = Math.min(existing.minFire, fire);
    existing.maxFire = Math.max(existing.maxFire, fire);
  } else {
    countryMap.set(slug, {
      name: city.country,
      slug,
      cityCount: 1,
      minFire: fire,
      maxFire: fire,
      emoji: city.emoji,
    });
  }
}

const countries = Array.from(countryMap.values()).sort((a, b) => a.name.localeCompare(b.name));

const siteUrl = 'https://portfolioatlas.org';
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': siteUrl },
    { '@type': 'ListItem', 'position': 2, 'name': 'Retire Abroad', 'item': `${siteUrl}/retire-in/` },
  ],
};
---

<Layout
  title="Retire Abroad: FIRE Numbers by Country"
  description={`Compare FIRE Numbers across ${countries.length} countries and 100+ cities. See how much you need to retire abroad using the 4% rule — from Southeast Asia to Europe to Latin America.`}
  jsonLd={breadcrumbLd}
>
  <!-- Hero -->
  <section class="relative bg-brand-950 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-950/95 via-brand-900/80 to-brand-800/70"></div>
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25px 25px, white 2px, transparent 0); background-size: 50px 50px;"></div>
    </div>
    <div class="relative container-narrow py-16 md:py-20">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-serif font-bold mb-4">
        Retire Abroad: Choose Your Country
      </h1>
      <p class="text-lg text-sand-300 max-w-2xl leading-relaxed">
        We track <strong class="text-white">{countries.length} countries</strong> and <strong class="text-white">{allCities.length}+ cities</strong> worldwide. Pick a country to see FIRE Numbers for every city.
      </p>
    </div>
  </section>

  <div class="container-narrow py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {countries.map((c) => (
        <a
          href={`/retire-in/${c.slug}/`}
          class="bg-white rounded-xl border border-sand-200 p-5 hover:border-brand-300 hover:shadow-md transition-all group"
        >
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">{c.emoji}</span>
            <h2 class="font-serif text-lg font-bold text-brand-950 group-hover:text-brand-700 transition-colors">
              {c.name}
            </h2>
          </div>
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-500">
              {c.cityCount} {c.cityCount === 1 ? 'city' : 'cities'}
            </span>
            <span class="text-gray-600">
              {c.minFire === c.maxFire
                ? formatFireNumber(c.minFire)
                : `${formatFireNumber(c.minFire)} – ${formatFireNumber(c.maxFire)}`}
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <section class="mt-12">
      <div class="bg-brand-950 rounded-2xl p-8 text-center text-white">
        <h2 class="font-serif text-2xl font-bold mb-3">
          Find Your FIRE Destination
        </h2>
        <p class="text-sand-300 mb-6 max-w-lg mx-auto">
          Enter your portfolio value and see every city in the world where you can retire.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white text-brand-700 font-semibold rounded-lg hover:bg-sand-50 transition-colors"
        >
          Explore All Cities
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </section>
  </div>
</Layout>
