---
import type { CityData } from '../data/types';

interface Props {
  currentCity: CityData;
  allCities: CityData[];
}

const { currentCity, allCities } = Astro.props;

// Suggest 3 cities from the same region + 2 from different regions
const samRegion = allCities
  .filter((c) => c.region === currentCity.region && c.slug !== currentCity.slug)
  .slice(0, 3);

const diffRegion = allCities
  .filter((c) => c.region !== currentCity.region)
  .sort((a, b) => b.fireScore - a.fireScore)
  .slice(0, 2);

const suggestions = [...samRegion, ...diffRegion].slice(0, 5);
---

<section class="bg-brand-50 rounded-2xl p-6 border border-brand-100">
  <h3 class="font-serif text-xl font-bold text-brand-950 mb-2">
    Compare {currentCity.name} With...
  </h3>
  <p class="text-sm text-gray-600 mb-4">
    See how {currentCity.name} stacks up against other popular FIRE destinations.
  </p>

  <div class="flex flex-wrap gap-2 comparison-cta-links" data-current-slug={currentCity.slug}>
    {suggestions.map((city) => (
      <a
        href={`/compare?cities=${currentCity.slug},${city.slug}`}
        class="inline-flex items-center gap-1.5 px-3 py-2 bg-white rounded-full text-sm font-medium text-gray-700 border border-sand-200 hover:border-brand-300 hover:text-brand-600 transition-all"
      >
        <span>{city.emoji}</span>
        {city.name}
      </a>
    ))}
  </div>

  <a
    href="/compare"
    class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-brand-600 hover:text-brand-800 transition-colors"
  >
    Compare all destinations
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</section>

<script>
  // Preserve ?nw= param on comparison links
  (function() {
    const params = new URLSearchParams(window.location.search);
    const nw = params.get('nw');
    if (!nw) return;
    const container = document.querySelector('.comparison-cta-links');
    if (!container) return;
    container.querySelectorAll('a').forEach((a) => {
      const href = a.getAttribute('href');
      if (href && href.startsWith('/compare')) {
        const url = new URL(href, window.location.origin);
        url.searchParams.set('nw', nw);
        a.setAttribute('href', url.pathname + url.search);
      }
    });
  })();
</script>
