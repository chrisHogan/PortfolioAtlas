---
import type { CityData } from '../data/types';
import { getFireScoreClass, formatCurrency } from '../data/types';
import {
  getCityFireNumber,
  getLifestyleMonthlyCost,
  formatFireNumber,
  getCityDisplayTags,
  getTagColor,
} from '../data/fireNumber';
import type { LifestyleTier } from '../data/fireNumber';

interface Props {
  city: CityData;
  lifestyle?: LifestyleTier;
  portfolio?: number;
}

const { city, lifestyle = 'comfortable', portfolio = 0 } = Astro.props;
const scoreClass = getFireScoreClass(city.fireScore);
const fireNumber = getCityFireNumber(city, lifestyle);
const monthlyCost = getLifestyleMonthlyCost(city, lifestyle);
const tags = getCityDisplayTags(city);
const affordable = portfolio > 0 && portfolio >= fireNumber;
const gap = portfolio > 0 ? portfolio - fireNumber : 0;

// Show 3-4 most relevant tags as pills
const tagPills = [
  { label: tags.climate, category: 'climate' },
  { label: tags.safety, category: 'safety' },
  { label: tags.english, category: 'english' },
  { label: tags.visa !== 'Moderate' ? `Visa: ${tags.visa}` : '', category: 'visa' },
].filter(t => t.label);

const tagTooltips: Record<string, string> = { climate: 'Climate', safety: 'Safety rating', english: 'English proficiency', visa: 'Visa ease' };
---

<a href={`/cities/${city.slug}`} class="city-card block group" data-fire-number={fireNumber}>
  <!-- Color bar at top -->
  <div class:list={['h-2 bg-gradient-to-r', affordable ? 'from-emerald-400 to-emerald-500' : 'from-brand-500 to-brand-600']}></div>

  <div class="p-5">
    <div class="flex items-start justify-between mb-3">
      <div class="flex items-center gap-2">
        <span class="text-2xl">{city.emoji}</span>
        <div>
          <h3 class="font-serif font-bold text-lg text-brand-950 group-hover:text-brand-600 transition-colors">
            {city.name}
          </h3>
          <p class="text-sm text-gray-500">{city.country}</p>
        </div>
      </div>
      <div class={`fire-score w-10 h-10 text-sm ${scoreClass}`}>
        {city.fireScore.toFixed(1)}
      </div>
    </div>

    <!-- FIRE Number + sustainability signal -->
    <div class="mb-3">
      <div class="flex items-baseline justify-between">
        <span class="text-xs text-gray-500">FIRE Number</span>
        <span class="text-lg font-bold text-brand-700">{formatFireNumber(fireNumber)}</span>
      </div>
      {portfolio > 0 ? (
        affordable ? (
          <div class="flex items-center gap-1.5 mt-1">
            <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm font-semibold text-emerald-600">You can retire here</span>
          </div>
        ) : (
          <p class="text-sm text-gray-500 mt-1">Need {formatFireNumber(Math.abs(gap))} more</p>
        )
      ) : null}
    </div>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5 mb-3">
      {tagPills.slice(0, 4).map(({ label, category }) => (
        <span title={`${tagTooltips[category] || category}: ${label}`} class:list={['text-[10px] font-medium px-2 py-0.5 rounded-full', getTagColor(category, label)]}>
          {label}
        </span>
      ))}
    </div>

    <div class="flex items-center justify-between pt-3 border-t border-sand-100">
      <p class="text-xs text-gray-400">
        From {formatCurrency(monthlyCost)}/mo
      </p>
      <span class="text-xs font-medium text-brand-600 bg-brand-50 px-3 py-1 rounded-full">
        {city.region}
      </span>
    </div>
  </div>
</a>
