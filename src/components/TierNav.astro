---
import type { TierKey } from '../data/types';

const tiers: TierKey[] = ['1M', '2M', '3M', '5M', '10M'];
---

<nav class="bg-white sticky top-16 z-40 border-b border-sand-200 shadow-sm">
  <div class="container-narrow">
    <div class="relative">
    <div class="flex items-center gap-1 overflow-x-auto py-3 scrollbar-hide">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider mr-2 shrink-0">
        Portfolio:
      </span>
      <button
        id="tier-nav-yours"
        data-tier-target="personalized"
        class="hidden shrink-0 px-4 py-2 text-sm font-bold rounded-full bg-brand-600 text-white border border-brand-600 hover:bg-brand-700 transition-all tier-nav-pill"
        type="button"
      >
        Your Portfolio
      </button>
      {tiers.map((tier) => (
        <button
          data-tier-target={tier}
          class="shrink-0 px-4 py-2 text-sm font-medium rounded-full border border-sand-200 text-gray-600 hover:bg-brand-50 hover:text-brand-700 hover:border-brand-200 transition-all tier-nav-pill"
          type="button"
        >
          ${tier}
        </button>
      ))}
    </div>
    <!-- Scroll hint: right-edge gradient fade, visible only on small screens -->
    <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-white to-transparent sm:hidden" aria-hidden="true"></div>
    </div>
  </div>
</nav>

<script>
  (function() {
    const params = new URLSearchParams(window.location.search);
    if (params.get('nw')) {
      const pill = document.getElementById('tier-nav-yours');
      if (pill) pill.classList.remove('hidden');
    }

    // Nav pill click: open matching accordion, close others, scroll into view
    document.querySelectorAll('.tier-nav-pill').forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = (btn as HTMLButtonElement).dataset.tierTarget;
        if (!target) return;

        // Handle personalized tier separately (it's not an accordion)
        if (target === 'personalized') {
          const el = document.getElementById('personalized-tier');
          if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          return;
        }

        // Open accordion for this tier
        const accordion = document.querySelector(`.accordion-tier[data-tier="${target}"]`) as HTMLElement;
        if (!accordion) return;

        // Close all other accordions
        document.querySelectorAll('.accordion-tier').forEach((el) => {
          if (el !== accordion) {
            el.setAttribute('data-open', 'false');
            const headerBtn = el.querySelector('.accordion-header') as HTMLButtonElement;
            if (headerBtn) headerBtn.setAttribute('aria-expanded', 'false');
          }
        });

        // Open this one
        accordion.setAttribute('data-open', 'true');
        const headerBtn = accordion.querySelector('.accordion-header') as HTMLButtonElement;
        if (headerBtn) headerBtn.setAttribute('aria-expanded', 'true');

        // Scroll into view
        accordion.scrollIntoView({ behavior: 'smooth', block: 'start' });

        // Update active pill styles
        updateActivePill(target);
      });
    });

    function updateActivePill(activeTier: string) {
      document.querySelectorAll('.tier-nav-pill').forEach((pill) => {
        const target = (pill as HTMLButtonElement).dataset.tierTarget;
        if (target === activeTier) {
          pill.classList.add('bg-brand-600', 'text-white', 'border-brand-600');
          pill.classList.remove('text-gray-600', 'border-sand-200');
        } else {
          pill.classList.remove('bg-brand-600', 'text-white', 'border-brand-600');
          pill.classList.add('text-gray-600', 'border-sand-200');
        }
      });
    }

    // Set initial active pill to match whatever accordion is open
    const openAccordion = document.querySelector('.accordion-tier[data-open="true"]');
    if (openAccordion) {
      updateActivePill(openAccordion.getAttribute('data-tier') || '');
    }
  })();
</script>
