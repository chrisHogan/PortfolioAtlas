---
import type { TierKey } from '../data/types';
import { TIER_LABELS } from '../data/types';

const tiers: TierKey[] = ['1M', '2M', '3M', '5M', '10M'];
---

<nav class="bg-white sticky top-16 z-40 border-b border-sand-200 shadow-sm">
  <div class="container-narrow">
    <div class="flex items-center gap-1 overflow-x-auto py-3 scrollbar-hide">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider mr-2 shrink-0">
        Portfolio:
      </span>
      <a
        id="tier-nav-yours"
        href="#personalized-tier"
        class="hidden shrink-0 px-4 py-2 text-sm font-bold rounded-full bg-brand-600 text-white border border-brand-600 hover:bg-brand-700 transition-all"
      >
        Your Portfolio
      </a>
      {tiers.map((tier) => (
        <a
          href={`#tier-${tier}`}
          class="shrink-0 px-4 py-2 text-sm font-medium rounded-full border border-sand-200 text-gray-600 hover:bg-brand-50 hover:text-brand-700 hover:border-brand-200 transition-all"
        >
          ${tier}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  (function() {
    const params = new URLSearchParams(window.location.search);
    if (!params.get('nw')) return;
    const pill = document.getElementById('tier-nav-yours');
    if (pill) pill.classList.remove('hidden');
  })();
</script>
