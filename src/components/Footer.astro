---
const year = new Date().getFullYear();
---

<footer class="bg-brand-950 text-sand-300 mt-20">
  <div class="container-wide py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <span class="font-serif font-bold text-xl text-white">
          Portfolio<span class="text-brand-400">Atlas</span>
        </span>
        <p class="mt-3 text-sm text-sand-400 max-w-xs">
          Discover what your investment portfolio can buy you in cities around the world. Plan your FIRE lifestyle with confidence.
        </p>
      </div>

      <!-- Explore -->
      <div>
        <h4 class="font-semibold text-white text-sm uppercase tracking-wider mb-4">Explore</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">All Destinations</a></li>
          <li><a href="/compare" class="hover:text-white transition-colors">Compare Cities</a></li>
          <li><a href="/calculator" class="hover:text-white transition-colors">Calculator</a></li>
          <li><a href="/about" class="hover:text-white transition-colors">About</a></li>
        </ul>
      </div>

      <!-- Regions -->
      <div>
        <h4 class="font-semibold text-white text-sm uppercase tracking-wider mb-4">Regions</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/#north-america" class="hover:text-white transition-colors">North America</a></li>
          <li><a href="/#europe" class="hover:text-white transition-colors">Europe</a></li>
          <li><a href="/#latin-america" class="hover:text-white transition-colors">Latin America</a></li>
          <li><a href="/#southeast-asia" class="hover:text-white transition-colors">Southeast Asia</a></li>
          <li><a href="/#east-asia" class="hover:text-white transition-colors">East Asia</a></li>
          <li><a href="/#south-asia" class="hover:text-white transition-colors">South Asia</a></li>
          <li><a href="/#oceania" class="hover:text-white transition-colors">Oceania</a></li>
          <li><a href="/#middle-east" class="hover:text-white transition-colors">Middle East</a></li>
          <li><a href="/#africa" class="hover:text-white transition-colors">Africa</a></li>
          <li><a href="/#caribbean" class="hover:text-white transition-colors">Caribbean</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-brand-800 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-sand-500">
        &copy; {year} PortfolioAtlas. All rights reserved.
      </p>
      <p class="text-xs text-sand-500">
        Data is for informational purposes only. Consult a financial advisor before making relocation decisions.
      </p>
    </div>
  </div>
</footer>
