---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="city-card block group">
  <div class="h-2 bg-gradient-to-r from-brand-500 to-brand-600"></div>

  <div class="p-5">
    <div class="flex items-center gap-2 text-xs text-gray-500 mb-3">
      <time datetime={date.toISOString().split('T')[0]}>{formattedDate}</time>
    </div>

    <h3 class="font-serif font-bold text-lg text-brand-950 group-hover:text-brand-600 transition-colors mb-2">
      {title}
    </h3>

    <p class="text-sm text-gray-600 mb-4 line-clamp-2">
      {description}
    </p>

    <div class="flex flex-wrap gap-2 pt-3 border-t border-sand-100">
      {tags.map((tag) => (
        <span class="text-xs font-medium text-brand-600 bg-brand-50 px-3 py-1 rounded-full">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
