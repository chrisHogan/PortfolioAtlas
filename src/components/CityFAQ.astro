---
import type { CityData } from '../data/types';
import { formatCurrency, getTotalSpend } from '../data/types';

interface Props {
  city: CityData;
}

const { city } = Astro.props;

const tier1M = city.tiers['1M'];
const tier3M = city.tiers['3M'];
const totalSpend1M = getTotalSpend(tier1M);
const totalSpend3M = getTotalSpend(tier3M);

const faqs = [
  {
    question: `What is the cost of living in ${city.name}, ${city.country} for retirees?`,
    answer: `With a $1M portfolio (${formatCurrency(tier1M.monthlyBudget)}/month at 4% withdrawal rate), monthly living costs in ${city.name} total roughly ${formatCurrency(totalSpend1M)}, covering housing, dining, groceries, healthcare, transportation, entertainment, and utilities. With a $3M portfolio (${formatCurrency(tier3M.monthlyBudget)}/month), you can expect to spend about ${formatCurrency(totalSpend3M)}/month for a significantly more comfortable lifestyle.`,
  },
  {
    question: `How much does housing cost in ${city.name}?`,
    answer: `Housing in ${city.name} ranges from ${formatCurrency(tier1M.housing.monthlyCost)}/month for ${tier1M.housing.description.toLowerCase()} to ${formatCurrency(tier3M.housing.monthlyCost)}/month for ${tier3M.housing.description.toLowerCase()}. At higher portfolio levels ($5M+), luxury options are available from ${formatCurrency(city.tiers['5M'].housing.monthlyCost)}/month.`,
  },
  {
    question: `What is healthcare like in ${city.name} for expats and retirees?`,
    answer: `Healthcare in ${city.name} costs approximately ${formatCurrency(tier1M.healthcare.monthlyCost)} to ${formatCurrency(tier3M.healthcare.monthlyCost)}/month depending on coverage level. ${tier1M.healthcare.description}. At higher budgets, ${tier3M.healthcare.description.toLowerCase()}.`,
  },
  {
    question: `Do I need a visa to retire in ${city.name}, ${city.country}?`,
    answer: city.quickFacts.visa,
  },
  {
    question: `What is the weather like in ${city.name}?`,
    answer: `${city.quickFacts.climate} The average temperature is ${city.quickFacts.averageTemp}.`,
  },
  {
    question: `Is ${city.name} English-friendly?`,
    answer: `English proficiency in ${city.name} is rated "${city.quickFacts.englishFriendly}." The primary language is ${city.quickFacts.language}. ${city.quickFacts.englishFriendly === 'High' ? 'You can navigate daily life comfortably in English.' : city.quickFacts.englishFriendly === 'Moderate' ? 'Learning some basic local phrases will help, but you can get by in tourist areas and with younger locals.' : 'Learning the local language is strongly recommended for daily life, though some English is spoken in tourist areas.'}`,
  },
  {
    question: `How safe is ${city.name} for retirees?`,
    answer: city.quickFacts.safetyRating,
  },
  {
    question: `Can I retire in ${city.name} with $1 million?`,
    answer: `With a $1M portfolio generating ${formatCurrency(tier1M.monthlyBudget)}/month at a 4% safe withdrawal rate, your monthly expenses in ${city.name} would be approximately ${formatCurrency(totalSpend1M)}. That leaves a ${totalSpend1M <= tier1M.monthlyBudget ? `surplus of ${formatCurrency(tier1M.monthlyBudget - totalSpend1M)}/month` : `deficit of ${formatCurrency(totalSpend1M - tier1M.monthlyBudget)}/month, meaning $1M may be tight here`}. ${tier1M.lifestyle}`,
  },
];
---

<section class="mt-12 pt-8 border-t border-sand-200">
  <h2 class="font-serif text-2xl font-bold text-brand-950 mb-6">
    Frequently Asked Questions About Retiring in {city.name}
  </h2>

  <div class="space-y-4">
    {faqs.map((faq) => (
      <details class="bg-white rounded-xl border border-sand-200 group">
        <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none font-medium text-gray-800 hover:bg-sand-50 rounded-xl transition-colors">
          <span class="pr-4 text-sm">{faq.question}</span>
          <svg class="w-4 h-4 text-gray-400 shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4">
          <p class="text-sm text-gray-600 leading-relaxed">{faq.answer}</p>
        </div>
      </details>
    ))}
  </div>
</section>
