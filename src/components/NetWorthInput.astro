---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class="net-worth-input" data-compact={compact ? 'true' : undefined}>
  <form id="nw-form" action="/calculator" method="GET" class={compact ? '' : 'max-w-lg mx-auto'}>
    <label for="nw-input" class={`block font-semibold mb-2 ${compact ? 'text-sm text-gray-700' : 'text-lg text-white'}`}>
      Enter your portfolio value
    </label>

    <div class="flex gap-2">
      <div class="relative flex-1">
        <span class={`absolute left-4 top-1/2 -translate-y-1/2 font-bold ${compact ? 'text-gray-500 text-base' : 'text-brand-300 text-xl'}`}>$</span>
        <input
          type="text"
          id="nw-input"
          name="nw"
          inputmode="numeric"
          placeholder="5,200,000"
          autocomplete="off"
          class:list={[
            'w-full rounded-xl font-bold focus:outline-none focus:ring-2 focus:ring-brand-400',
            compact
              ? 'pl-8 pr-4 py-2.5 text-base bg-white border border-sand-200 text-gray-900'
              : 'pl-10 pr-4 py-4 text-2xl bg-white/10 backdrop-blur-sm border border-white/20 text-white placeholder-white/40',
          ]}
        />
      </div>
      <button
        type="submit"
        class:list={[
          'font-semibold rounded-xl transition-colors shrink-0',
          compact
            ? 'px-5 py-2.5 text-sm bg-brand-600 text-white hover:bg-brand-700'
            : 'px-8 py-4 text-lg bg-white text-brand-950 hover:bg-sand-100',
        ]}
      >
        Calculate
      </button>
    </div>

    {!compact && (
      <div class="flex flex-wrap justify-center gap-2 mt-4">
        {[1_000_000, 2_000_000, 3_000_000, 5_000_000, 10_000_000].map((value) => (
          <button
            type="button"
            class="nw-quick-btn px-4 py-1.5 text-sm font-medium rounded-full bg-white/10 border border-white/20 text-white/80 hover:bg-white/20 hover:text-white transition-all"
            data-value={value}
          >
            ${value / 1_000_000}M
          </button>
        ))}
      </div>
    )}

    <div id="nw-preview" class={`mt-3 text-sm font-medium ${compact ? 'text-gray-500' : 'text-brand-200'} hidden`}>
      Monthly budget: <span id="nw-preview-amount" class={compact ? 'text-brand-600 font-bold' : 'text-white font-bold'}></span>/mo
    </div>
  </form>
</div>

<script>
  function initNetWorthInput() {
    const input = document.getElementById('nw-input') as HTMLInputElement;
    const form = document.getElementById('nw-form') as HTMLFormElement;
    const preview = document.getElementById('nw-preview') as HTMLElement;
    const previewAmount = document.getElementById('nw-preview-amount') as HTMLElement;
    const quickBtns = document.querySelectorAll('.nw-quick-btn');

    if (!input || !form) return;

    function formatWithCommas(val: string): string {
      const num = val.replace(/[^0-9]/g, '');
      return num.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    function getRawValue(): number {
      return parseInt(input.value.replace(/[^0-9]/g, ''), 10) || 0;
    }

    function updatePreview() {
      const raw = getRawValue();
      if (raw > 0 && preview && previewAmount) {
        const monthly = Math.round((raw * 0.04) / 12);
        previewAmount.textContent = '$' + monthly.toLocaleString('en-US');
        preview.classList.remove('hidden');
      } else if (preview) {
        preview.classList.add('hidden');
      }
    }

    input.addEventListener('input', () => {
      const pos = input.selectionStart || 0;
      // Count digits before cursor in the old value
      const digitsBefore = input.value.slice(0, pos).replace(/[^0-9]/g, '').length;
      input.value = formatWithCommas(input.value);
      // Find the position after the same number of digits in the new value
      let newPos = 0;
      let counted = 0;
      for (let i = 0; i < input.value.length && counted < digitsBefore; i++) {
        if (/[0-9]/.test(input.value[i])) counted++;
        newPos = i + 1;
      }
      input.setSelectionRange(newPos, newPos);
      updatePreview();
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const raw = getRawValue();
      if (raw > 0) {
        // Preserve existing filter params (loc, climate, eng)
        const params = new URLSearchParams(window.location.search);
        const filterParams = new URLSearchParams();
        filterParams.set('nw', String(raw));
        for (const key of ['loc', 'climate', 'eng']) {
          const val = params.get(key);
          if (val) filterParams.set(key, val);
        }
        window.location.href = `/calculator?${filterParams.toString()}`;
      }
    });

    quickBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const value = parseInt((btn as HTMLElement).dataset.value || '0', 10);
        if (value > 0) {
          input.value = value.toLocaleString('en-US');
          updatePreview();
        }
      });
    });

    // Pre-fill from URL if on calculator page
    const params = new URLSearchParams(window.location.search);
    const nw = params.get('nw');
    if (nw) {
      const val = parseInt(nw, 10);
      if (val > 0) {
        input.value = val.toLocaleString('en-US');
        updatePreview();
      }
    }
  }

  initNetWorthInput();
</script>
