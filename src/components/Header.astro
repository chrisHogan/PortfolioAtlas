---
import { allCities } from '../data/cities/index';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const searchCities = allCities.map(c => ({ name: c.name, country: c.country, slug: c.slug, emoji: c.emoji }));
---

<header class="bg-white/80 backdrop-blur-md border-b border-sand-200 sticky top-0 z-50">
  <nav class="container-wide flex items-center justify-between h-16">
    <a href="/" id="logo-link" class="flex items-center gap-2 group">
      <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <span class="font-serif font-bold text-xl text-brand-950 group-hover:text-brand-700 transition-colors">
        Portfolio<span class="text-brand-600">Atlas</span>
      </span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a
        href="/"
        class:list={[
          'text-sm font-medium transition-colors',
          currentPath === '/' ? 'text-brand-600' : 'text-gray-600 hover:text-brand-600',
        ]}
      >
        Explore
      </a>
      <a
        href="/retire-in"
        class:list={[
          'text-sm font-medium transition-colors',
          currentPath.startsWith('/retire-in') ? 'text-brand-600' : 'text-gray-600 hover:text-brand-600',
        ]}
      >
        By Country
      </a>
      <a
        href="/compare"
        class:list={[
          'text-sm font-medium transition-colors',
          currentPath.startsWith('/compare') ? 'text-brand-600' : 'text-gray-600 hover:text-brand-600',
        ]}
      >
        Compare
      </a>
      <a
        href="/blog"
        class:list={[
          'text-sm font-medium transition-colors',
          currentPath.startsWith('/blog') ? 'text-brand-600' : 'text-gray-600 hover:text-brand-600',
        ]}
      >
        Blog
      </a>
      <a
        href="/about"
        class:list={[
          'text-sm font-medium transition-colors',
          currentPath === '/about' ? 'text-brand-600' : 'text-gray-600 hover:text-brand-600',
        ]}
      >
        About
      </a>

      <!-- Desktop city search -->
      <div class="relative" id="desktop-search-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="desktop-search-input"
          placeholder="Search cities..."
          autocomplete="off"
          class="w-48 focus:w-64 transition-all pl-9 pr-3 py-1.5 text-sm rounded-xl bg-white border border-sand-200 text-gray-800 placeholder-gray-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none"
        />
        <div id="desktop-search-dropdown" class="header-search-dropdown hidden"></div>
      </div>

      <span id="header-nw-badge" class="hidden items-center gap-1.5 px-3 py-1 bg-brand-50 border border-brand-200 rounded-full text-xs font-semibold text-brand-700">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        <span id="header-nw-value"></span>
        <button id="header-reset-btn" type="button" class="ml-1 -mr-1 p-0.5 rounded-full hover:bg-brand-200 transition-colors" aria-label="Reset all data" title="Reset all data">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>
    </div>

    <!-- Mobile: search icon + hamburger -->
    <div class="flex items-center gap-1 md:hidden">
      <button
        id="mobile-search-btn"
        class="p-2 text-gray-600 hover:text-brand-600"
        aria-label="Search cities"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>
      <button
        id="mobile-menu-btn"
        class="p-2 text-gray-600 hover:text-brand-600"
        aria-label="Toggle menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile search panel -->
  <div id="mobile-search-panel" class="hidden md:hidden border-t border-sand-200 bg-white">
    <div class="container-wide py-3 relative">
      <div class="relative">
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="mobile-search-input"
          placeholder="Search cities..."
          autocomplete="off"
          class="w-full pl-9 pr-3 py-2.5 text-sm rounded-xl bg-sand-50 border border-sand-200 text-gray-800 placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none"
        />
        <div id="mobile-search-dropdown" class="header-search-dropdown hidden"></div>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-sand-200 bg-white">
    <div class="container-wide py-4 flex flex-col gap-3">
      <a href="/" class:list={['text-sm font-medium py-1', currentPath === '/' ? 'text-brand-600' : 'text-gray-600 hover:text-brand-600']}>Explore</a>
      <a href="/retire-in" class:list={['text-sm font-medium py-1', currentPath.startsWith('/retire-in') ? 'text-brand-600' : 'text-gray-600 hover:text-brand-600']}>By Country</a>
      <a href="/compare" class:list={['text-sm font-medium py-1', currentPath.startsWith('/compare') ? 'text-brand-600' : 'text-gray-600 hover:text-brand-600']}>Compare</a>
      <a href="/blog" class:list={['text-sm font-medium py-1', currentPath.startsWith('/blog') ? 'text-brand-600' : 'text-gray-600 hover:text-brand-600']}>Blog</a>
      <a href="/about" class:list={['text-sm font-medium py-1', currentPath === '/about' ? 'text-brand-600' : 'text-gray-600 hover:text-brand-600']}>About</a>
    </div>
  </div>
</header>

<style is:global>
  .header-search-dropdown {
    position: absolute;
    top: 100%;
    left: -1px;
    right: -1px;
    z-index: 50;
    max-height: 280px;
    overflow-y: auto;
    background: white;
    border: 2px solid #3b82f6;
    border-top: 1px solid #e5e7eb;
    border-radius: 0 0 0.75rem 0.75rem;
    box-shadow: 0 12px 24px -4px rgba(0,0,0,0.12);
    margin-top: 0;
    padding: 4px;
  }
  .header-search-dropdown .search-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    cursor: pointer;
    border-radius: 0.5rem;
    transition: background 0.1s;
  }
  .header-search-dropdown .search-item .search-city {
    font-weight: 600;
    color: #1f2937;
    font-size: 0.875rem;
  }
  .header-search-dropdown .search-item .search-country {
    margin-left: auto;
    color: #9ca3af;
    font-size: 0.75rem;
    font-weight: 400;
    white-space: nowrap;
  }
  .header-search-dropdown .search-item:hover,
  .header-search-dropdown .search-item.highlighted {
    background: #f3f4f6;
  }
  /* When dropdown is open, flatten input bottom corners to connect */
  .search-input-open {
    border-bottom-left-radius: 0 !important;
    border-bottom-right-radius: 0 !important;
    border-bottom-color: #e5e7eb !important;
    border-color: #3b82f6 !important;
  }
</style>

<script id="search-cities-data" type="application/json" set:html={JSON.stringify(searchCities)}></script>
<script is:inline>
(function() {
  var dataEl = document.getElementById('search-cities-data');
  if (!dataEl) return;
  var cities = JSON.parse(dataEl.textContent);

  function initSearch(inputId, dropdownId) {
    var input = document.getElementById(inputId);
    var dropdown = document.getElementById(dropdownId);
    if (!input || !dropdown) return;

    var highlightIdx = -1;
    var currentMatches = [];

    function showDropdown() {
      dropdown.classList.remove('hidden');
      input.classList.add('search-input-open');
    }

    function hideDropdown() {
      dropdown.classList.add('hidden');
      input.classList.remove('search-input-open');
    }

    function renderDropdown() {
      var q = input.value.toLowerCase().trim();

      currentMatches = (!q ? cities.slice() : cities.filter(function(c) {
        return c.name.toLowerCase().includes(q) || c.country.toLowerCase().includes(q);
      })).sort(function(a, b) { return a.name.localeCompare(b.name); });

      highlightIdx = -1;

      if (currentMatches.length === 0) {
        dropdown.innerHTML = '<div style="padding:0.75rem;text-align:center;font-size:0.875rem;color:#9ca3af;">No cities found</div>';
      } else {
        dropdown.innerHTML = currentMatches.map(function(c, i) {
          return '<div class="search-item" data-idx="' + i + '" data-slug="' + c.slug + '">' +
            '<span>' + c.emoji + '</span>' +
            '<span class="search-city">' + c.name + '</span>' +
            '<span class="search-country">' + c.country + '</span>' +
            '</div>';
        }).join('');

        dropdown.querySelectorAll('.search-item').forEach(function(item) {
          item.addEventListener('mousedown', function(e) {
            e.preventDefault();
            window.location.href = '/cities/' + item.dataset.slug + '/';
          });
        });
      }
      showDropdown();
    }

    function updateHighlight() {
      var items = dropdown.querySelectorAll('.search-item');
      for (var i = 0; i < items.length; i++) {
        if (i === highlightIdx) {
          items[i].classList.add('highlighted');
          items[i].scrollIntoView({ block: 'nearest' });
        } else {
          items[i].classList.remove('highlighted');
        }
      }
    }

    input.addEventListener('input', renderDropdown);

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        hideDropdown();
        input.blur();
        return;
      }
      if (currentMatches.length === 0) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (highlightIdx < currentMatches.length - 1) highlightIdx++;
        updateHighlight();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (highlightIdx > 0) highlightIdx--;
        updateHighlight();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        var idx = highlightIdx >= 0 ? highlightIdx : 0;
        if (currentMatches[idx]) {
          window.location.href = '/cities/' + currentMatches[idx].slug + '/';
        }
      }
    });

    input.addEventListener('blur', function() {
      setTimeout(function() { hideDropdown(); }, 200);
    });

    input.addEventListener('focus', function() {
      renderDropdown();
    });
  }

  // Init both desktop and mobile search
  initSearch('desktop-search-input', 'desktop-search-dropdown');
  initSearch('mobile-search-input', 'mobile-search-dropdown');

  // Mobile search toggle
  var mobileSearchBtn = document.getElementById('mobile-search-btn');
  var mobileSearchPanel = document.getElementById('mobile-search-panel');
  var mobileSearchInput = document.getElementById('mobile-search-input');
  if (mobileSearchBtn && mobileSearchPanel) {
    mobileSearchBtn.addEventListener('click', function() {
      var isHidden = mobileSearchPanel.classList.contains('hidden');
      mobileSearchPanel.classList.toggle('hidden');
      if (isHidden && mobileSearchInput) {
        setTimeout(function() { mobileSearchInput.focus(); }, 50);
      }
    });
  }

  // Mobile menu toggle
  var menuBtn = document.getElementById('mobile-menu-btn');
  var menu = document.getElementById('mobile-menu');
  if (menuBtn && menu) {
    menuBtn.addEventListener('click', function() { menu.classList.toggle('hidden'); });
  }

  // Reset all stored state and navigate to clean homepage
  function resetAll() {
    try { localStorage.removeItem('pa_calc'); } catch (e) {}
    window.location.href = '/';
  }

  // Logo click: clear everything and go to clean homepage
  var logoLink = document.getElementById('logo-link');
  if (logoLink) {
    logoLink.addEventListener('click', function(e) {
      e.preventDefault();
      resetAll();
    });
  }

  // Reset button in NW badge
  var resetBtnEl = document.getElementById('header-reset-btn');
  if (resetBtnEl) {
    resetBtnEl.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      resetAll();
    });
  }

  // Show net worth badge from URL or localStorage
  var params = new URLSearchParams(window.location.search);
  var nw = params.get('portfolio') || params.get('nw');
  if (!nw) {
    try {
      var stored = localStorage.getItem('pa_calc');
      if (stored) { var s = JSON.parse(stored); if (s && s.nw) nw = String(s.nw); }
    } catch (e) {}
  }
  if (nw) {
    var val = parseInt(nw, 10);
    if (!isNaN(val) && val > 0) {
      var badge = document.getElementById('header-nw-badge');
      var valueEl = document.getElementById('header-nw-value');
      if (badge && valueEl) {
        var label;
        if (val >= 1000000) {
          var m = val / 1000000;
          label = m % 1 === 0 ? '$' + m + 'M' : '$' + m.toFixed(1) + 'M';
        } else {
          label = '$' + (val / 1000).toFixed(0) + 'K';
        }
        valueEl.textContent = label;
        badge.classList.remove('hidden');
        badge.classList.add('inline-flex');
      }
    }
  }
})();
</script>
