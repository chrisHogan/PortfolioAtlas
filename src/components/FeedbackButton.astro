<!-- Floating feedback button + modal -->
<button
  id="feedback-btn"
  type="button"
  class="fixed bottom-6 right-6 z-40 inline-flex items-center gap-2 px-5 py-2.5 bg-brand-600 text-white text-sm font-semibold rounded-full shadow-lg hover:bg-brand-700 transition-colors"
  aria-label="Share feedback"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
  </svg>
  <span class="hidden sm:inline">Share Feedback</span>
</button>

<!-- Modal overlay -->
<div id="feedback-overlay" class="fixed inset-0 z-50 hidden">
  <div id="feedback-backdrop" class="absolute inset-0 bg-black/50"></div>
  <div class="relative flex items-center justify-center min-h-full p-4">
    <div id="feedback-modal" class="relative w-full max-w-md bg-white rounded-2xl shadow-2xl overflow-hidden sm:my-8">
      <!-- Close button -->
      <button id="feedback-close" type="button" class="absolute top-4 right-4 p-1 text-gray-400 hover:text-gray-600 z-10" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="p-6 sm:p-8">
        <!-- Form state -->
        <div id="feedback-form-wrap">
          <h2 class="font-serif text-xl font-bold text-brand-950 mb-1">Share your feedback</h2>
          <p class="text-sm text-gray-500 mb-6">Help make PortfolioAtlas better. What's working, what's confusing, or what's missing?</p>

          <form id="feedback-form" novalidate>
            <!-- Message -->
            <div class="mb-4">
              <label for="fb-message" class="block text-sm font-semibold text-gray-700 mb-1">Feedback <span class="text-red-400">*</span></label>
              <textarea
                id="fb-message"
                rows="4"
                maxlength="2000"
                required
                placeholder="What's on your mind? City data corrections, missing features, confusing UI — all welcome."
                class="w-full rounded-lg border border-sand-200 px-3 py-2.5 text-sm text-gray-800 bg-sand-50 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 resize-y"
              ></textarea>
              <div class="flex justify-end mt-1">
                <span id="fb-char-count" class="text-xs text-gray-400">0 / 2000</span>
              </div>
            </div>

            <!-- Name -->
            <div class="mb-4">
              <label for="fb-name" class="block text-sm font-semibold text-gray-700 mb-1">Name</label>
              <input
                type="text"
                id="fb-name"
                placeholder="Optional"
                class="w-full rounded-lg border border-sand-200 px-3 py-2.5 text-sm text-gray-800 bg-sand-50 focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
              />
            </div>

            <!-- Email -->
            <div class="mb-5">
              <label for="fb-email" class="block text-sm font-semibold text-gray-700 mb-1">Email</label>
              <input
                type="email"
                id="fb-email"
                placeholder="Optional — only if you'd like a reply"
                class="w-full rounded-lg border border-sand-200 px-3 py-2.5 text-sm text-gray-800 bg-sand-50 focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
              />
              <p id="fb-email-error" class="text-xs text-red-500 mt-1 hidden">Please enter a valid email address.</p>
            </div>

            <!-- Submit -->
            <button
              id="fb-submit"
              type="submit"
              class="w-full py-3 text-sm font-bold rounded-xl bg-brand-600 text-white hover:bg-brand-700 transition-colors flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span id="fb-submit-text">Send Feedback</span>
              <svg id="fb-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
            </button>

            <p id="fb-error" class="text-sm text-red-500 mt-3 hidden"></p>
          </form>
        </div>

        <!-- Success state -->
        <div id="feedback-success" class="hidden text-center py-6">
          <div class="w-14 h-14 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-brand-950 mb-2">Thank you!</h3>
          <p class="text-sm text-gray-500 mb-6">Your feedback has been received. It genuinely helps.</p>
          <button id="feedback-success-close" type="button" class="px-6 py-2.5 text-sm font-semibold rounded-xl border border-sand-200 text-gray-700 hover:bg-sand-50 transition-colors">
            Close
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('feedback-btn');
  const overlay = document.getElementById('feedback-overlay');
  const backdrop = document.getElementById('feedback-backdrop');
  const closeBtn = document.getElementById('feedback-close');
  const successClose = document.getElementById('feedback-success-close');
  const form = document.getElementById('feedback-form') as HTMLFormElement | null;
  const formWrap = document.getElementById('feedback-form-wrap');
  const successWrap = document.getElementById('feedback-success');
  const messageEl = document.getElementById('fb-message') as HTMLTextAreaElement | null;
  const charCount = document.getElementById('fb-char-count');
  const emailInput = document.getElementById('fb-email') as HTMLInputElement | null;
  const emailError = document.getElementById('fb-email-error');
  const submitBtn = document.getElementById('fb-submit') as HTMLButtonElement | null;
  const submitText = document.getElementById('fb-submit-text');
  const spinner = document.getElementById('fb-spinner');
  const errorEl = document.getElementById('fb-error');

  function openModal() {
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function resetForm() {
    form?.reset();
    if (charCount) charCount.textContent = '0 / 2000';
    if (charCount) { charCount.classList.remove('text-red-500'); charCount.classList.add('text-gray-400'); }
    errorEl?.classList.add('hidden');
    emailError?.classList.add('hidden');
    formWrap?.classList.remove('hidden');
    successWrap?.classList.add('hidden');
  }

  btn?.addEventListener('click', () => {
    resetForm();
    openModal();
  });

  closeBtn?.addEventListener('click', closeModal);
  successClose?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay?.classList.contains('hidden')) {
      closeModal();
    }
  });

  // Character count
  messageEl?.addEventListener('input', () => {
    const len = messageEl.value.length;
    if (charCount) {
      charCount.textContent = `${len} / 2000`;
      if (len > 1800) {
        charCount.classList.add('text-red-500');
        charCount.classList.remove('text-gray-400');
      } else {
        charCount.classList.remove('text-red-500');
        charCount.classList.add('text-gray-400');
      }
    }
  });

  // Email validation on blur
  emailInput?.addEventListener('blur', () => {
    const val = emailInput.value.trim();
    if (val && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)) {
      emailError?.classList.remove('hidden');
    } else {
      emailError?.classList.add('hidden');
    }
  });

  // Submit
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl?.classList.add('hidden');

    const message = messageEl?.value.trim() || '';
    if (!message) {
      if (errorEl) { errorEl.textContent = 'Please enter your feedback.'; errorEl.classList.remove('hidden'); }
      return;
    }

    const email = emailInput?.value.trim() || '';
    if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailError?.classList.remove('hidden');
      return;
    }

    // Disable button, show spinner
    if (submitBtn) submitBtn.disabled = true;
    submitText?.classList.add('hidden');
    spinner?.classList.remove('hidden');

    try {
      const res = await fetch('/api/feedback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message,
          name: (document.getElementById('fb-name') as HTMLInputElement)?.value.trim() || '',
          email,
        }),
      });

      if (res.status === 429) {
        if (errorEl) {
          errorEl.textContent = "You've submitted a few times recently. Please wait a bit before sending more feedback.";
          errorEl.classList.remove('hidden');
        }
        return;
      }

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        if (errorEl) {
          errorEl.textContent = data.error || 'Something went wrong. Please try again or email chris@portfolioatlas.org directly.';
          errorEl.classList.remove('hidden');
        }
        return;
      }

      // Success
      formWrap?.classList.add('hidden');
      successWrap?.classList.remove('hidden');
    } catch {
      if (errorEl) {
        errorEl.textContent = 'Something went wrong. Please try again or email chris@portfolioatlas.org directly.';
        errorEl.classList.remove('hidden');
      }
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      submitText?.classList.remove('hidden');
      spinner?.classList.add('hidden');
    }
  });
</script>
