---
import type { TierCostBreakdown, TierKey } from '../data/types';
import { TIER_LABELS, formatCurrency, getTotalSpend } from '../data/types';

interface Props {
  tierKey: TierKey;
  tier: TierCostBreakdown;
  cityName: string;
}

const { tierKey, tier, cityName } = Astro.props;

const totalSpend = getTotalSpend(tier);

const surplus = tier.monthlyBudget - totalSpend;

const costItems = [
  { label: 'Housing', cost: tier.housing.monthlyCost, description: tier.housing.description, color: 'bg-brand-500' },
  { label: 'Dining Out', cost: tier.dining.monthlyCost, description: tier.dining.description, color: 'bg-amber-500' },
  { label: 'Groceries', cost: tier.groceries.monthlyCost, description: null, color: 'bg-emerald-500' },
  { label: 'Healthcare', cost: tier.healthcare.monthlyCost, description: tier.healthcare.description, color: 'bg-red-400' },
  { label: 'Transportation', cost: tier.transportation.monthlyCost, description: tier.transportation.description, color: 'bg-purple-500' },
  { label: 'Entertainment', cost: tier.entertainment.monthlyCost, description: tier.entertainment.description, color: 'bg-pink-500' },
  { label: 'Utilities', cost: tier.utilities.monthlyCost, description: null, color: 'bg-gray-400' },
];

if (tier.domesticHelp) {
  costItems.push({
    label: 'Domestic Help',
    cost: tier.domesticHelp.monthlyCost,
    description: tier.domesticHelp.description,
    color: 'bg-teal-500',
  });
}

if (tier.luxuryExtras) {
  costItems.push({
    label: 'Luxury & Extras',
    cost: tier.luxuryExtras.monthlyCost,
    description: tier.luxuryExtras.description,
    color: 'bg-yellow-500',
  });
}
---

<div class="tier-card" id={`tier-${tierKey}`}>
  <!-- Tier Header -->
  <div class="flex items-center justify-between mb-6 pb-4 border-b border-sand-200">
    <div>
      <h3 class="font-serif text-2xl font-bold text-brand-950">
        {TIER_LABELS[tierKey]} Portfolio
      </h3>
      <p class="text-sm text-gray-500 mt-1">
        {formatCurrency(tier.monthlyBudget)}/month at 4% safe withdrawal rate
      </p>
    </div>
    <div class="text-right">
      <div class="text-2xl font-bold text-brand-600">
        {formatCurrency(tier.monthlyBudget)}
      </div>
      <div class="text-xs text-gray-500">per month</div>
    </div>
  </div>

  <!-- Cost Breakdown -->
  <div class="space-y-3 mb-6">
    {costItems.map((item) => (
      <div class="group">
        <div class="flex items-center justify-between mb-1">
          <div class="flex items-center gap-2">
            <div class={`w-3 h-3 rounded-full ${item.color}`}></div>
            <span class="text-sm font-medium text-gray-700">{item.label}</span>
          </div>
          <span class="text-sm font-semibold text-gray-900">
            {formatCurrency(item.cost)}
          </span>
        </div>
        {item.description && (
          <p class="text-xs text-gray-500 ml-5 leading-relaxed">
            {item.description}
          </p>
        )}
        <!-- Cost bar -->
        <div class="ml-5 mt-1 h-1.5 bg-sand-100 rounded-full overflow-hidden">
          <div
            class={`h-full rounded-full ${item.color} opacity-60`}
            style={`width: ${Math.min((item.cost / tier.monthlyBudget) * 100, 100)}%`}
          ></div>
        </div>
      </div>
    ))}
  </div>

  <!-- Total & Surplus -->
  <div class="bg-sand-50 rounded-xl p-4 mb-6">
    <div class="flex justify-between items-center mb-2">
      <span class="text-sm font-medium text-gray-600">Total Monthly Spend</span>
      <span class="text-lg font-bold text-gray-900">{formatCurrency(totalSpend)}</span>
    </div>
    <div class="flex justify-between items-center">
      <span class="text-sm font-medium text-gray-600">
        {surplus >= 0 ? 'Monthly Surplus' : 'Monthly Deficit'}
      </span>
      <span class:list={[
        'text-lg font-bold',
        surplus >= 0 ? 'text-emerald-600' : 'text-red-600',
      ]}>
        {surplus >= 0 ? '+' : ''}{formatCurrency(surplus)}
      </span>
    </div>
  </div>

  <!-- Lifestyle Description -->
  <div class="bg-brand-50 rounded-xl p-4">
    <h4 class="text-sm font-semibold text-brand-800 mb-2">
      What life looks like in {cityName}
    </h4>
    <p class="text-sm text-brand-900 leading-relaxed">
      {tier.lifestyle}
    </p>
  </div>
</div>
