---
import type { TierCostBreakdown, TierKey } from '../data/types';
import { TIER_LABELS, formatCurrency, getTotalSpend } from '../data/types';
import { TIER_DESCRIPTIONS } from '../data/spendingProfile';
import { SUSTAINABILITY_FOOTNOTE } from '../data/sustainability';

interface Props {
  tierKey: TierKey;
  tier: TierCostBreakdown;
  cityName: string;
}

const { tierKey, tier, cityName } = Astro.props;

const totalSpend = getTotalSpend(tier);

const TIER_LIFESTYLE: Record<TierKey, string> = {
  '1M': 'Budget',
  '2M': 'Budget+',
  '3M': 'Comfortable',
  '5M': 'Premium',
  '10M': 'Luxury',
};

const lifestyleLabel = TIER_LIFESTYLE[tierKey];
const tierDescription = TIER_DESCRIPTIONS[lifestyleLabel] || '';
---

<div class="accordion-tier" id={`tier-${tierKey}`} data-tier={tierKey} data-open="false" data-total-spend={totalSpend} data-budget={tier.monthlyBudget}>
  <!-- Accordion Header (always visible) -->
  <button class="accordion-header" type="button" aria-expanded="false">
    <div class="flex items-center gap-3 flex-wrap">
      <h3 class="font-serif text-xl font-bold text-brand-950">
        {TIER_LABELS[tierKey]} Portfolio
      </h3>
      <div>
        <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-brand-100 text-brand-700">
          {lifestyleLabel} Lifestyle
        </span>
        {tierDescription && (
          <p class="text-xs text-gray-400 mt-1">{tierDescription}</p>
        )}
      </div>
      <span class="text-sm text-gray-500">
        {formatCurrency(tier.monthlyBudget)}/mo
      </span>
    </div>
    <div class="flex items-center gap-3">
      <span class="accordion-preview text-sm font-medium">
        <span class="text-gray-500">{formatCurrency(totalSpend)}/mo est.</span>
      </span>
      <span class="tier-signal hidden"></span>
      <svg class="accordion-chevron w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </button>

  <!-- Accordion Body (collapsible) -->
  <div class="accordion-body">
    <div class="accordion-body-inner">
      <div class="tier-card-body">
        <!-- Lifestyle Description (prominent) -->
        <div class="bg-brand-50 rounded-xl p-5 mb-5">
          <h4 class="text-sm font-semibold text-brand-800 mb-2">
            What life looks like in {cityName}
          </h4>
          <p class="text-sm text-brand-900 leading-relaxed">
            {tier.lifestyle}
          </p>
        </div>

        <!-- Total estimated cost + sustainability signal -->
        <div class="bg-sand-50 rounded-xl p-4 mb-4">
          <div class="flex justify-between items-center">
            <span class="text-sm font-medium text-gray-600">Estimated Monthly Cost</span>
            <span class="text-lg font-bold text-gray-900">{formatCurrency(totalSpend)}</span>
          </div>
          <div class="flex justify-between items-center mt-2">
            <span class="text-sm font-medium text-gray-600">Available per Month</span>
            <span class="text-lg font-bold text-brand-600">{formatCurrency(tier.monthlyBudget)}</span>
          </div>
          <div class="tier-sustainability-signal mt-3 pt-3 border-t border-sand-200 hidden"></div>
        </div>

        <p class="text-[10px] text-gray-400 mb-4">
          Costs are estimates and vary by personal spending habits, exchange rates, and lifestyle choices.
        </p>

        <p class="tier-footnote text-[10px] text-gray-400 hidden">
          {SUSTAINABILITY_FOOTNOTE}
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  // Show sustainability signal when user has a portfolio set
  (function() {
    const params = new URLSearchParams(window.location.search);
    let nw = params.get('nw');
    if (!nw) {
      try {
        const stored = JSON.parse(localStorage.getItem('pa_calc') || '{}');
        if (stored.nw) nw = String(stored.nw);
      } catch (e) {}
    }
    if (!nw) return;

    const portfolioValue = parseInt(nw, 10);
    if (isNaN(portfolioValue) || portfolioValue <= 0) return;
    const budget = Math.round((portfolioValue * 0.04) / 12);

    document.querySelectorAll('.accordion-tier').forEach((el) => {
      const totalSpend = parseFloat(el.getAttribute('data-total-spend') || '0');
      const ratio = totalSpend / budget;

      let label: string, colorClass: string, dotClass: string;
      if (ratio <= 0.95) {
        label = 'Sustainable'; colorClass = 'text-emerald-600'; dotClass = 'bg-emerald-500';
      } else if (ratio <= 1.0) {
        label = 'Borderline'; colorClass = 'text-amber-600'; dotClass = 'bg-amber-400';
      } else {
        label = 'Not sustainable'; colorClass = 'text-gray-500'; dotClass = 'bg-gray-400';
      }

      // Header signal badge
      const headerSignal = el.querySelector('.tier-signal');
      if (headerSignal) {
        headerSignal.innerHTML = `<span class="inline-flex items-center gap-1 text-xs font-medium ${colorClass}"><span class="w-1.5 h-1.5 rounded-full ${dotClass} inline-block"></span>${label}</span>`;
        headerSignal.classList.remove('hidden');
      }

      // Body signal area
      const bodySignal = el.querySelector('.tier-sustainability-signal');
      if (bodySignal) {
        bodySignal.innerHTML = `<div class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full ${dotClass}"></span><span class="text-sm font-semibold ${colorClass}">${label}</span></div>`;
        bodySignal.classList.remove('hidden');
      }

      // Show footnote
      const footnote = el.querySelector('.tier-footnote');
      if (footnote) footnote.classList.remove('hidden');
    });
  })();
</script>
